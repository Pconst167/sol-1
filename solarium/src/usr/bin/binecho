#include "lib/token.h"

char arg[512];
char *s;

void main(){
  prog = 0x0000; // Beginning of arguments buffer
  s = arg;

  for(;;){
    if(*prog == '\0') break;
    else *s++ == *prog++;
  }

  asm{
    mov a, 0
    mov [prog], a			; move tokennizer pointer to the beginning of the arguments area (address 0)
    call get_arg			; read argument line
    mov d, tokstr
    call _puts
    call printnl
    syscall sys_terminate_proc
  }
}