0151   051B             ;; CD
0152   051B             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0153   051B             ; search for given directory inside current dir
0154   051B             ; if found, read its LBA, and switch directories
0155   051B             ; example:  cd /usr/bin; ls
0156   051B             ;       cd /usr/bin;
0157   051B             ;      cd /usr/bin
0158   051B             cmd_cd:
0159   051B 07 34 12      call get_token
0160   051E 1D D6 13      mov al, [tok]
0161   0521 B9 14         cmp al, TOK_END
0162   0523 C6 4D 05      je cmd_cd_gotohome
0163   0526 B9 06         cmp al, TOK_SEMI
0164   0528 C6 4D 05      je cmd_cd_gotohome
0165   052B B9 08         cmp al, TOK_TILDE
0166   052D C6 4D 05      je cmd_cd_gotohome
0167   0530 07 BA 13      call _putback
0168   0533 07 DD 11      call get_path    ; get the path for the cd command
0169   0536             cmd_cd_syscall:
0170   0536 3B D7 13      mov d, tokstr
0171   0539 19 13         mov al, 19
0172   053B 05 04         syscall sys_filesystem  ; get dirID in A
0173   053D AF FF FF      cmp a, $FFFF
0174   0540 C6 5E 05      je cmd_cd_fail
0175   0543 27            mov b, a
0176   0544 19 03         mov al, 3
0177   0546 05 04         syscall sys_filesystem  ; set dir to B
0178   0548             
0179   0548             ; apply 'ls' to the directory
0180   0548 19 04       	mov al, 4
0181   054A 05 04       	syscall sys_filesystem
0182   054C 09            ret
0183   054D             cmd_cd_gotohome:
0184   054D 07 BA 13      call _putback
0185   0550 FD 4D 0A 06   mov si, homedir
0186   0554 FD 4F D7 13   mov di, tokstr
0187   0558 07 C5 0D      call _strcpy
0188   055B 0A 36 05      jmp cmd_cd_syscall
0189   055E             cmd_cd_fail:
0190   055E 09            ret
0191   055F             
0192   055F             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0193   055F             ;; EXEC/OPEN PROGRAM/FILE
0194   055F             ;; 'filename' maps to '$path/filename'
0195   055F             ;; './file' or '/a/directory/file' loads a file directly
0196   055F             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0197   055F             cmd_exec:
0198   055F BC D6 13 14   cmp byte[tok], TOK_END
0199   0563 C6 E9 05      je cmd_exec_ret    ; check for NULL input
0200   0566 07 DD 11      call get_path    ; get file path 
0201   0569 14 D3 13      mov a, [prog]
0202   056C D7            push a        ; save argument pointer
0203   056D FD 4D D7 13   mov si, tokstr
0204   0571 FD 4F 59 09   mov di, temp_data1
0205   0575 07 C5 0D      call _strcpy      ; copy filename for later
0206   0578 BC D7 13 2F   cmp byte[tokstr], '/'  ; check first character of path
0207   057C C6 DA 05      je cmd_exec_abs
0208   057F BC D7 13 2E   cmp byte[tokstr], '.'  ; check first character of path
0209   0583 C6 DA 05      je cmd_exec_abs
0210   0586 10 8A 06      mov a, path
0211   0589 42 D3 13      mov [prog], a    ; set token pointer to $path beginning
0212   058C             cmd_exec_L0:
0213   058C 07 DD 11      call get_path    ; get a path option
0214   058F FD 4D D7 13   mov si, tokstr
0215   0593 FD 4F 59 0B   mov di, temp_data
0216   0597 07 C5 0D      call _strcpy      ; firstly, form address from one of the '$path' addresses
0217   059A FD 4D 4D 07   mov si, s_fslash
0218   059E FD 4F 59 0B   mov di, temp_data
0219   05A2 07 D3 0D      call _strcat      ; add '/' in between $path component and filename
0220   05A5 FD 4D 59 09   mov si, temp_data1
0221   05A9 FD 4F 59 0B   mov di, temp_data
0222   05AD 07 D3 0D      call _strcat      ; now glue the given filename to the total path
0223   05B0 3B 59 0B      mov d, temp_data
0224   05B3 19 15         mov al, 21
0225   05B5 05 04         syscall sys_filesystem  ; now we check whether such a file exists. success code is given in A. if 0, file does not exist
0226   05B7 AF 00 00      cmp a, 0
0227   05BA C7 CA 05      jne cmd_exec_path_exists
0228   05BD 07 34 12      call get_token
0229   05C0 BC D6 13 06   cmp byte[tok], TOK_SEMI
0230   05C4 C7 8C 05      jne cmd_exec_L0    ; if not ';' at the end, then token must be a separator. so try another path
0231   05C7 0A EA 05      jmp cmd_exec_unknown
0232   05CA             cmd_exec_path_exists:
0233   05CA E4            pop a        ; retrieve token pointer which points to the arguments given
0234   05CB 42 D3 13      mov [prog], a
0235   05CE 07 A9 11      call get_arg    ; if however, $path/filename was found, then we execute it
0236   05D1 26 D7 13      mov b, tokstr
0237   05D4 3B 59 0B      mov d, temp_data
0238   05D7 05 05         syscall sys_spawn_proc
0239   05D9 09            ret
0240   05DA             cmd_exec_abs:  ; execute as absolute path
0241   05DA E4            pop a
