0243   05DE 07 F6 11      call get_arg
0244   05E1 26 24 14      mov b, tokstr
0245   05E4 3B 59 09      mov d, temp_data1  ;original filename
0246   05E7 05 05         syscall sys_spawn_proc
0247   05E9             cmd_exec_ret:
0248   05E9 09            ret
0249   05EA             cmd_exec_unknown:
0250   05EA E4            pop a
0251   05EB 09            ret
