0135   0502 3B 24 14      mov d, tokstr
0136   0505 FD 4F 24 15   mov di, shell_transient_area
0137   0509 19 14         mov al, 20
0138   050B 05 04         syscall sys_filesystem        ; read textfile 
0139   050D               
0140   050D 3B 24 15      mov d, shell_transient_area
0141   0510 13            mov a, d
0142   0511 42 20 14      mov [prog], a      ; reset tokenizer buffer pointer
0143   0514 07 56 04      call cmd_parser
0144   0517             
0145   0517 07 B0 0F      call printnl
