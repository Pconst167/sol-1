0008++ 065E             ; reverse a string
0009++ 065E             ; D = string address
0010++ 065E             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0011++ 065E             ; 01234
0012++ 065E             _strrev:
0013++ 065E 4B          	pusha
0014++ 065F 07 A5 06    	call _strlen	; length in C
0015++ 0662 12          	mov a, c
0016++ 0663 AF 01 00    	cmp a, 1
0017++ 0666 D0 80 06    	jleu _strrev_end	; check string length. string len must be > 1
0018++ 0669 7D          	dec a
