0020   0412 3B 70 04      mov d, s_prompt 
0021   0415 07 1F 07      call _puts
0022   0418 3B 85 04    	mov d, kernel_filename
0023   041B 19 06       	mov al, 6               ; mkbin
0024   041D 05 04       	syscall sys_filesystem      ; create the binary file for the kernel
0025   041F                                       ; we need to be on '/boot' here
0026   041F FD 4D 85 04   mov si, kernel_filename
0027   0423 FD 4F C5 04   mov di, kernel_fullpath
0028   0427 07 85 05      call _strcat             ; form full pathname for the kernel file
0029   042A 3B C5 04    	mov d, kernel_fullpath
0030   042D 19 13       	mov al, 19
0031   042F 05 04       	syscall sys_filesystem		; obtain dirID for kernel file, in A
0032   0431 27            mov b, a
0033   0432 FD 77       	inc b					; increment LBA because data starts after the header sector
0034   0434 19 03         mov al, 3
0035   0436 05 0C       	syscall sys_system
0036   0438             
0037   0438 05 0B       	syscall sys_terminate_proc
