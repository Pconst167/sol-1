0021   0415 07 67 07      call _puts
0022   0418 3B 84 04    	mov d, kernel_filename
0023   041B 19 06       	mov al, 6               ; mkbin
0024   041D 05 04       	syscall sys_filesystem      ; create the binary file for the kernel
0025   041F                                       ; we need to be on '/boot' here
0026   041F             
0027   041F FD 4D 84 04   mov si, kernel_filename
0028   0423 FD 4F C4 04   mov di, kernel_fullpath
0029   0427 07 84 05      call _strcat             ; form full pathname for the kernel file
0030   042A 3B C4 04    	mov d, kernel_fullpath
0031   042D 19 13       	mov al, 19
0032   042F 05 04       	syscall sys_filesystem		; obtain dirID for kernel file, in A
0033   0431 FD 77       	inc b					; increment LBA because data starts after the header sector
0034   0433 19 03         mov al, 3
0035   0435 05 0C       	syscall sys_system
0036   0437             
0037   0437 05 0B       	syscall sys_terminate_proc
