0776   0438             ide_read_sect:
0777   0438 1A            mov al, ah
0778   0439 24            mov ah, bl
0779   043A 42 D2 FF      mov [_ide_R2], a                ; number of sectors (0..255)
0780   043D 1C            mov al, bh
0781   043E 3D D4 FF      mov [_ide_R4], al
0782   0441 12            mov a, c
0783   0442 3D D5 FF      mov [_ide_R5], al
0784   0445 1A            mov al, ah
0785   0446 87 0F         and al, %00001111
0786   0448 8B E0         or al, %11100000                ; mode lba, master
0787   044A 3D D6 FF      mov [_ide_R6], al
0788   044D             ide_read_sect_wait:
0789   044D 1D D7 FF      mov al, [_ide_R7]  
0790   0450 93 80         test al, $80                     ; BUSY FLAG
0791   0452 C7 4D 04      jnz ide_read_sect_wait
0792   0455 19 20         mov al, $20
0793   0457 3D D7 FF      mov [_ide_R7], al               ; read sector cmd
0794   045A 07 84 04      call ide_read  
0795   045D 09            ret
0796   045E             ide_write_sect:
0797   045E 1A            mov al, ah
0798   045F 24            mov ah, bl
0799   0460 42 D2 FF      mov [_ide_R2], a                ; number of sectors (0..255)
0800   0463 1C            mov al, bh
0801   0464 3D D4 FF      mov [_ide_R4], al
0802   0467 12            mov a, c
0803   0468 3D D5 FF      mov [_ide_R5], al
0804   046B 1A            mov al, ah
0805   046C 87 0F         and al, %00001111
