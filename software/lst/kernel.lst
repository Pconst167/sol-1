1080   05E7             fs_mkfs:  
1081   05E7 06            sysret  
1082   05E8               
1083   05E8             fs_cd_root:
1084   05E8 10 20 00      mov a, root_id
1085   05EB 42 EA 16      mov [current_dirID], a      ; set current directory LBA to ROOT
1086   05EE 06            sysret  
1087   05EF             
1088   05EF             ; filename in D (userspace data)
1089   05EF             ; permission in BL
1090   05EF             fs_chmod:
1091   05EF DD            push bl
1092   05F0 FD 4E         mov si, d
1093   05F2 FD 4F D5 1B   mov di, user_data
1094   05F6 38 80 00      mov c, 128
1095   05F9 04            load                        ; load filename from user-space
1096   05FA 14 EA 16      mov a, [current_dirID]
1097   05FD 77            inc a                       ; metadata sector
1098   05FE 27            mov b, a
1099   05FF 38 00 00      mov c, 0                    ; reset LBA to 0
1100   0602 22 01         mov ah, $01                 ; disk read
1101   0604 3B D5 2F      mov d, transient_area
1102   0607 07 4E 04      call ide_read_sect          ; read directory
1103   060A FD 10         cla
1104   060C 42 E2 16      mov [index], a              ; reset file counter
1105   060F             fs_chmod_L1:
1106   060F FD 4E         mov si, d
1107   0611 FD 4F D5 1B   mov di, user_data
1108   0615 07 DD 0F      call _strcmp
1109   0618 C6 2F 06      je fs_chmod_found_entry
1110   061B 58 20 00      add d, 32
1111   061E 14 E2 16      mov a, [index]
1112   0621 77            inc a
1113   0622 42 E2 16      mov [index], a
1114   0625 AF 10 00      cmp a, FST_FILES_PER_DIR
1115   0628 C7 0F 06      jne fs_chmod_L1
1116   062B EA            pop bl
1117   062C 0A 48 06      jmp fs_chmod_not_found
1118   062F             fs_chmod_found_entry:  
1119   062F FD 79         mov g, b                    ; save LBA
1120   0631 EA            pop bl                      ; retrieve saved permission value
1121   0632 1F 18 00      mov al, [d + 24]            ; read file permissions
1122   0635 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1123   0637 8C            or al, bl                   ; set new permissions
1124   0638 3F 18 00      mov [d + 24], al            ; write new permissions
1125   063B 38 00 00      mov c, 0
1126   063E 3B D5 2F      mov d, transient_area
1127   0641 22 01         mov ah, $01                 ; disk write 1 sect
1128   0643 FD 27         mov b, g                    ; retrieve LBA
1129   0645 07 74 04      call ide_write_sect         ; write sector
1130   0648             fs_chmod_not_found:
1131   0648 06            sysret
1132   0649             
1133   0649             
1134   0649             ;------------------------------------------------------------------------------------------------------;
1135   0649             ; CREATE NEW DIRECTORY
1136   0649             ;------------------------------------------------------------------------------------------------------;
1137   0649             ; search list for NULL name entry. add new directory to list
1138   0649             fs_mkdir:
1139   0649 FD 4E         mov si, d
1140   064B FD 4F D5 1B   mov di, user_data
1141   064F 38 00 02      mov c, 512
1142   0652 04            load                        ; load data from user-space
1143   0653 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1144   0656                                           ; when checking for NULL name, since root has a NULL name)
1145   0656 38 00 00      mov c, 0                    ; reset LBA to 0
1146   0659             fs_mkdir_L1:  
1147   0659 22 01         mov ah, $01                 ; disk read
1148   065B 3B D5 2F      mov d, transient_area
1149   065E 07 4E 04      call ide_read_sect          ; read sector
1150   0661 BD 00         cmp byte[d], 0              ; check for NULL
1151   0663 C6 6C 06      je fs_mkdir_found_null
1152   0666 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1153   0669 0A 59 06      jmp fs_mkdir_L1
1154   066C             fs_mkdir_found_null:
1155   066C             ;create header file by grabbing dir name from parameter
1156   066C D8            push b                      ; save new directory's LBA
1157   066D 38 40 00      mov c, 64
1158   0670 FD 4D D5 1B   mov si, user_data
1159   0674 FD 4F D5 2F   mov di, transient_area
1160   0678 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1161   067A 14 EA 16      mov a, [current_dirID]
1162   067D 42 15 30      mov [transient_area + 64], a    ; store parent directory LBA
1163   0680 19 00         mov al, 0
1164   0682 FD 4F D5 31   mov di, transient_area + 512
1165   0686 38 00 02      mov c, 512
1166   0689 FD F7         rep stosb                       ; clean buffer
1167   068B 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1168   068E             ; write directory entry sectors
1169   068E 3B D5 2F      mov d, transient_area
1170   0691 22 02         mov ah, $02                     ; disk write, 2 sectors
1171   0693 07 74 04      call ide_write_sect             ; write sector
1172   0696             ; now we need to add the new directory to the list, insIDE the current directory
1173   0696 14 EA 16      mov a, [current_dirID]
1174   0699 53 01 00      add a, 1
1175   069C 27            mov b, a                        ; metadata sector
1176   069D 38 00 00      mov c, 0
1177   06A0 FD 79         mov g, b                        ; save LBA
1178   06A2 3B D5 2F      mov d, transient_area
1179   06A5 22 01         mov ah, $01                     ; disk read
1180   06A7 07 4E 04      call ide_read_sect              ; read metadata sector
1181   06AA             fs_mkdir_L2:
1182   06AA BD 00         cmp byte[d], 0
1183   06AC C6 B5 06      je fs_mkdir_found_null2
1184   06AF 58 20 00      add d, FST_ENTRY_SIZE
1185   06B2 0A AA 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1186   06B5             fs_mkdir_found_null2:
1187   06B5 FD 4D D5 1B   mov si, user_data
1188   06B9 FD 50         mov di, d
1189   06BB 07 F2 0F      call _strcpy                    ; copy directory name
1190   06BE 58 18 00      add d, 24                       ; goto ATTRIBUTES
1191   06C1 19 0B         mov al, %00001011               ; directory, no execute, write, read
1192   06C3 3E            mov [d], al      
1193   06C4 79            inc d
1194   06C5 E5            pop b
1195   06C6 D8            push b                          ; push LBA back
1196   06C7 FD 43         mov [d], b                      ; save LBA
1197   06C9             ; set file creation date  
1198   06C9 58 04 00      add d, 4
1199   06CC 19 04         mov al, 4
1200   06CE 05 01         syscall sys_rtc
1201   06D0 1A            mov al, ah
1202   06D1 3E            mov [d], al                     ; set day
1203   06D2 79            inc d
1204   06D3 19 05         mov al, 5
1205   06D5 05 01         syscall sys_rtc
1206   06D7 1A            mov al, ah
1207   06D8 3E            mov [d], al                     ; set month
1208   06D9 79            inc d
1209   06DA 19 06         mov al, 6
1210   06DC 05 01         syscall sys_rtc
1211   06DE 1A            mov al, ah
1212   06DF 3E            mov [d], al                     ; set year
1213   06E0             ; write sector into disk for new directory entry
1214   06E0 FD 27         mov b, g
1215   06E2 38 00 00      mov c, 0
1216   06E5 3B D5 2F      mov d, transient_area
1217   06E8 22 01         mov ah, $01                     ; disk write, 1 sector
1218   06EA 07 74 04      call ide_write_sect             ; write sector
1219   06ED             
1220   06ED             ; after adding the new directory's information to its parent directory's list
1221   06ED             ; we need to now enter the new directory, and to it add two new directories!
1222   06ED             ; which directories do we need to add ? '..' and '.' are the directories needed.
1223   06ED             ; importantly, note that these two new directories are only entries in the list
1224   06ED             ; and do not have actual physical entries in the disk as real directories.
1225   06ED             ; i.e. they only exist as list entries in the new directory created so that
1226   06ED             ; the new directory can reference its parent and itself.
1227   06ED             ; We need to add both '..' and '.'
1228   06ED             ; this first section is for '..' and on the section below we do the same for '.'
1229   06ED E4            pop a                         ; retrieve the new directory's LBA  
1230   06EE D7            push a                        ; and save again
1231   06EF 53 01 00      add a, 1
1232   06F2 27            mov b, a                      ; metadata sector
1233   06F3 38 00 00      mov c, 0
1234   06F6 FD 79         mov g, b                      ; save LBA
1235   06F8 3B D5 2F      mov d, transient_area
1236   06FB 22 01         mov ah, $01                   ; disk read
1237   06FD 07 4E 04      call ide_read_sect            ; read metadata sector
1238   0700             fs_mkdir_L3:
1239   0700 BD 00         cmp byte[d], 0
1240   0702 C6 0B 07      je fs_mkdir_found_null3
1241   0705 58 20 00      add d, FST_ENTRY_SIZE
1242   0708 0A 00 07      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1243   070B             fs_mkdir_found_null3:
1244   070B FD 4D F7 16   mov si, s_parent_dir
1245   070F FD 50         mov di, d
1246   0711 07 F2 0F      call _strcpy                  ; copy directory name
1247   0714 58 18 00      add d, 24                     ; goto ATTRIBUTES
1248   0717 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1249   0719 3E            mov [d], al      
1250   071A 79            inc d
1251   071B 29 EA 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1252   071E FD 43         mov [d], b                    ; save LBA
1253   0720             ; set file creation date  
1254   0720 58 04 00      add d, 4
1255   0723 19 04         mov al, 4
1256   0725 05 01         syscall sys_rtc
1257   0727 1A            mov al, ah
1258   0728 3E            mov [d], al                   ; set day
1259   0729 79            inc d
1260   072A 19 05         mov al, 5
1261   072C 05 01         syscall sys_rtc
1262   072E 1A            mov al, ah
1263   072F 3E            mov [d], al                   ; set month
1264   0730 79            inc d
1265   0731 19 06         mov al, 6
1266   0733 05 01         syscall sys_rtc
1267   0735 1A            mov al, ah
1268   0736 3E            mov [d], al                   ; set year
1269   0737             ; write sector into disk for new directory entry
1270   0737 FD 27         mov b, g
1271   0739 38 00 00      mov c, 0
1272   073C 3B D5 2F      mov d, transient_area
1273   073F 22 01         mov ah, $01                   ; disk write, 1 sector
1274   0741 07 74 04      call ide_write_sect           ; write sector
1275   0744             ;;;;;;;;;;;;;
1276   0744             ; like we did above for '..', we need to now add the '.' directory to the list.
1277   0744             ;------------------------------------------------------------------------------------------------------;
1278   0744 E4            pop a                         ; retrieve the new directory's LBA  
1279   0745 D7            push a
1280   0746 53 01 00      add a, 1
1281   0749 27            mov b, a                      ; metadata sector
1282   074A 38 00 00      mov c, 0
1283   074D FD 79         mov g, b                      ; save LBA
1284   074F 3B D5 2F      mov d, transient_area
1285   0752 22 01         mov ah, $01                   ; disk read
1286   0754 07 4E 04      call ide_read_sect            ; read metadata sector
1287   0757             fs_mkdir_L4:
1288   0757 BD 00         cmp byte[d], 0
1289   0759 C6 62 07      je fs_mkdir_found_null4
1290   075C 58 20 00      add d, FST_ENTRY_SIZE
1291   075F 0A 57 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1292   0762             fs_mkdir_found_null4:
1293   0762 FD 4D FA 16   mov si, s_current_dir
1294   0766 FD 50         mov di, d
1295   0768 07 F2 0F      call _strcpy                  ; copy directory name
1296   076B 58 18 00      add d, 24                     ; goto ATTRIBUTES
1297   076E 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1298   0770 3E            mov [d], al      
1299   0771 79            inc d
1300   0772 E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1301   0773 FD 43         mov [d], b                    ; save LBA
1302   0775             ; set file creation date  
1303   0775 58 04 00      add d, 4
1304   0778 19 04         mov al, 4
1305   077A 05 01         syscall sys_rtc
1306   077C 1A            mov al, ah
1307   077D 3E            mov [d], al                   ; set day
1308   077E 79            inc d
1309   077F 19 05         mov al, 5
1310   0781 05 01         syscall sys_rtc
1311   0783 1A            mov al, ah
1312   0784 3E            mov [d], al                   ; set month
1313   0785 79            inc d
1314   0786 19 06         mov al, 6
1315   0788 05 01         syscall sys_rtc
1316   078A 1A            mov al, ah
1317   078B 3E            mov [d], al                   ; set year
1318   078C             ; write sector into disk for new directory entry
1319   078C FD 27         mov b, g
1320   078E 38 00 00      mov c, 0
1321   0791 3B D5 2F      mov d, transient_area
1322   0794 22 01         mov ah, $01                   ; disk write, 1 sector
1323   0796 07 74 04      call ide_write_sect           ; write sector
