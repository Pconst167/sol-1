0944   054E 1D FA 16      mov al, [sys_echo_on]
0945   0551 B9 01         cmp al, 1
0946   0553 24            mov ah, bl
0947   0554 C7 63 05      jne io_getchar_end
0948   0557             ; here we just echo the char back to the console
0949   0557             io_getchar_echo_L0:
0950   0557 1D 85 FF      mov al, [_UART0_LSR]         ; read Line Status Register
0951   055A 93 20         test al, $20                 ; isolate Transmitter Empty
0952   055C C6 57 05      jz io_getchar_echo_L0
0953   055F 1A            mov al, ah
0954   0560 3D 80 FF      mov [_UART0_DATA], al        ; write char to Transmitter Holding Register
0955   0563             io_getchar_end:
0956   0563 E7            pop d
0957   0564 E5            pop b
0958   0565 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0959   0567 06            sysret
0960   0568             io_getchar_fail:
0961   0568 E7            pop d
0962   0569 E5            pop b
0963   056A 19 00         mov al, 0                    ; AL = 0 means no char received
0964   056C 06            sysret
0965   056D             
0966   056D             ; char in ah
0967   056D             ; al = sucess code
0968   056D             io_getchar_noech:
0969   056D D8            push b
0970   056E DA            push d
0971   056F             io_getchar_noech_L0:  
0972   056F 14 08 17      mov a, [fifo_out]
0973   0572 29 06 17      mov b, [fifo_in]
0974   0575 B0            cmp a, b
0975   0576 C6 92 05      je io_getchar_noech_fail
0976   0579 3C            mov d, a
0977   057A 1E            mov al, [d]
0978   057B DB            push al
0979   057C 14 08 17      mov a, [fifo_out]
0980   057F 77            inc a
0981   0580 AF F5 3B      cmp a, fifo + FIFO_SIZE      ; check if pointer reached the end of the fifo
0982   0583 C7 89 05      jne io_getchar_noech_cont
0983   0586 10 F5 1D      mov a, fifo  
0984   0589             io_getchar_noech_cont:  
0985   0589 42 08 17      mov [fifo_out], a             ; update fifo pointer
0986   058C E9            pop ah
0987   058D 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0988   058F E7            pop d
0989   0590 E5            pop b
0990   0591 06            sysret
0991   0592             io_getchar_noech_fail:
0992   0592 E7            pop d
0993   0593 E5            pop b
0994   0594 19 00         mov al, 0                    ; AL = 0 means no char received
0995   0596 06            sysret
