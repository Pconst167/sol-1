0950   0525             ;------------------------------------------------------------------------------------------------------;
0951   0525             ; FILE SYSTEM DATA
0952   0525             ;------------------------------------------------------------------------------------------------------;
0953   0525             ; infor for : IDE SERVICES INTERRUPT
0954   0525             ; IDE read/write 512-byte sector
0955   0525             ; al = option
0956   0525             ; user buffer pointer in D
0957   0525             ; AH = number of sectors
0958   0525             ; CB = LBA bytes 3..0  
0959   0525             ;------------------------------------------------------------------------------------------------------;
0960   0525             ; FILE SYSTEM DATA STRUCTURE
0961   0525             ;------------------------------------------------------------------------------------------------------;
0962   0525             ; for a directory we have the header first, followed by metadata
0963   0525             ; header 1 sector (512 bytes)
0964   0525             ; metadata 1 sector (512 bytes)
0965   0525             ; HEADER ENTRIES:
0966   0525             ; filename (64)
0967   0525             ; parent dir LBA (2) -  to be used for faster backwards navigation...
0968   0525             ;
0969   0525             ; metadata entries:
0970   0525             ; filename (24)
0971   0525             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
0972   0525             ; LBA (2)
0973   0525             ; size (2)
0974   0525             ; day (1)
0975   0525             ; month (1)
0976   0525             ; year (1)
0977   0525             ; packet size = 32 bytes
0978   0525             ;
0979   0525             ; first directory on disk is the root directory '/'
0980   0525             file_system_jmptbl:
0981   0525 90 05         .dw fs_mkfs                   ; 0
0982   0527 00 00         .dw 0                         ; 1
0983   0529 F2 05         .dw fs_mkdir                  ; 2
0984   052B 6B 09         .dw fs_cd                     ; 3
0985   052D 73 09         .dw fs_ls                     ; 4
0986   052F 00 00         .dw 0                  ; 5
0987   0531 25 0B         .dw fs_mkbin                  ; 6
0988   0533 EC 0B         .dw fs_pwd                    ; 7
0989   0535 09 0C         .dw fs_cat                    ; 8
0990   0537 65 0C         .dw fs_rmdir                  ; 9
0991   0539 C1 0C         .dw fs_rm                     ; 10
0992   053B 80 0A         .dw fs_starcom                ; 11
0993   053D 00 00         .dw 0                         ; 12
0994   053F 00 00         .dw 0                         ; 13
0995   0541 98 05         .dw fs_chmod                  ; 14
0996   0543 29 0D         .dw fs_mv                     ; 15
0997   0545 91 05         .dw fs_cd_root                ; 16
0998   0547 67 09         .dw fs_get_curr_dirID         ; 17
0999   0549 43 07         .dw fs_dir_id_to_path         ; 18
1000   054B A9 07         .dw fs_path_to_dir_id_user    ; 19
1001   054D C3 08         .dw fs_load_from_path_user    ; 20  
1002   054F 33 08         .dw fs_filepath_exists_user   ; 21
