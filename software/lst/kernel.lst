0947   051D DA            push d
0948   051E FD 0C         sti
0949   0520             syscall_io_getche_L0:  
0950   0520 14 E8 16      mov a, [fifo_out]
0951   0523 29 E6 16      mov b, [fifo_in]
0952   0526 B0            cmp a, b
