0969   053C 1E            mov al, [d]
0970   053D 23            mov ah, al
0971   053E 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0972   0540 E7            pop d
0973   0541 E5            pop b
0974   0542 06            sysret
