0590   02EB             ; RTC Services Syscall
0591   02EB             ; RTC I/O bank = FFA0 to FFAF
0592   02EB             ; FFA0 to FFA7 is scratch RAM
0593   02EB             ; Control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0594   02EB             ; al = 0..6 -> get
0595   02EB             ; al = 7..D -> set
0596   02EB             ; ------------------------------------------------------------------------------------------------------------------;
0597   02EB             syscall_rtc:
0598   02EB DB            push al
0599   02EC DA            push d
0600   02ED B9 06         cmp al, 6
0601   02EF D1 04 03      jgu syscall_rtc_set
0602   02F2             syscall_rtc_get:
0603   02F2 6A A9         add al, $A9             ; generate RTC address to get to address A9 of clock
0604   02F4 22 FF         mov ah, $FF    
0605   02F6 3C            mov d, a                ; get to FFA9 + offset
0606   02F7 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0607   02FB 1E            mov al, [d]             ; get data
0608   02FC F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
0609   0300 23            mov ah, al
0610   0301 E7            pop d
0611   0302 E8            pop al
0612   0303 06            sysret
