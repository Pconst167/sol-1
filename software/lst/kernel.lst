0946   0552 3C            mov d, a
0947   0553 77            inc a
0948   0554 42 12 17      mov [fifo_out], a             ; update fifo pointer
0949   0557 AF FF 21      cmp a, fifo + FIFO_SIZE      ; check if pointer reached the end of the fifo
0950   055A C6 64 05      je syscall_io_getch_xon
0951   055D             syscall_io_getch_cont:  
0952   055D 1E            mov al, [d]
0953   055E 23            mov ah, al
0954   055F 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0955   0561 E7            pop d
0956   0562 E5            pop b
