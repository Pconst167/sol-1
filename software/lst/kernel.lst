0809   0473 1D D7 FF      mov al, [_ide_R7]  
0810   0476 93 80         test al, $80                     ; BUSY FLAG
0811   0478 C7 73 04      jnz ide_write_sect_wait
0812   047B 19 30         mov al, $30
0813   047D 3D D7 FF      mov [_ide_R7], al               ; write sector cmd
0814   0480 07 9F 04      call ide_write      
0815   0483 09            ret
