1030   0597 06            sysret  
1031   0598             
1032   0598             ; filename in D (userspace data)
1033   0598             ; permission in BL
1034   0598             fs_chmod:
1035   0598 DD            push bl
1036   0599 FD 4E         mov si, d
1037   059B FD 4F 61 1B   mov di, user_data
1038   059F 38 80 00      mov c, 128
1039   05A2 04            load                        ; load filename from user-space
1040   05A3 14 76 16      mov a, [current_dirID]
1041   05A6 77            inc a                       ; metadata sector
1042   05A7 27            mov b, a
1043   05A8 38 00 00      mov c, 0                    ; reset LBA to 0
1044   05AB 22 01         mov ah, $01                 ; disk read
1045   05AD 3B 61 3F      mov d, transient_area
1046   05B0 07 27 04      call ide_read_sect          ; read directory
1047   05B3 FD 10         cla
1048   05B5 42 6E 16      mov [index], a              ; reset file counter
1049   05B8             fs_chmod_L1:
1050   05B8 FD 4E         mov si, d
1051   05BA FD 4F 61 1B   mov di, user_data
1052   05BE 07 7F 0F      call _strcmp
1053   05C1 C6 D8 05      je fs_chmod_found_entry
1054   05C4 58 20 00      add d, 32
1055   05C7 14 6E 16      mov a, [index]
1056   05CA 77            inc a
1057   05CB 42 6E 16      mov [index], a
1058   05CE AF 10 00      cmp a, FST_FILES_PER_DIR
1059   05D1 C7 B8 05      jne fs_chmod_L1
1060   05D4 EA            pop bl
1061   05D5 0A F1 05      jmp fs_chmod_not_found
1062   05D8             fs_chmod_found_entry:  
1063   05D8 FD 79         mov g, b                    ; save LBA
1064   05DA EA            pop bl                      ; retrieve saved permission value
1065   05DB 1F 18 00      mov al, [d + 24]            ; read file permissions
1066   05DE 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1067   05E0 8C            or al, bl                   ; set new permissions
1068   05E1 3F 18 00      mov [d + 24], al            ; write new permissions
1069   05E4 38 00 00      mov c, 0
1070   05E7 3B 61 3F      mov d, transient_area
1071   05EA 22 01         mov ah, $01                 ; disk write 1 sect
1072   05EC FD 27         mov b, g                    ; retrieve LBA
1073   05EE 07 4D 04      call ide_write_sect         ; write sector
1074   05F1             fs_chmod_not_found:
1075   05F1 06            sysret
