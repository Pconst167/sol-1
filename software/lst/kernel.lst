1325   0799 06            sysret
1326   079A             
1327   079A             ;------------------------------------------------------------------------------------------------------;
1328   079A             ; get path from a given directory dirID
1329   079A             ; pseudo code:
1330   079A             ;  fs_dir_id_to_path(int dirID, char *D){
1331   079A             ;    if(dirID == 0){
1332   079A             ;      reverse path in D;
1333   079A             ;      return;
1334   079A             ;    }
1335   079A             ;    else{
1336   079A             ;      copy directory name to end of D;
1337   079A             ;      add '/' to end of D;
1338   079A             ;      parentID = get parent directory ID;
1339   079A             ;      fs_dir_id_to_path(parentID, D);
1340   079A             ;    }
1341   079A             ;  }
1342   079A             ; A = dirID
1343   079A             ; D = generated path string pointer
1344   079A             ;------------------------------------------------------------------------------------------------------;
1345   079A             ; sample path: /usr/bin
1346   079A             fs_dir_id_to_path:
1347   079A 3B 55 1B      mov d, filename
1348   079D 19 00         mov al, 0
1349   079F 3E            mov [d], al                     ; initialize path string 
1350   07A0 14 EA 16      mov a, [current_dirID]
1351   07A3 07 B0 07      call fs_dir_id_to_path_E0
1352   07A6 3B 55 1B      mov d, filename
1353   07A9 07 86 0F      call _strrev
1354   07AC 07 B8 11      call _puts
1355   07AF 06            sysret
1356   07B0             fs_dir_id_to_path_E0:
1357   07B0 07 CF 07      call get_dirname_from_dirID
1358   07B3 FD 4D FC 16   mov si, s_fslash
1359   07B7 FD 50         mov di, d
1360   07B9 07 00 10      call _strcat                    ; add '/' to end of path
1361   07BC AF 20 00      cmp a, root_id               ; check if we are at the root directory
1362   07BF C6 CE 07      je fs_dir_id_to_path_root
1363   07C2 07 EC 07      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1364   07C5 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1365   07C8 C6 CE 07      je fs_dir_id_to_path_root
1366   07CB 07 B0 07      call fs_dir_id_to_path_E0     ; recursively call itself
1367   07CE             fs_dir_id_to_path_root:
1368   07CE 09            ret
1369   07CF             
1370   07CF             ;------------------------------------------------------------------------------------------------------;
1371   07CF             ; in_puts:
1372   07CF             ; A = directory ID
1373   07CF             ; out_puts:
1374   07CF             ; D = pointer to directory name string
1375   07CF             ;------------------------------------------------------------------------------------------------------;
1376   07CF             get_dirname_from_dirID:
1377   07CF D7            push a
1378   07D0 D8            push b
1379   07D1 DA            push d
1380   07D2 27            mov b, a
1381   07D3 38 00 00      mov c, 0                      ; reset LBA to 0
1382   07D6 22 01         mov ah, $01                   ; disk read
1383   07D8 3B D5 2D      mov d, transient_area - 512
1384   07DB 07 4E 04      call ide_read_sect            ; read directory
1385   07DE 07 86 0F      call _strrev                  ; reverse dir name before copying
1386   07E1 FD 4E         mov si, d
1387   07E3 E7            pop d                         ; destination address = D value pushed at beginning
