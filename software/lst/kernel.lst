1256   0729 1A            mov al, ah
1257   072A 3E            mov [d], al                   ; set day
1258   072B 79            inc d
1259   072C 19 05         mov al, 5
1260   072E 05 01         syscall sys_rtc
1261   0730 1A            mov al, ah
1262   0731 3E            mov [d], al                   ; set month
1263   0732 79            inc d
1264   0733 19 06         mov al, 6
1265   0735 05 01         syscall sys_rtc
1266   0737 1A            mov al, ah
1267   0738 3E            mov [d], al                   ; set year
1268   0739             ; write sector into disk for new directory entry
1269   0739 FD 27         mov b, g
1270   073B 38 00 00      mov c, 0
1271   073E 3B BA 27      mov d, transient_area
1272   0741 22 01         mov ah, $01                   ; disk write, 1 sector
1273   0743 07 7E 04      call ide_write_sect           ; write sector
1274   0746             ;;;;;;;;;;;;;
1275   0746             ; like we did above for '..', we need to now add the '.' directory to the list.
1276   0746             ;------------------------------------------------------------------------------------------------------;
1277   0746 E4            pop a                         ; retrieve the new directory's LBA  
1278   0747 D7            push a
1279   0748 53 01 00      add a, 1
1280   074B 27            mov b, a                      ; metadata sector
1281   074C 38 00 00      mov c, 0
1282   074F FD 79         mov g, b                      ; save LBA
1283   0751 3B BA 27      mov d, transient_area
1284   0754 22 01         mov ah, $01                   ; disk read
1285   0756 07 58 04      call ide_read_sect            ; read metadata sector
1286   0759             fs_mkdir_L4:
1287   0759 BD 00         cmp byte[d], 0
