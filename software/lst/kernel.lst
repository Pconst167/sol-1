1240   0707 58 20 00      add d, FST_ENTRY_SIZE
1241   070A 0A 02 07      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1242   070D             fs_mkdir_found_null3:
