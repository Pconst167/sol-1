0950   0519             ;------------------------------------------------------------------------------------------------------;
0951   0519             ; FILE SYSTEM DATA
0952   0519             ;------------------------------------------------------------------------------------------------------;
0953   0519             ; infor for : IDE SERVICES INTERRUPT
0954   0519             ; IDE read/write 512-byte sector
0955   0519             ; al = option
0956   0519             ; user buffer pointer in D
0957   0519             ; AH = number of sectors
0958   0519             ; CB = LBA bytes 3..0  
0959   0519             ;------------------------------------------------------------------------------------------------------;
0960   0519             ; FILE SYSTEM DATA STRUCTURE
0961   0519             ;------------------------------------------------------------------------------------------------------;
0962   0519             ; for a directory we have the header first, followed by metadata
0963   0519             ; header 1 sector (512 bytes)
0964   0519             ; metadata 1 sector (512 bytes)
0965   0519             ; HEADER ENTRIES:
0966   0519             ; filename (64)
0967   0519             ; parent dir LBA (2) -  to be used for faster backwards navigation...
0968   0519             ;
0969   0519             ; metadata entries:
0970   0519             ; filename (24)
0971   0519             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
0972   0519             ; LBA (2)
0973   0519             ; size (2)
0974   0519             ; day (1)
0975   0519             ; month (1)
0976   0519             ; year (1)
0977   0519             ; packet size = 32 bytes
0978   0519             ;
0979   0519             ; first directory on disk is the root directory '/'
0980   0519             file_system_jmptbl:
0981   0519 84 05         .dw fs_mkfs                   ; 0
0982   051B 00 00         .dw 0                         ; 1
0983   051D E6 05         .dw fs_mkdir                  ; 2
0984   051F 5F 09         .dw fs_cd                     ; 3
0985   0521 67 09         .dw fs_ls                     ; 4
0986   0523 00 00         .dw 0                  ; 5
0987   0525 19 0B         .dw fs_mkbin                  ; 6
0988   0527 E0 0B         .dw fs_pwd                    ; 7
0989   0529 FD 0B         .dw fs_cat                    ; 8
0990   052B 59 0C         .dw fs_rmdir                  ; 9
0991   052D B5 0C         .dw fs_rm                     ; 10
0992   052F 74 0A         .dw fs_starcom                ; 11
0993   0531 00 00         .dw 0                         ; 12
0994   0533 00 00         .dw 0                         ; 13
0995   0535 8C 05         .dw fs_chmod                  ; 14
0996   0537 1D 0D         .dw fs_mv                     ; 15
0997   0539 85 05         .dw fs_cd_root                ; 16
0998   053B 5B 09         .dw fs_get_curr_dirID         ; 17
0999   053D 37 07         .dw fs_dir_id_to_path         ; 18
1000   053F 9D 07         .dw fs_path_to_dir_id_user    ; 19
1001   0541 B7 08         .dw fs_load_from_path_user    ; 20  
1002   0543 27 08         .dw fs_filepath_exists_user   ; 21
