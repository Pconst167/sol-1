0576   02B4             ; RTC Services Syscall
0577   02B4             ; RTC I/O bank = FFA0 to FFAF
0578   02B4             ; FFA0 to FFA7 is scratch RAM
0579   02B4             ; Control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0580   02B4             ; al = 0..6 -> get
0581   02B4             ; al = 7..D -> set
0582   02B4             ; ------------------------------------------------------------------------------------------------------------------;
0583   02B4             syscall_rtc:
0584   02B4 DB            push al
0585   02B5 DA            push d
0586   02B6 B9 06         cmp al, 6
0587   02B8 D1 CD 02      jgu syscall_rtc_set
0588   02BB             syscall_rtc_get:
0589   02BB 6A A9         add al, $A9             ; generate RTC address to get to address A9 of clock
0590   02BD 22 FF         mov ah, $FF    
0591   02BF 3C            mov d, a                ; get to FFA9 + offset
0592   02C0 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0593   02C4 1E            mov al, [d]             ; get data
0594   02C5 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
0595   02C9 23            mov ah, al
0596   02CA E7            pop d
0597   02CB E8            pop al
0598   02CC 06            sysret
0599   02CD             syscall_rtc_set:
0600   02CD DD            push bl
0601   02CE 99            mov bl, ah              ; set data asIDE
0602   02CF 6A A2         add al, $A2             ; generate RTC address to get to address A9 of clock
0603   02D1 22 FF         mov ah, $FF    
0604   02D3 3C            mov d, a                ; get to FFA9 + offset
0605   02D4 1B            mov al, bl              ; get data back
0606   02D5 F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0607   02D9 3E            mov [d], al             ; set data
0608   02DA F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0609   02DE EA            pop bl
0610   02DF E7            pop d
0611   02E0 E8            pop al
0612   02E1 06            sysret
