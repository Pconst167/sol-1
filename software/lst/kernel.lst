1297   07B8             ;------------------------------------------------------------------------------------------------------;
1298   07B8             ; get path from a given directory dirID
1299   07B8             ; pseudo code:
1300   07B8             ;  fs_dir_id_to_path(int dirID, char *D){
1301   07B8             ;    if(dirID == 0){
1302   07B8             ;      reverse path in D;
1303   07B8             ;      return;
1304   07B8             ;    }
1305   07B8             ;    else{
1306   07B8             ;      copy directory name to end of D;
1307   07B8             ;      add '/' to end of D;
1308   07B8             ;      parentID = get parent directory ID;
1309   07B8             ;      fs_dir_id_to_path(parentID, D);
1310   07B8             ;    }
1311   07B8             ;  }
1312   07B8             ; A = dirID
1313   07B8             ; D = generated path string pointer
1314   07B8             ;------------------------------------------------------------------------------------------------------;
1315   07B8             ; sample path: /usr/bin
1316   07B8             fs_dir_id_to_path:
1317   07B8 3B 5D 1B      mov d, filename
1318   07BB 19 00         mov al, 0
1319   07BD 3E            mov [d], al                     ; initialize path string 
1320   07BE 14 F2 16      mov a, [current_dirID]
1321   07C1 07 CE 07      call fs_dir_id_to_path_E0
1322   07C4 3B 5D 1B      mov d, filename
1323   07C7 07 A4 0F      call _strrev
1324   07CA 07 B8 11      call _puts
1325   07CD 06            sysret
1326   07CE             fs_dir_id_to_path_E0:
1327   07CE 07 ED 07      call get_dirname_from_dirID
1328   07D1 FD 4D 04 17   mov si, s_fslash
1329   07D5 FD 50         mov di, d
1330   07D7 07 1E 10      call _strcat                    ; add '/' to end of path
1331   07DA AF 20 00      cmp a, root_id               ; check if we are at the root directory
1332   07DD C6 EC 07      je fs_dir_id_to_path_root
1333   07E0 07 0A 08      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1334   07E3 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1335   07E6 C6 EC 07      je fs_dir_id_to_path_root
1336   07E9 07 CE 07      call fs_dir_id_to_path_E0     ; recursively call itself
1337   07EC             fs_dir_id_to_path_root:
1338   07EC 09            ret
1339   07ED             
1340   07ED             ;------------------------------------------------------------------------------------------------------;
1341   07ED             ; in_puts:
1342   07ED             ; A = directory ID
1343   07ED             ; out_puts:
1344   07ED             ; D = pointer to directory name string
1345   07ED             ;------------------------------------------------------------------------------------------------------;
1346   07ED             get_dirname_from_dirID:
1347   07ED D7            push a
1348   07EE D8            push b
1349   07EF DA            push d
1350   07F0 27            mov b, a
1351   07F1 38 00 00      mov c, 0                      ; reset LBA to 0
1352   07F4 22 01         mov ah, $01                   ; disk read
1353   07F6 3B DD 21      mov d, transient_area - 512
1354   07F9 07 4E 04      call ide_read_sect            ; read directory
1355   07FC 07 A4 0F      call _strrev                  ; reverse dir name before copying
1356   07FF FD 4E         mov si, d
1357   0801 E7            pop d                         ; destination address = D value pushed at beginning
1358   0802 FD 50         mov di, d
1359   0804 07 1E 10      call _strcat                  ; copy filename to D
1360   0807 E5            pop b
1361   0808 E4            pop a
1362   0809 09            ret
1363   080A             
1364   080A             ;------------------------------------------------------------------------------------------------------;
1365   080A             ; in_puts:
1366   080A             ; A = directory ID
1367   080A             ; out_puts:
1368   080A             ; A = parent directory ID
1369   080A             ;------------------------------------------------------------------------------------------------------;
1370   080A             get_parentID_from_dirID:
1371   080A D8            push b
1372   080B DA            push d
1373   080C 27            mov b, a
1374   080D 38 00 00      mov c, 0                      ; reset LBA to 0
1375   0810 22 01         mov ah, $01                   ; disk read
1376   0812 3B DD 21      mov d, transient_area - 512
1377   0815 07 4E 04      call ide_read_sect            ; read directory
1378   0818 16 40 00      mov a, [d + 64]               ; copy parent ID value to A
1379   081B E7            pop d
1380   081C E5            pop b
1381   081D 09            ret
1382   081E             
1383   081E             ;------------------------------------------------------------------------------------------------------;
1384   081E             ; get dirID from a given path string
1385   081E             ; in_puts:
1386   081E             ; D = path pointer 
1387   081E             ; out_puts:
1388   081E             ; A = dirID
1389   081E             ; if dir non existent, A = FFFF (fail code)
1390   081E             ; /usr/local/bin    - absolute
1391   081E             ; local/bin/games    - relative
1392   081E             ;------------------------------------------------------------------------------------------------------;
1393   081E             fs_path_to_dir_id_user:
1394   081E FD 4E         mov si, d
1395   0820 FD 4F DD 1B   mov di, user_data
