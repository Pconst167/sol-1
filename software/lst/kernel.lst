0897   04DF             syscall_io:
0898   04DF FD 0A D9 04   jmp [syscall_io_jmp + al]
0899   04E3             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0900   04E3             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0901   04E3             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0902   04E3             syscall_io_uart_setup:
0903   04E3 1D E3 16      mov al, [sys_uart0_lcr]
0904   04E6 8B 80         or al, $80                ; set DLAB access bit
0905   04E8 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 1 stop, no parity by default
0906   04EB 1D E6 16      mov al, [sys_uart0_div0]
0907   04EE 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0908   04F1 1D E7 16      mov al, [sys_uart0_div1]
0909   04F4 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
0910   04F7             
