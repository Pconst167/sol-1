2593   180D 22 00         mov ah, 0
2594   180F FD 99         shl a                             ; x2
2595   1811 B7 A4 18      mov a, [proc_table_convert + a]   ; get process state start index  
2596   1814               
2597   1814 4D            mov si, a                         ; source is proc state block
2598   1815 48            mov a, sp
2599   1816 5F 13 00      sub a, 19
2600   1819 4F            mov di, a                         ; destination is kernel stack
2601   181A             ; restore SP
2602   181A 7D            dec a
2603   181B 47            mov sp, a
2604   181C 38 14 00      mov c, 20
2605   181F FD F5         rep movsb
2606   1821             ; set VM process
2607   1821 1D 17 19      mov al, [active_proc_index]
2608   1824 01            setptb
2609   1825                 
2610   1825 4C            popa
2611   1826 06            sysret
2612   1827             
2613   1827             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
2614   1827             ;; spawn a new process
2615   1827             ;; D = path of the process file to be spawned
2616   1827             ;; B = arguments ptr
2617   1827             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
2618   1827             syscall_spawn_proc:
2619   1827             ; we save the active process first  
2620   1827 4B            pusha
2621   1828 22 00         mov ah, 0
2622   182A 1D 17 19      mov al, [active_proc_index]
2623   182D FD 99         shl a              ; x2
2624   182F B7 A4 18      mov a, [proc_table_convert + a]    ; get process state table's start index
2625   1832               
2626   1832 4F            mov di, a
2627   1833 48            mov a, sp
2628   1834 77            inc a
2629   1835 4D            mov si, a
2630   1836 38 14 00      mov c, 20
2631   1839 FD F5         rep movsb                          ; save process state!
2632   183B             ; restore kernel stack position to point before interrupt arrived
2633   183B 51 14 00      add sp, 20
2634   183E               
2635   183E FD 4E         mov si, d                          ; copy the file path
2636   1840 FD 4F 1B 20   mov di, temp_data
2637   1844 38 00 02      mov c, 512
2638   1847 04            load
2639   1848 11            mov a, b
2640   1849 4D            mov si, a                          ; copy the arguments
2641   184A FD 4F 1B 32   mov di, scrap_sector
2642   184E 38 00 02      mov c, 512
2643   1851 04            load
2644   1852 07 2D 11      call loadfile_from_path            ; load the process file from disk by path (path is in temp_data)
2645   1855                                                  ; the file data is loaded into transient_area
2646   1855             ; now we allocate a new process  
2647   1855 07 86 17      call find_free_proc                ; index in A
2648   1858 01            setptb 
2649   1859 07 98 17      call proc_memory_map               ; map process memory pages
2650   185C             ; copy arguments into process's memory
2651   185C FD 4D 1B 32   mov si, scrap_sector
2652   1860 FD 4F 00 00   mov di, 0
2653   1864 38 00 02      mov c, 512
2654   1867 03            store
2655   1868             ; now copy process binary data into process's memory
2656   1868 FD 4D 1B 34   mov si, transient_area
2657   186C FD 4F 00 04   mov di, TEXT_ORG              ; code origin address for all user processes
2658   1870 38 00 40      mov c, FS_FILE_SIZE                ; size of memory space to copy, which is equal to the max file size in disk (for now)
2659   1873 03            store                              ; copy process data
2660   1874                 
2661   1874 07 86 17      call find_free_proc                ; index in A
2662   1877 3D 17 19      mov [active_proc_index], al        ; set new active process
2663   187A FD 9D 05      shl a, 5                           ; x32
2664   187D 53 1B 1C      add a, proc_names
2665   1880 4F            mov di, a
2666   1881 FD 4D 1B 20   mov si, temp_data                  ; copy and store process filename
2667   1885 07 A8 00      call _strcpy
2668   1888               
2669   1888 07 86 17      call find_free_proc                ; index in A
2670   188B 3C            mov d, a
2671   188C 19 01         mov al, 1
2672   188E 3F 0B 1C      mov [d + proc_availab_table], al   ; make process busy
2673   1891               
2674   1891 1D 16 19      mov al, [nbr_active_procs]         ; increase nbr of active processes
2675   1894 7A            inc al
2676   1895 3D 16 19      mov [nbr_active_procs], al
2677   1898             ; launch process
2678   1898 FD D7 FF FF   push word $FFFF 
2679   189C FD DB 0E      push byte %00001110                ; dma_ack = 0, interrupts enabled = 1, mode = user, paging = on, halt=0, display_reg_load=0, dir=0
2680   189F FD D7 00 04   push word TEXT_ORG
2681   18A3 06            sysret
