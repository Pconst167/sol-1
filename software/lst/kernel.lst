0219   083B FD 99         shl a              ; x2
0220   083D B7 A3 18      mov a, [proc_table_convert + a]  ; get process state start index
0221   0840 4F            mov di, a
0222   0841 48            mov a, sp
0223   0842 77            inc a
0224   0843 4D            mov si, a
0225   0844 38 14 00      mov c, 20
0226   0847 FD F5         rep movsb          ; save process state!
0227   0849             ; restore kernel stack position to point before interrupt arrived
0228   0849 51 14 00      add sp, 20
0229   084C             ; now load next process in queue
0230   084C 1D 16 19      mov al, [active_proc_index]
0231   084F 31 15 19      mov bl, [nbr_active_procs]
0232   0852 BA            cmp al, bl
