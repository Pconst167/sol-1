0894   04D9             ; IO Syscall
0895   04D9             ;----------------------------------------------------------------------------------------------------;
0896   04D9             ; Baud  Divisor
0897   04D9             ; 50    2304
0898   04D9             ; 110   1047
0899   04D9             ; 300    384
0900   04D9             ; 600    192
0901   04D9             ; 1200    96
0902   04D9             ; 9600    12
0903   04D9             ; 19200    6
0904   04D9             ; 38400    3
