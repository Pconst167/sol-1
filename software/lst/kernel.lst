0001   0000             ; ------------------------------------------------------------------------------------------------------------------;
0002   0000             ; Solarium - Sol-1 Homebrew Minicomputer Operating System Kernel.
0003   0000             ; ------------------------------------------------------------------------------------------------------------------;
0004   0000             ; Memory Map
0005   0000             ; ------------------------------------------------------------------------------------------------------------------;
0006   0000             ; 0000    ROM BEGIN
0007   0000             ; ....
0008   0000             ; 7FFF    ROM END
0009   0000             ;
0010   0000             ; 8000    RAM begin
0011   0000             ; ....
0012   0000             ; F7FF    Stack root
0013   0000             ; ------------------------------------------------------------------------------------------------------------------;
0014   0000             ; I/O MAP
0015   0000             ; ------------------------------------------------------------------------------------------------------------------;
0016   0000             ; FF80    UART 0    (16550)
0017   0000             ; FF90    UART 1    (16550)
0018   0000             ; FFA0    RTC       (M48T02)
0019   0000             ; FFB0    PIO 0     (8255)
0020   0000             ; FFC0    PIO 1     (8255)
0021   0000             ; FFD0    IDE       (Compact Flash / PATA)
0022   0000             ; FFE0    Timer     (8253)
0023   0000             ; FFF0    BIOS CONFIGURATION NV-RAM STORE AREA
0024   0000             ; ------------------------------------------------------------------------------------------------------------------;
0025   0000             
0026   0000             ; ------------------------------------------------------------------------------------------------------------------;
0027   0000             ; System Constants
0028   0000             ; ------------------------------------------------------------------------------------------------------------------;
0029   0000             _UART0_DATA       .equ $FF80            ; data
0030   0000             _UART0_DLAB_0     .equ $FF80            ; divisor latch low byte
0031   0000             _UART0_DLAB_1     .equ $FF81            ; divisor latch high byte
0032   0000             _UART0_IER        .equ $FF81            ; Interrupt enable register
0033   0000             _UART0_FCR        .equ $FF82            ; FIFO control register
0034   0000             _UART0_LCR        .equ $FF83            ; line control register
0035   0000             _UART0_LSR        .equ $FF85            ; line status register
0036   0000             
0037   0000             _UART1_DATA       .equ $FF90            ; data
0038   0000             _UART1_DLAB_0     .equ $FF90            ; divisor latch low byte
0039   0000             _UART1_DLAB_1     .equ $FF91            ; divisor latch high byte
0040   0000             _UART1_IER        .equ $FF91            ; Interrupt enable register
0041   0000             _UART1_FCR        .equ $FF92            ; FIFO control register
0042   0000             _UART1_LCR        .equ $FF93            ; line control register
0043   0000             _UART1_LSR        .equ $FF95            ; line status register
0044   0000             
0045   0000             XON               .equ $11
0046   0000             XOFF              .equ $13
0047   0000             
0048   0000             _ide_BASE         .equ $FFD0            ; IDE BASE
0049   0000             _ide_R0           .equ _ide_BASE + 0    ; DATA PORT
0050   0000             _ide_R1           .equ _ide_BASE + 1    ; READ: ERROR CODE, WRITE: FEATURE
0051   0000             _ide_R2           .equ _ide_BASE + 2    ; NUMBER OF SECTORS TO TRANSFER
0052   0000             _ide_R3           .equ _ide_BASE + 3    ; SECTOR ADDRESS LBA 0 [0:7]
0053   0000             _ide_R4           .equ _ide_BASE + 4    ; SECTOR ADDRESS LBA 1 [8:15]
0054   0000             _ide_R5           .equ _ide_BASE + 5    ; SECTOR ADDRESS LBA 2 [16:23]
0055   0000             _ide_R6           .equ _ide_BASE + 6    ; SECTOR ADDRESS LBA 3 [24:27 (LSB)]
0056   0000             _ide_R7           .equ _ide_BASE + 7    ; READ: STATUS, WRITE: COMMAND
0057   0000             
0058   0000             _7SEG_DISPLAY     .equ $FFB0            ; BIOS POST CODE HEX DISPLAY (2 DIGITS)
0059   0000             _BIOS_POST_CTRL   .equ $FFB3            ; BIOS POST DISPLAY CONTROL REGISTER, 80h = As Output
0060   0000             _PIO_A            .equ $FFB0    
0061   0000             _PIO_B            .equ $FFB1
0062   0000             _PIO_C            .equ $FFB2
0063   0000             _PIO_CONTROL      .equ $FFB3            ; PIO CONTROL PORT
0064   0000             
0065   0000             _TIMER_C_0        .equ $FFE0            ; TIMER COUNTER 0
0066   0000             _TIMER_C_1        .equ $FFE1            ; TIMER COUNTER 1
0067   0000             _TIMER_C_2        .equ $FFE2            ; TIMER COUNTER 2
0068   0000             _TIMER_CTRL       .equ $FFE3            ; TIMER CONTROL REGISTER
0069   0000             
0070   0000             STACK_BEGIN       .equ $F7FF            ; beginning of stack
0071   0000             FIFO_SIZE         .equ 1024
0072   0000             
0073   0000             TEXT_ORG          .equ $400
0074   0000             ; ------------------------------------------------------------------------------------------------------------------;
0075   0000             
0076   0000             
0077   0000             ; For the next iteration:
0078   0000             ; boot-sector(1) | kernel-sectors(32) | inode-bitmap | rawdata-bitmap | inode-table | raw-disk-data
0079   0000             ; inode-table format:
0080   0000             ;  file-type(f, d)
0081   0000             ;  permissons
0082   0000             ;  link-count
0083   0000             ;  filesize
0084   0000             ;  time-stamps
0085   0000             ;  15 data block pointers
0086   0000             ;  single-indirect pointer
0087   0000             
0088   0000             ; FILE ENTRY ATTRIBUTES
0089   0000             ; filename (24)
0090   0000             ; attributes (1)       :|0|0|file_type(3bits)|x|w|r|
0091   0000             ; LBA (2)              : location of raw data for file entry, or dirID for directory entry
0092   0000             ; size (2)             : filesize
0093   0000             ; day (1)           
0094   0000             ; month (1)
0095   0000             ; year (1)
0096   0000             ; packet size = 32 bytes  : total packet size in bytes
0097   0000             
0098   0000             FST_ENTRY_SIZE          .equ 32  ; bytes
0099   0000             FST_FILES_PER_SECT      .equ (512 / FST_ENTRY_SIZE)
0100   0000             FST_FILES_PER_DIR       .equ (512 / FST_ENTRY_SIZE)
0101   0000             FST_NBR_DIRECTORIES     .equ 64
0102   0000                                     ; 1 sector for header, the rest is for the list of files/dirs
0103   0000             FST_SECTORS_PER_DIR     .equ (1 + (FST_ENTRY_SIZE * FST_FILES_PER_DIR / 512))    
0104   0000             FST_TOTAL_SECTORS       .equ (FST_SECTORS_PER_DIR * FST_NBR_DIRECTORIES)
0105   0000             FST_LBA_START           .equ 32
0106   0000             FST_LBA_END             .equ (FST_LBA_START + FST_TOTAL_SECTORS - 1)
0107   0000             
0108   0000             FS_NBR_FILES            .equ (FST_NBR_DIRECTORIES * FST_FILES_PER_DIR)
0109   0000             FS_SECTORS_PER_FILE     .equ 32         ; the first sector is always a header with a NULL parameter (first byte)
0110   0000                                                     ; so that we know which blocks are free or taken
0111   0000             FS_FILE_SIZE            .equ (FS_SECTORS_PER_FILE * 512)                  
0112   0000             FS_TOTAL_SECTORS        .equ (FS_NBR_FILES * FS_SECTORS_PER_FILE)
0113   0000             FS_LBA_START            .equ (FST_LBA_END + 1)
0114   0000             FS_LBA_END              .equ (FS_LBA_START + FS_NBR_FILES - 1)
0115   0000             
0116   0000             root_id:                .equ FST_LBA_START
0117   0000             
0118   0000             ; ------------------------------------------------------------------------------------------------------------------;
0119   0000             ; GLOBAL SYSTEM VARIABLES
0120   0000             ; ------------------------------------------------------------------------------------------------------------------;
0121   0000             
0122   0000             ; ------------------------------------------------------------------------------------------------------------------;
0123   0000             ; IRQ Table
0124   0000             ; Highest priority at lowest address
0125   0000             ; ------------------------------------------------------------------------------------------------------------------;
0126   0000 3A 00       .dw int_0
0127   0002 3B 00       .dw int_1
0128   0004 3C 00       .dw int_2
0129   0006 3D 00       .dw int_3
0130   0008 3E 00       .dw int_4
0131   000A 3F 00       .dw int_5
0132   000C 40 00       .dw int_6
0133   000E 8C 00       .dw int_7
0134   0010             
0135   0010             ; ------------------------------------------------------------------------------------------------------------------;
0136   0010             ; Reset Vector
0137   0010             ; ------------------------------------------------------------------------------------------------------------------;
0138   0010 65 0E       .dw kernel_reset_vector
0139   0012             
0140   0012             ; ------------------------------------------------------------------------------------------------------------------;
0141   0012             ; Exception Vector Table
0142   0012             ; Total of 7 entries, starting at address $0012
0143   0012             ; ------------------------------------------------------------------------------------------------------------------;
0144   0012 C0 01       .dw trap_privilege
0145   0014 DD 02       .dw trap_div_zero
0146   0016 EA 02       .dw trap_undef_opcode
0147   0018 00 00       .dw 0
0148   001A 00 00       .dw 0
0149   001C 00 00       .dw 0
0150   001E 00 00       .dw 0
0151   0020             
0152   0020             ; ------------------------------------------------------------------------------------------------------------------;
0153   0020             ; System Call Vector Table
0154   0020             ; Starts at address $0020
0155   0020             ; ------------------------------------------------------------------------------------------------------------------;
0156   0020 CC 01       .dw syscall_break
0157   0022 EB 02       .dw syscall_rtc
0158   0024 25 04       .dw syscall_ide
0159   0026 02 05       .dw syscall_io
0160   0028 3C 06       .dw syscall_file_system
0161   002A 3C 0F       .dw syscall_spawn_proc
0162   002C 85 01       .dw syscall_list_procs
0163   002E 1D 03       .dw syscall_datetime
0164   0030 41 01       .dw syscall_reboot
0165   0032 06 0F       .dw syscall_pause_proc
0166   0034 4D 01       .dw syscall_resume_proc
0167   0036 C3 0E       .dw syscall_terminate_proc
0168   0038 15 01       .dw syscall_system
0169   003A             
0170   003A             ; ------------------------------------------------------------------------------------------------------------------;
0171   003A             ; System Call Aliases
0172   003A             ; ------------------------------------------------------------------------------------------------------------------;
0173   003A             sys_break             .equ 0
0174   003A             sys_rtc              .equ 1
0175   003A             sys_ide              .equ 2
0176   003A             sys_io               .equ 3
0177   003A             sys_filesystem       .equ 4
0178   003A             sys_spawn_proc       .equ 5
0179   003A             sys_list             .equ 6
0180   003A             sys_datetime         .equ 7
0181   003A             sys_reboot           .equ 8
0182   003A             sys_pause_proc       .equ 9
0183   003A             sys_resume_proc      .equ 10
0184   003A             sys_terminate_proc   .equ 11
0185   003A             sys_system           .equ 12
0186   003A             
0187   003A             ; ------------------------------------------------------------------------------------------------------------------;
0188   003A             ; Alias Exports
0189   003A             ; ------------------------------------------------------------------------------------------------------------------;
0190   003A             .export TEXT_ORG
0191   003A             .export sys_break
0192   003A             .export sys_ide
0193   003A             .export sys_io
0194   003A             .export sys_filesystem
0195   003A             .export sys_spawn_proc
0196   003A             .export sys_list
0197   003A             .export sys_rtc
0198   003A             .export sys_datetime
0199   003A             .export sys_reboot
0200   003A             .export sys_pause_proc
0201   003A             .export sys_resume_proc
0202   003A             .export sys_terminate_proc
0203   003A             .export sys_system
0204   003A             
0205   003A             ; ------------------------------------------------------------------------------------------------------------------;
0206   003A             ; IRQs' Code Block
0207   003A             ; ------------------------------------------------------------------------------------------------------------------;
0208   003A             int_0:
0209   003A 06            sysret
0210   003B             int_1:
0211   003B 06            sysret
0212   003C             int_2:
0213   003C 06            sysret
0214   003D             int_3:
0215   003D 06            sysret
0216   003E             int_4:
0217   003E 06            sysret
0218   003F             int_5:
0219   003F 06            sysret
0220   0040             
0221   0040             ; ------------------------------------------------------------------------------------------------------------------;
0222   0040             ; Process Swapping
0223   0040             ; ------------------------------------------------------------------------------------------------------------------;
0224   0040             int_6:  
0225   0040 4B            pusha ; save all registers into kernel stack
0226   0041 22 00         mov ah, 0
0227   0043 1D 55 17      mov al, [active_proc_index]
0228   0046 FD 99         shl a              ; x2
0229   0048 B7 B9 0F      mov a, [proc_table_convert + a]  ; get process state start index
0230   004B 4F            mov di, a
0231   004C 48            mov a, sp
0232   004D 77            inc a
0233   004E 4D            mov si, a
0234   004F 38 14 00      mov c, 20
0235   0052 FD F5         rep movsb          ; save process state!
0236   0054             ; restore kernel stack position to point before interrupt arrived
0237   0054 51 14 00      add sp, 20
0238   0057             ; now load next process in queue
0239   0057 1D 55 17      mov al, [active_proc_index]
0240   005A 31 54 17      mov bl, [nbr_active_procs]
0241   005D BA            cmp al, bl
0242   005E C6 65 00      je int6_cycle_back
0243   0061 7A            inc al            ; next process is next in the series
0244   0062 0A 67 00      jmp int6_continue
0245   0065             int6_cycle_back:
0246   0065 19 01         mov al, 1        ; next process = process 1
0247   0067             int6_continue:
0248   0067 3D 55 17      mov [active_proc_index], al    ; set next active proc
0249   006A             
0250   006A             ; calculate LUT entry for next process
0251   006A 22 00         mov ah, 0
0252   006C FD 99         shl a              ; x2
0253   006E B7 B9 0F      mov a, [proc_table_convert + a]    ; get process state start index  
0254   0071               
0255   0071 4D            mov si, a            ; source is proc state block
0256   0072 48            mov a, sp
0257   0073 5F 13 00      sub a, 19
0258   0076 4F            mov di, a            ; destination is kernel stack
0259   0077             ; restore SP
0260   0077 7D            dec a
0261   0078 47            mov sp, a
0262   0079 38 14 00      mov c, 20
0263   007C FD F5         rep movsb
0264   007E             ; set VM process
0265   007E 1D 55 17      mov al, [active_proc_index]
0266   0081 01            setptb
0267   0082 F2 E0 FF 00   mov byte[_TIMER_C_0], 0        ; load counter 0 low byte
0268   0086 F2 E0 FF 10   mov byte[_TIMER_C_0], $10        ; load counter 0 high byte
0269   008A 4C            popa
0270   008B 06            sysret
0271   008C             
0272   008C             ; ------------------------------------------------------------------------------------------------------------------;
0273   008C             ; UART0 Interrupt
0274   008C             ; ------------------------------------------------------------------------------------------------------------------;
0275   008C             int_7:
0276   008C D7            push a
0277   008D DA            push d
0278   008E E1            pushf
0279   008F 14 5A 17      mov a, [fifo_in]
0280   0092 3C            mov d, a
0281   0093 31 80 FF      mov bl, [_UART0_DATA]  ; get character
0282   0096 C1 03         cmp bl, $03        ; CTRL-C
0283   0098 C6 01 01      je CTRLC
0284   009B C1 1A         cmp bl, $1A        ; CTRL-Z
0285   009D C6 07 01      je CTRLZ
0286   00A0 FD 3E         mov [d], bl        ; add to fifo
0287   00A2 77            inc a
0288   00A3 42 5A 17      mov [fifo_in], a
0289   00A6 AF 49 22      cmp a, fifo + FIFO_SIZE
0290   00A9 C6 B0 00      je int_7_xoff
0291   00AC             int_7_continue1:  
0292   00AC EE            popf
0293   00AD E7            pop d
0294   00AE E4            pop a  
0295   00AF 06            sysret
0296   00B0             
0297   00B0             int_7_xoff:    
0298   00B0 22 13         mov ah, XOFF  
0299   00B2 07 E2 10      call _putchar
0300   00B5 3B D4 00      mov d, s_int_7_xoff
0301   00B8 07 2C 12      call _puts
0302   00BB 29 5C 17      mov b, [fifo_out]
0303   00BE 07 84 12      call print_u16x
0304   00C1 22 20         mov ah, ' '
0305   00C3 07 E2 10      call _putchar
0306   00C6 29 5A 17      mov b, [fifo_in]
0307   00C9 07 84 12      call print_u16x
0308   00CC 22 0A         mov ah, $0A
0309   00CE 07 E2 10      call _putchar
0310   00D1 0A AC 00      jmp int_7_continue1
0311   00D4             
0312   00D4             ; condition for 'fifo-full':
0313   00D4             ; fifo_in == fifo + FIFO_SIZE
0314   00D4             ; condition for fifo recovery:
0315   00D4             ; fifo must be full and
0316   00D4             ; fifo_out == fifo_in
0317   00D4             
0318   00D4 0A 57 61 72 s_int_7_xoff: .db "\nWarning: FIFO is full. Sending XOFF. Ptrs: ", 0
0318   00D8 6E 69 6E 67 
0318   00DC 3A 20 46 49 
0318   00E0 46 4F 20 69 
0318   00E4 73 20 66 75 
0318   00E8 6C 6C 2E 20 
0318   00EC 53 65 6E 64 
0318   00F0 69 6E 67 20 
0318   00F4 58 4F 46 46 
0318   00F8 2E 20 50 74 
0318   00FC 72 73 3A 20 
0318   0100 00 
0319   0101             
0320   0101             CTRLC:
0321   0101 51 05 00      add sp, 5
0322   0104 0A C3 0E      jmp syscall_terminate_proc
0323   0107             CTRLZ:
0324   0107 EE            popf
0325   0108 E7            pop d
0326   0109 E4            pop a
0327   010A 0A 06 0F      jmp syscall_pause_proc    ; pause current process and go back to the shell
0328   010D             
0329   010D             ; ------------------------------------------------------------------------------------------------------------------;
0330   010D             ; System Syscalls
0331   010D             ; ------------------------------------------------------------------------------------------------------------------;
0332   010D             system_jmptbl:
0333   010D 3F 01         .dw system_uname
0334   010F 40 01         .dw system_whoami
0335   0111 3C 01         .dw system_setparam
0336   0113 19 01         .dw system_bootloader_install
0337   0115             syscall_system:
0338   0115 FD 0A 0D 01   jmp [system_jmptbl + al]
0339   0119             
0340   0119             ; kernel LBA address in 'b'
0341   0119             system_bootloader_install:
0342   0119 D8            push b
0343   011A 26 00 00      mov b, 0
0344   011D 38 00 00      mov c, 0
0345   0120 22 01         mov ah, $01                 ; 1 sector
0346   0122 3B 49 24      mov d, transient_area
0347   0125 07 6F 04      call ide_read_sect          ; read sector
0348   0128 E5            pop b
0349   0129 FD 44 FE 01   mov [d + 510], b            ; update LBA address
0350   012D 26 00 00      mov b, 0
0351   0130 38 00 00      mov c, 0
0352   0133 22 01         mov ah, $01                 ; 1 sector
0353   0135 3B 49 24      mov d, transient_area
0354   0138 07 95 04      call ide_write_sect         ; write sector
0355   013B 06            sysret
0356   013C             
0357   013C             ; param register address in register d
0358   013C             ; param value in register bl
0359   013C             system_setparam:
0360   013C FD 3E         mov [d], bl
0361   013E 06            sysret
0362   013F             
0363   013F             system_uname:
0364   013F 06            sysret
0365   0140             
0366   0140             system_whoami:
0367   0140 06            sysret
0368   0141             
0369   0141             ; REBOOT SYSTEM
0370   0141             syscall_reboot:
0371   0141 FD D7 FF FF   push word $FFFF 
0372   0145 FD DB 00      push byte %00000000             ; dma_ack = 0, interrupts disabled, mode = supervisor, paging = off, halt=0, display_reg_load=0, dir=0
0373   0148 FD D7 C0 01   push word BIOS_RESET_VECTOR    ; and then push RESET VECTOR of the shell to the stack
0374   014C 06            sysret
0375   014D             
0376   014D             ;------------------------------------------------------------------------------------------------------;;
0377   014D             ; switch to another process
0378   014D             ; inputs:
0379   014D             ; AL = new process number
0380   014D             ;------------------------------------------------------------------------------------------------------;;
0381   014D             syscall_resume_proc:
0382   014D FD 78         mov g, a                            ; save the process number
0383   014F 4B            pusha                               ; save all registers into kernel stack
0384   0150 22 00         mov ah, 0
0385   0152 1D 55 17      mov al, [active_proc_index]
0386   0155 FD 99         shl a              ; x2
0387   0157 B7 B9 0F      mov a, [proc_table_convert + a]     ; get process state start index
0388   015A 4F            mov di, a
0389   015B 48            mov a, sp
0390   015C 77            inc a
0391   015D 4D            mov si, a
0392   015E 38 14 00      mov c, 20
0393   0161 FD F5         rep movsb                           ; save process state!
0394   0163             ; restore kernel stack position to point before interrupt arrived
0395   0163 51 14 00      add sp, 20
0396   0166             ; now load the new process number!
0397   0166 FD 12         mov a, g                            ; retrieve the process number argument that was saved in the beginning
0398   0168 3D 55 17      mov [active_proc_index], al         ; set new active proc
0399   016B             ; calculate LUT entry for next process
0400   016B 22 00         mov ah, 0
0401   016D FD 99         shl a                               ; x2
0402   016F B7 B9 0F      mov a, [proc_table_convert + a]     ; get process state start index  
0403   0172 4D            mov si, a                           ; source is proc state block
0404   0173 48            mov a, sp
0405   0174 5F 13 00      sub a, 19
0406   0177 4F            mov di, a                           ; destination is kernel stack
0407   0178             ; restore SP
0408   0178 7D            dec a
0409   0179 47            mov sp, a
0410   017A 38 14 00      mov c, 20
0411   017D FD F5         rep movsb
0412   017F             ; set VM process
0413   017F 1D 55 17      mov al, [active_proc_index]
0414   0182 01            setptb
0415   0183 4C            popa
0416   0184 06            sysret
0417   0185             
0418   0185             syscall_list_procs:
0419   0185 3B 7A 17      mov d, s_ps_header
0420   0188 07 2C 12      call _puts
0421   018B 3B BA 19      mov d, proc_availab_table + 1
0422   018E 38 01 00      mov c, 1
0423   0191             list_procs_L0:  
0424   0191 BD 01         cmp byte[d], 1
0425   0193 C7 B7 01      jne list_procs_next
0426   0196 2D            mov b, d
0427   0197 61 B9 19      sub b, proc_availab_table
0428   019A FD 9F 05      shl b, 5
0429   019D DA            push d
0430   019E D8            push b
0431   019F 28            mov b, c
0432   01A0 07 C8 12      call print_u8x
0433   01A3 22 20         mov ah, ' '
0434   01A5 07 E2 10      call _putchar
0435   01A8 07 E2 10      call _putchar
0436   01AB E5            pop b
0437   01AC 74            mov d, b
0438   01AD 58 C9 19      add d, proc_names
0439   01B0 07 2C 12      call _puts
0440   01B3 07 D9 11      call printnl
0441   01B6 E7            pop d
0442   01B7             list_procs_next:
0443   01B7 79            inc d
0444   01B8 78            inc c
0445   01B9 C2 09 00      cmp c, 9
0446   01BC C7 91 01      jne list_procs_L0
0447   01BF             list_procs_end:
0448   01BF 06            sysret
0449   01C0             
0450   01C0             ; ------------------------------------------------------------------------------------------------------------------;
0451   01C0             ; Exceptions' Code Block
0452   01C0             ; ------------------------------------------------------------------------------------------------------------------;
0453   01C0             ; Privilege
0454   01C0             ; ------------------------------------------------------------------------------------------------------------------;
0455   01C0             trap_privilege:
0456   01C0 0A 41 01      jmp syscall_reboot
0457   01C3 DA            push d
0458   01C4 3B BC 17      mov d, s_priviledge
0459   01C7 07 2C 12      call _puts
0460   01CA E7            pop d
0461   01CB 06            sysret
0462   01CC             
0463   01CC             ; ------------------------------------------------------------------------------------------------------------------;
0464   01CC             ; Breakpoint
0465   01CC             ; IMPORTANT: values in the stack are being pushed in big endian. i.e.: MSB at low address
0466   01CC             ; and LSB at high address. *** NEED TO CORRECT THIS IN THE MICROCODE and make it little endian again ***
0467   01CC             ; ------------------------------------------------------------------------------------------------------------------;
0468   01CC             syscall_break:
0469   01CC 4B            pusha
0470   01CD             syscall_break_prompt:
0471   01CD 3B 87 02      mov d, s_break1
0472   01D0 07 2C 12      call _puts
0473   01D3 07 D9 11      call printnl
0474   01D6 07 26 13      call scan_u16d
0475   01D9 AF 00 00      cmp a, 0
0476   01DC C6 E7 01      je syscall_break_regs
0477   01DF AF 01 00      cmp a, 1
0478   01E2 C6 0A 02      je syscall_break_mem
0479   01E5             syscall_break_end:  
0480   01E5 4C            popa
0481   01E6 06            sysret
0482   01E7             syscall_break_regs:
0483   01E7 48            mov a, sp
0484   01E8 53 0E 00      add a, 14               ; back-track 7 registers
0485   01EB 3C            mov d, a
0486   01EC 3A 07         mov cl, 7
0487   01EE             syscall_regs_L0:
0488   01EE 2A            mov b, [d]
0489   01EF FD AB         swp b
0490   01F1 07 84 12      call print_u16x         ; print register value
0491   01F4 07 D9 11      call printnl
0492   01F7 63 02 00      sub d, 2
