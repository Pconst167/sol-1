1289   075E 58 20 00      add d, FST_ENTRY_SIZE
1290   0761 0A 59 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
