1074   0603             fs_cd_root:
1075   0603 10 20 00      mov a, root_id
1076   0606 42 0A 17      mov [current_dirID], a      ; set current directory LBA to ROOT
1077   0609 06            sysret  
1078   060A             
1079   060A             ; filename in D (userspace data)
1080   060A             ; permission in BL
1081   060A             fs_chmod:
1082   060A DD            push bl
1083   060B FD 4E         mov si, d
1084   060D FD 4F F5 1B   mov di, user_data
1085   0611 38 80 00      mov c, 128
1086   0614 04            load                        ; load filename from user-space
1087   0615 14 0A 17      mov a, [current_dirID]
1088   0618 77            inc a                       ; metadata sector
1089   0619 27            mov b, a
1090   061A 38 00 00      mov c, 0                    ; reset LBA to 0
1091   061D 22 01         mov ah, $01                 ; disk read
1092   061F 3B F5 3D      mov d, transient_area
1093   0622 07 62 04      call ide_read_sect          ; read directory
1094   0625 FD 10         cla
1095   0627 42 02 17      mov [index], a              ; reset file counter
1096   062A             fs_chmod_L1:
1097   062A FD 4E         mov si, d
1098   062C FD 4F F5 1B   mov di, user_data
1099   0630 07 F8 0F      call _strcmp
1100   0633 C6 4A 06      je fs_chmod_found_entry
1101   0636 58 20 00      add d, 32
1102   0639 14 02 17      mov a, [index]
1103   063C 77            inc a
1104   063D 42 02 17      mov [index], a
1105   0640 AF 10 00      cmp a, FST_FILES_PER_DIR
1106   0643 C7 2A 06      jne fs_chmod_L1
1107   0646 EA            pop bl
1108   0647 0A 63 06      jmp fs_chmod_not_found
1109   064A             fs_chmod_found_entry:  
1110   064A FD 79         mov g, b                    ; save LBA
1111   064C EA            pop bl                      ; retrieve saved permission value
1112   064D 1F 18 00      mov al, [d + 24]            ; read file permissions
1113   0650 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1114   0652 8C            or al, bl                   ; set new permissions
1115   0653 3F 18 00      mov [d + 24], al            ; write new permissions
1116   0656 38 00 00      mov c, 0
1117   0659 3B F5 3D      mov d, transient_area
1118   065C 22 01         mov ah, $01                 ; disk write 1 sect
1119   065E FD 27         mov b, g                    ; retrieve LBA
1120   0660 07 88 04      call ide_write_sect         ; write sector
1121   0663             fs_chmod_not_found:
1122   0663 06            sysret
1123   0664             
1124   0664             
1125   0664             ;------------------------------------------------------------------------------------------------------;
1126   0664             ; CREATE NEW DIRECTORY
1127   0664             ;------------------------------------------------------------------------------------------------------;
1128   0664             ; search list for NULL name entry. add new directory to list
1129   0664             fs_mkdir:
1130   0664 FD 4E         mov si, d
1131   0666 FD 4F F5 1B   mov di, user_data
1132   066A 38 00 02      mov c, 512
1133   066D 04            load                        ; load data from user-space
1134   066E 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1135   0671                                           ; when checking for NULL name, since root has a NULL name)
1136   0671 38 00 00      mov c, 0                    ; reset LBA to 0
1137   0674             fs_mkdir_L1:  
1138   0674 22 01         mov ah, $01                 ; disk read
1139   0676 3B F5 3D      mov d, transient_area
1140   0679 07 62 04      call ide_read_sect          ; read sector
1141   067C BD 00         cmp byte[d], 0              ; check for NULL
1142   067E C6 87 06      je fs_mkdir_found_null
1143   0681 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1144   0684 0A 74 06      jmp fs_mkdir_L1
1145   0687             fs_mkdir_found_null:
1146   0687             ;create header file by grabbing dir name from parameter
1147   0687 D8            push b                      ; save new directory's LBA
1148   0688 38 40 00      mov c, 64
1149   068B FD 4D F5 1B   mov si, user_data
1150   068F FD 4F F5 3D   mov di, transient_area
1151   0693 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1152   0695 14 0A 17      mov a, [current_dirID]
1153   0698 42 35 3E      mov [transient_area + 64], a    ; store parent directory LBA
1154   069B 19 00         mov al, 0
1155   069D FD 4F F5 3F   mov di, transient_area + 512
1156   06A1 38 00 02      mov c, 512
1157   06A4 FD F7         rep stosb                       ; clean buffer
1158   06A6 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1159   06A9             ; write directory entry sectors
1160   06A9 3B F5 3D      mov d, transient_area
1161   06AC 22 02         mov ah, $02                     ; disk write, 2 sectors
1162   06AE 07 88 04      call ide_write_sect             ; write sector
1163   06B1             ; now we need to add the new directory to the list, insIDE the current directory
1164   06B1 14 0A 17      mov a, [current_dirID]
1165   06B4 53 01 00      add a, 1
1166   06B7 27            mov b, a                        ; metadata sector
1167   06B8 38 00 00      mov c, 0
1168   06BB FD 79         mov g, b                        ; save LBA
1169   06BD 3B F5 3D      mov d, transient_area
1170   06C0 22 01         mov ah, $01                     ; disk read
1171   06C2 07 62 04      call ide_read_sect              ; read metadata sector
1172   06C5             fs_mkdir_L2:
1173   06C5 BD 00         cmp byte[d], 0
1174   06C7 C6 D0 06      je fs_mkdir_found_null2
1175   06CA 58 20 00      add d, FST_ENTRY_SIZE
1176   06CD 0A C5 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1177   06D0             fs_mkdir_found_null2:
1178   06D0 FD 4D F5 1B   mov si, user_data
1179   06D4 FD 50         mov di, d
1180   06D6 07 0D 10      call _strcpy                    ; copy directory name
1181   06D9 58 18 00      add d, 24                       ; goto ATTRIBUTES
1182   06DC 19 0B         mov al, %00001011               ; directory, no execute, write, read
1183   06DE 3E            mov [d], al      
1184   06DF 79            inc d
1185   06E0 E5            pop b
1186   06E1 D8            push b                          ; push LBA back
1187   06E2 FD 43         mov [d], b                      ; save LBA
1188   06E4             ; set file creation date  
1189   06E4 58 04 00      add d, 4
1190   06E7 19 04         mov al, 4
1191   06E9 05 01         syscall sys_rtc
1192   06EB 1A            mov al, ah
1193   06EC 3E            mov [d], al                     ; set day
1194   06ED 79            inc d
1195   06EE 19 05         mov al, 5
1196   06F0 05 01         syscall sys_rtc
1197   06F2 1A            mov al, ah
1198   06F3 3E            mov [d], al                     ; set month
1199   06F4 79            inc d
1200   06F5 19 06         mov al, 6
1201   06F7 05 01         syscall sys_rtc
1202   06F9 1A            mov al, ah
1203   06FA 3E            mov [d], al                     ; set year
1204   06FB             ; write sector into disk for new directory entry
1205   06FB FD 27         mov b, g
1206   06FD 38 00 00      mov c, 0
1207   0700 3B F5 3D      mov d, transient_area
1208   0703 22 01         mov ah, $01                     ; disk write, 1 sector
1209   0705 07 88 04      call ide_write_sect             ; write sector
1210   0708             
1211   0708             ; after adding the new directory's information to its parent directory's list
1212   0708             ; we need to now enter the new directory, and to it add two new directories!
1213   0708             ; which directories do we need to add ? '..' and '.' are the directories needed.
1214   0708             ; importantly, note that these two new directories are only entries in the list
1215   0708             ; and do not have actual physical entries in the disk as real directories.
1216   0708             ; i.e. they only exist as list entries in the new directory created so that
1217   0708             ; the new directory can reference its parent and itself.
1218   0708             ; We need to add both '..' and '.'
1219   0708             ; this first section is for '..' and on the section below we do the same for '.'
1220   0708 E4            pop a                         ; retrieve the new directory's LBA  
1221   0709 D7            push a                        ; and save again
1222   070A 53 01 00      add a, 1
1223   070D 27            mov b, a                      ; metadata sector
1224   070E 38 00 00      mov c, 0
1225   0711 FD 79         mov g, b                      ; save LBA
1226   0713 3B F5 3D      mov d, transient_area
1227   0716 22 01         mov ah, $01                   ; disk read
1228   0718 07 62 04      call ide_read_sect            ; read metadata sector
1229   071B             fs_mkdir_L3:
1230   071B BD 00         cmp byte[d], 0
1231   071D C6 26 07      je fs_mkdir_found_null3
1232   0720 58 20 00      add d, FST_ENTRY_SIZE
1233   0723 0A 1B 07      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1234   0726             fs_mkdir_found_null3:
1235   0726 FD 4D 17 17   mov si, s_parent_dir
1236   072A FD 50         mov di, d
1237   072C 07 0D 10      call _strcpy                  ; copy directory name
1238   072F 58 18 00      add d, 24                     ; goto ATTRIBUTES
1239   0732 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1240   0734 3E            mov [d], al      
1241   0735 79            inc d
1242   0736 29 0A 17      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1243   0739 FD 43         mov [d], b                    ; save LBA
1244   073B             ; set file creation date  
1245   073B 58 04 00      add d, 4
1246   073E 19 04         mov al, 4
1247   0740 05 01         syscall sys_rtc
1248   0742 1A            mov al, ah
1249   0743 3E            mov [d], al                   ; set day
1250   0744 79            inc d
1251   0745 19 05         mov al, 5
1252   0747 05 01         syscall sys_rtc
1253   0749 1A            mov al, ah
1254   074A 3E            mov [d], al                   ; set month
1255   074B 79            inc d
1256   074C 19 06         mov al, 6
1257   074E 05 01         syscall sys_rtc
1258   0750 1A            mov al, ah
1259   0751 3E            mov [d], al                   ; set year
1260   0752             ; write sector into disk for new directory entry
1261   0752 FD 27         mov b, g
1262   0754 38 00 00      mov c, 0
1263   0757 3B F5 3D      mov d, transient_area
1264   075A 22 01         mov ah, $01                   ; disk write, 1 sector
1265   075C 07 88 04      call ide_write_sect           ; write sector
1266   075F             ;;;;;;;;;;;;;
1267   075F             ; like we did above for '..', we need to now add the '.' directory to the list.
1268   075F             ;------------------------------------------------------------------------------------------------------;
1269   075F E4            pop a                         ; retrieve the new directory's LBA  
1270   0760 D7            push a
1271   0761 53 01 00      add a, 1
1272   0764 27            mov b, a                      ; metadata sector
1273   0765 38 00 00      mov c, 0
1274   0768 FD 79         mov g, b                      ; save LBA
1275   076A 3B F5 3D      mov d, transient_area
1276   076D 22 01         mov ah, $01                   ; disk read
1277   076F 07 62 04      call ide_read_sect            ; read metadata sector
1278   0772             fs_mkdir_L4:
1279   0772 BD 00         cmp byte[d], 0
1280   0774 C6 7D 07      je fs_mkdir_found_null4
1281   0777 58 20 00      add d, FST_ENTRY_SIZE
1282   077A 0A 72 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1283   077D             fs_mkdir_found_null4:
1284   077D FD 4D 1A 17   mov si, s_current_dir
1285   0781 FD 50         mov di, d
1286   0783 07 0D 10      call _strcpy                  ; copy directory name
1287   0786 58 18 00      add d, 24                     ; goto ATTRIBUTES
1288   0789 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1289   078B 3E            mov [d], al      
1290   078C 79            inc d
1291   078D E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1292   078E FD 43         mov [d], b                    ; save LBA
1293   0790             ; set file creation date  
1294   0790 58 04 00      add d, 4
1295   0793 19 04         mov al, 4
1296   0795 05 01         syscall sys_rtc
1297   0797 1A            mov al, ah
1298   0798 3E            mov [d], al                   ; set day
1299   0799 79            inc d
1300   079A 19 05         mov al, 5
1301   079C 05 01         syscall sys_rtc
1302   079E 1A            mov al, ah
1303   079F 3E            mov [d], al                   ; set month
1304   07A0 79            inc d
1305   07A1 19 06         mov al, 6
1306   07A3 05 01         syscall sys_rtc
1307   07A5 1A            mov al, ah
1308   07A6 3E            mov [d], al                   ; set year
1309   07A7             ; write sector into disk for new directory entry
1310   07A7 FD 27         mov b, g
1311   07A9 38 00 00      mov c, 0
1312   07AC 3B F5 3D      mov d, transient_area
