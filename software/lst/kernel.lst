1367   0830 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1368   0833 C6 42 08      je fs_dir_id_to_path_root
1369   0836 07 60 08      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1370   0839 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1371   083C C6 42 08      je fs_dir_id_to_path_root
1372   083F 07 24 08      call fs_dir_id_to_path_E0     ; recursively call itself
1373   0842             fs_dir_id_to_path_root:
1374   0842 09            ret
