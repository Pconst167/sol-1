1104   0667             ;------------------------------------------------------------------------------------------------------;
1105   0667             ; CREATE NEW DIRECTORY
1106   0667             ;------------------------------------------------------------------------------------------------------;
1107   0667             ; search list for NULL name entry. add new directory to list
1108   0667             fs_mkdir:
1109   0667 FD 4E         mov si, d
1110   0669 FD 4F DD 1B   mov di, user_data
1111   066D 38 00 02      mov c, 512
1112   0670 04            load                        ; load data from user-space
1113   0671 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1114   0674                                           ; when checking for NULL name, since root has a NULL name)
1115   0674 38 00 00      mov c, 0                    ; reset LBA to 0
1116   0677             fs_mkdir_L1:  
1117   0677 22 01         mov ah, $01                 ; disk read
1118   0679 3B DD 23      mov d, transient_area
1119   067C 07 4E 04      call ide_read_sect          ; read sector
1120   067F BD 00         cmp byte[d], 0              ; check for NULL
1121   0681 C6 8A 06      je fs_mkdir_found_null
1122   0684 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1123   0687 0A 77 06      jmp fs_mkdir_L1
1124   068A             fs_mkdir_found_null:
1125   068A             ;create header file by grabbing dir name from parameter
1126   068A D8            push b                      ; save new directory's LBA
1127   068B 38 40 00      mov c, 64
1128   068E FD 4D DD 1B   mov si, user_data
1129   0692 FD 4F DD 23   mov di, transient_area
1130   0696 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1131   0698 14 F2 16      mov a, [current_dirID]
1132   069B 42 1D 24      mov [transient_area + 64], a    ; store parent directory LBA
1133   069E 19 00         mov al, 0
1134   06A0 FD 4F DD 25   mov di, transient_area + 512
1135   06A4 38 00 02      mov c, 512
1136   06A7 FD F7         rep stosb                       ; clean buffer
1137   06A9 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1138   06AC             ; write directory entry sectors
1139   06AC 3B DD 23      mov d, transient_area
1140   06AF 22 02         mov ah, $02                     ; disk write, 2 sectors
1141   06B1 07 74 04      call ide_write_sect             ; write sector
1142   06B4             ; now we need to add the new directory to the list, insIDE the current directory
1143   06B4 14 F2 16      mov a, [current_dirID]
1144   06B7 53 01 00      add a, 1
1145   06BA 27            mov b, a                        ; metadata sector
1146   06BB 38 00 00      mov c, 0
1147   06BE FD 79         mov g, b                        ; save LBA
1148   06C0 3B DD 23      mov d, transient_area
1149   06C3 22 01         mov ah, $01                     ; disk read
1150   06C5 07 4E 04      call ide_read_sect              ; read metadata sector
1151   06C8             fs_mkdir_L2:
1152   06C8 BD 00         cmp byte[d], 0
1153   06CA C6 D3 06      je fs_mkdir_found_null2
1154   06CD 58 20 00      add d, FST_ENTRY_SIZE
1155   06D0 0A C8 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1156   06D3             fs_mkdir_found_null2:
1157   06D3 FD 4D DD 1B   mov si, user_data
1158   06D7 FD 50         mov di, d
1159   06D9 07 10 10      call _strcpy                    ; copy directory name
1160   06DC 58 18 00      add d, 24                       ; goto ATTRIBUTES
1161   06DF 19 0B         mov al, %00001011               ; directory, no execute, write, read
1162   06E1 3E            mov [d], al      
1163   06E2 79            inc d
1164   06E3 E5            pop b
1165   06E4 D8            push b                          ; push LBA back
1166   06E5 FD 43         mov [d], b                      ; save LBA
1167   06E7             ; set file creation date  
1168   06E7 58 04 00      add d, 4
1169   06EA 19 04         mov al, 4
1170   06EC 05 01         syscall sys_rtc
1171   06EE 1A            mov al, ah
1172   06EF 3E            mov [d], al                     ; set day
1173   06F0 79            inc d
1174   06F1 19 05         mov al, 5
1175   06F3 05 01         syscall sys_rtc
1176   06F5 1A            mov al, ah
1177   06F6 3E            mov [d], al                     ; set month
1178   06F7 79            inc d
1179   06F8 19 06         mov al, 6
1180   06FA 05 01         syscall sys_rtc
1181   06FC 1A            mov al, ah
1182   06FD 3E            mov [d], al                     ; set year
1183   06FE             ; write sector into disk for new directory entry
1184   06FE FD 27         mov b, g
1185   0700 38 00 00      mov c, 0
1186   0703 3B DD 23      mov d, transient_area
1187   0706 22 01         mov ah, $01                     ; disk write, 1 sector
1188   0708 07 74 04      call ide_write_sect             ; write sector
1189   070B             
1190   070B             ; after adding the new directory's information to its parent directory's list
1191   070B             ; we need to now enter the new directory, and to it add two new directories!
1192   070B             ; which directories do we need to add ? '..' and '.' are the directories needed.
1193   070B             ; importantly, note that these two new directories are only entries in the list
1194   070B             ; and do not have actual physical entries in the disk as real directories.
1195   070B             ; i.e. they only exist as list entries in the new directory created so that
1196   070B             ; the new directory can reference its parent and itself.
1197   070B             ; We need to add both '..' and '.'
1198   070B             ; this first section is for '..' and on the section below we do the same for '.'
1199   070B E4            pop a                         ; retrieve the new directory's LBA  
1200   070C D7            push a                        ; and save again
1201   070D 53 01 00      add a, 1
1202   0710 27            mov b, a                      ; metadata sector
1203   0711 38 00 00      mov c, 0
1204   0714 FD 79         mov g, b                      ; save LBA
1205   0716 3B DD 23      mov d, transient_area
1206   0719 22 01         mov ah, $01                   ; disk read
1207   071B 07 4E 04      call ide_read_sect            ; read metadata sector
1208   071E             fs_mkdir_L3:
1209   071E BD 00         cmp byte[d], 0
1210   0720 C6 29 07      je fs_mkdir_found_null3
1211   0723 58 20 00      add d, FST_ENTRY_SIZE
1212   0726 0A 1E 07      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1213   0729             fs_mkdir_found_null3:
1214   0729 FD 4D FF 16   mov si, s_parent_dir
1215   072D FD 50         mov di, d
1216   072F 07 10 10      call _strcpy                  ; copy directory name
1217   0732 58 18 00      add d, 24                     ; goto ATTRIBUTES
1218   0735 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1219   0737 3E            mov [d], al      
1220   0738 79            inc d
1221   0739 29 F2 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1222   073C FD 43         mov [d], b                    ; save LBA
1223   073E             ; set file creation date  
1224   073E 58 04 00      add d, 4
1225   0741 19 04         mov al, 4
1226   0743 05 01         syscall sys_rtc
1227   0745 1A            mov al, ah
1228   0746 3E            mov [d], al                   ; set day
1229   0747 79            inc d
1230   0748 19 05         mov al, 5
1231   074A 05 01         syscall sys_rtc
1232   074C 1A            mov al, ah
1233   074D 3E            mov [d], al                   ; set month
1234   074E 79            inc d
1235   074F 19 06         mov al, 6
1236   0751 05 01         syscall sys_rtc
1237   0753 1A            mov al, ah
1238   0754 3E            mov [d], al                   ; set year
1239   0755             ; write sector into disk for new directory entry
1240   0755 FD 27         mov b, g
1241   0757 38 00 00      mov c, 0
1242   075A 3B DD 23      mov d, transient_area
1243   075D 22 01         mov ah, $01                   ; disk write, 1 sector
1244   075F 07 74 04      call ide_write_sect           ; write sector
1245   0762             ;;;;;;;;;;;;;
1246   0762             ; like we did above for '..', we need to now add the '.' directory to the list.
1247   0762             ;------------------------------------------------------------------------------------------------------;
1248   0762 E4            pop a                         ; retrieve the new directory's LBA  
1249   0763 D7            push a
1250   0764 53 01 00      add a, 1
1251   0767 27            mov b, a                      ; metadata sector
1252   0768 38 00 00      mov c, 0
1253   076B FD 79         mov g, b                      ; save LBA
1254   076D 3B DD 23      mov d, transient_area
1255   0770 22 01         mov ah, $01                   ; disk read
1256   0772 07 4E 04      call ide_read_sect            ; read metadata sector
1257   0775             fs_mkdir_L4:
1258   0775 BD 00         cmp byte[d], 0
1259   0777 C6 80 07      je fs_mkdir_found_null4
1260   077A 58 20 00      add d, FST_ENTRY_SIZE
1261   077D 0A 75 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1262   0780             fs_mkdir_found_null4:
1263   0780 FD 4D 02 17   mov si, s_current_dir
1264   0784 FD 50         mov di, d
1265   0786 07 10 10      call _strcpy                  ; copy directory name
1266   0789 58 18 00      add d, 24                     ; goto ATTRIBUTES
1267   078C 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1268   078E 3E            mov [d], al      
1269   078F 79            inc d
1270   0790 E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1271   0791 FD 43         mov [d], b                    ; save LBA
1272   0793             ; set file creation date  
1273   0793 58 04 00      add d, 4
1274   0796 19 04         mov al, 4
1275   0798 05 01         syscall sys_rtc
1276   079A 1A            mov al, ah
1277   079B 3E            mov [d], al                   ; set day
1278   079C 79            inc d
1279   079D 19 05         mov al, 5
1280   079F 05 01         syscall sys_rtc
1281   07A1 1A            mov al, ah
1282   07A2 3E            mov [d], al                   ; set month
1283   07A3 79            inc d
1284   07A4 19 06         mov al, 6
1285   07A6 05 01         syscall sys_rtc
1286   07A8 1A            mov al, ah
1287   07A9 3E            mov [d], al                   ; set year
1288   07AA             ; write sector into disk for new directory entry
1289   07AA FD 27         mov b, g
1290   07AC 38 00 00      mov c, 0
1291   07AF 3B DD 23      mov d, transient_area
1292   07B2 22 01         mov ah, $01                   ; disk write, 1 sector
1293   07B4 07 74 04      call ide_write_sect           ; write sector
