0738   03EE             syscall_ide:
0739   03EE DD            push bl
0740   03EF 31 A3 16      mov bl, [sys_debug_mode]
0741   03F2               ; debug block
0742   03F2 C1 00         cmp bl, 0
0743   03F4 EA            pop bl
