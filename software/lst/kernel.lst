0755   0409 FD 0A E6 03   jmp [ide_serv_tbl + al]    
0756   040D               
0757   040D             ide_reset:      
0758   040D F2 D7 FF 04   mov byte[_ide_R7], 4            ; RESET IDE
0759   0411 07 BA 04      call ide_wait                   ; wait for IDE ready             
0760   0414 F2 D6 FF E0   mov byte[_ide_R6], $E0          ; LBA3= 0, MASTER, MODE= LBA        
0761   0418 F2 D1 FF 01   mov byte[_ide_R1], 1            ; 8-BIT TRANSFERS      
0762   041C F2 D7 FF EF   mov byte[_ide_R7], $EF          ; SET FEATURE COMMAND
0763   0420 06            sysret
0764   0421             ide_sleep:
0765   0421 07 BA 04      call ide_wait                   ; wait for IDE ready             
0766   0424 F2 D6 FF 40   mov byte [_ide_R6], %01000000   ; lba[3:0](reserved), bit 6=1
0767   0428 F2 D7 FF E6   mov byte [_ide_R7], $E6         ; sleep command
0768   042C 07 BA 04      call ide_wait                   ; wait for IDE ready
0769   042F 06            sysret
0770   0430             ide_read_sect_wrapper:
0771   0430 07 38 04      call ide_read_sect
0772   0433 06            sysret
0773   0434             ide_write_sect_wrapper:
