0595   0AB4             ; RTC SERVICES INTERRUPT
0596   0AB4             ; RTC I/O bank = FFA0 to FFAF
0597   0AB4             ; FFA0 to FFA7 is scratch RAM
0598   0AB4             ; control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0599   0AB4             ; al = 0..6 -> get
0600   0AB4             ; al = 7..D -> set
