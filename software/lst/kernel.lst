1027   0585             fs_cd_root:
1028   0585 10 20 00      mov a, root_id
1029   0588 42 6A 16      mov [current_dirID], a      ; set current directory LBA to ROOT
1030   058B 06            sysret  
1031   058C             
1032   058C             ; filename in D (userspace data)
1033   058C             ; permission in BL
1034   058C             fs_chmod:
1035   058C DD            push bl
1036   058D FD 4E         mov si, d
1037   058F FD 4F 55 1B   mov di, user_data
1038   0593 38 80 00      mov c, 128
1039   0596 04            load                        ; load filename from user-space
1040   0597 14 6A 16      mov a, [current_dirID]
1041   059A 77            inc a                       ; metadata sector
1042   059B 27            mov b, a
1043   059C 38 00 00      mov c, 0                    ; reset LBA to 0
1044   059F 22 01         mov ah, $01                 ; disk read
1045   05A1 3B 55 37      mov d, transient_area
1046   05A4 07 27 04      call ide_read_sect          ; read directory
1047   05A7 FD 10         cla
1048   05A9 42 62 16      mov [index], a              ; reset file counter
1049   05AC             fs_chmod_L1:
1050   05AC FD 4E         mov si, d
1051   05AE FD 4F 55 1B   mov di, user_data
1052   05B2 07 73 0F      call _strcmp
1053   05B5 C6 CC 05      je fs_chmod_found_entry
1054   05B8 58 20 00      add d, 32
1055   05BB 14 62 16      mov a, [index]
1056   05BE 77            inc a
1057   05BF 42 62 16      mov [index], a
1058   05C2 AF 10 00      cmp a, FST_FILES_PER_DIR
1059   05C5 C7 AC 05      jne fs_chmod_L1
1060   05C8 EA            pop bl
1061   05C9 0A E5 05      jmp fs_chmod_not_found
1062   05CC             fs_chmod_found_entry:  
1063   05CC FD 79         mov g, b                    ; save LBA
1064   05CE EA            pop bl                      ; retrieve saved permission value
1065   05CF 1F 18 00      mov al, [d + 24]            ; read file permissions
1066   05D2 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1067   05D4 8C            or al, bl                   ; set new permissions
1068   05D5 3F 18 00      mov [d + 24], al            ; write new permissions
1069   05D8 38 00 00      mov c, 0
1070   05DB 3B 55 37      mov d, transient_area
1071   05DE 22 01         mov ah, $01                 ; disk write 1 sect
1072   05E0 FD 27         mov b, g                    ; retrieve LBA
1073   05E2 07 4D 04      call ide_write_sect         ; write sector
1074   05E5             fs_chmod_not_found:
1075   05E5 06            sysret
