1044   05B3 C1 00         cmp bl, 0
1045   05B5 EA            pop bl
1046   05B6 C6 CA 05      je syscall_filesystem_jmp
1047   05B9 DA            push d
1048   05BA DD            push bl
1049   05BB 3B 8F 05      mov d, s_syscall_fs_dbg0
1050   05BE 07 7A 11      call _puts
1051   05C1 2F            mov bl, al
1052   05C2 07 1A 12      call print_u8x
1053   05C5 07 27 11      call printnl
1054   05C8 EA            pop bl
