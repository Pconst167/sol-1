0933   050A C7 10 05      jne syscall_io_getch_cont
0934   050D 10 61 1D      mov a, fifo  
0935   0510             syscall_io_getch_cont:  
0936   0510 42 74 16      mov [fifo_out], a             ; update fifo pointer
0937   0513 E9            pop ah
0938   0514             ; here we just echo the char back to the console
0939   0514             syscall_io_getch_echo_L0:
0940   0514 1D 85 FF      mov al, [_UART0_LSR]         ; read Line Status Register
0941   0517 93 20         test al, $20                 ; isolate Transmitter Empty
0942   0519 C6 14 05      jz syscall_io_getch_echo_L0
0943   051C 1A            mov al, ah
0944   051D 3D 80 FF      mov [_UART0_DATA], al        ; write char to Transmitter Holding Register
0945   0520 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0946   0522 E7            pop d
0947   0523 E5            pop b
0948   0524 06            sysret
