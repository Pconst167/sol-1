2693   18B4             ; ************************************************************
2694   18B4             ; GET HEX FILE
2695   18B4             ; di = destination address
2696   18B4             ; return length in bytes in C
2697   18B4             ; ************************************************************
2698   18B4             _load_hex:
2699   18B4 D2            push bp
2700   18B5 9B            mov bp, sp
2701   18B6 D7            push a
2702   18B7 D8            push b
2703   18B8 DA            push d
2704   18B9 E2            push si
2705   18BA E3            push di
2706   18BB 52 00 80      sub sp, $8000      ; string data block
2707   18BE 38 00 00      mov c, 0
2708   18C1 48            mov a, sp
2709   18C2 77            inc a
2710   18C3 3C            mov d, a          ; start of string data block
2711   18C4 07 32 01      call _gets        ; get program string
2712   18C7 4D            mov si, a
2713   18C8             __load_hex_loop:
2714   18C8 F6            lodsb             ; load from [SI] to AL
2715   18C9 B9 00         cmp al, 0         ; check if ASCII 0
2716   18CB C6 D9 18      jz __load_hex_ret
2717   18CE 36            mov bh, al
2718   18CF F6            lodsb
2719   18D0 2F            mov bl, al
2720   18D1 07 E1 00      call _atoi        ; convert ASCII byte in B to int (to AL)
2721   18D4 F7            stosb             ; store AL to [DI]
2722   18D5 78            inc c
2723   18D6 0A C8 18      jmp __load_hex_loop
2724   18D9             __load_hex_ret:
2725   18D9 51 00 80      add sp, $8000
2726   18DC F0            pop di
2727   18DD EF            pop si
2728   18DE E7            pop d
2729   18DF E5            pop b
2730   18E0 E4            pop a
2731   18E1 9C            mov sp, bp
2732   18E2 F1            pop bp
2733   18E3 09            ret
2734   18E4             
2735   18E4             ; ************************************************************
2736   18E4             ; GET HEX FILE WITHOUT ECHO
2737   18E4             ; di = destination address
2738   18E4             ; return length in bytes in C
2739   18E4             ; ************************************************************
2740   18E4             _load_hex_sil:
2741   18E4 D2            push bp
2742   18E5 9B            mov bp, sp
2743   18E6 D7            push a
2744   18E7 D8            push b
2745   18E8 DA            push d
2746   18E9 E2            push si
2747   18EA E3            push di
2748   18EB 52 00 80      sub sp, $8000      ; string data block
2749   18EE 38 00 00      mov c, 0
2750   18F1 48            mov a, sp
2751   18F2 77            inc a
2752   18F3 3C            mov d, a          ; start of string data block
2753   18F4 07 D9 01      call _gets_sil        ; get program string silently
2754   18F7 4D            mov si, a
2755   18F8             __load_hex_sil_loop:
2756   18F8 F6            lodsb             ; load from [SI] to AL
2757   18F9 B9 00         cmp al, 0         ; check if ASCII 0
2758   18FB C6 09 19      jz __load_hex_sil_ret
2759   18FE 36            mov bh, al
2760   18FF F6            lodsb
2761   1900 2F            mov bl, al
2762   1901 07 E1 00      call _atoi        ; convert ASCII byte in B to int (to AL)
2763   1904 F7            stosb             ; store AL to [DI]
2764   1905 78            inc c
2765   1906 0A F8 18      jmp __load_hex_sil_loop
2766   1909             __load_hex_sil_ret:
2767   1909 51 00 80      add sp, $8000
2768   190C F0            pop di
2769   190D EF            pop si
2770   190E E7            pop d
2771   190F E5            pop b
2772   1910 E4            pop a
2773   1911 9C            mov sp, bp
2774   1912 F1            pop bp
2775   1913 09            ret
2776   1914             
2777   1914             ; synopsis: look insIDE a certain DIRECTORY for files/directories
2778   1914             ; BEFORE CALLING THIS FUNCTION, CD INTO REQUIRED DIRECTORY
2779   1914             ; for each entry insIDE DIRECTORY:
2780   1914             ;  if entry is a file:
2781   1914             ;    compare filename to searched filename
2782   1914             ;    if filenames are the same, print filename
2783   1914             ;  else if entry is a directory:
2784   1914             ;    cd to the given directory
2785   1914             ;    recursively call cmd_find
2786   1914             ;    cd outsIDE previous directory
2787   1914             ;  if current entry == last entry, return
2788   1914             ; endfor
2789   1914             f_find:
2790   1914 09            ret
