1247   0719 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1248   071B 3E            mov [d], al      
1249   071C 79            inc d
1250   071D 29 CF 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1251   0720 FD 43         mov [d], b                    ; save LBA
