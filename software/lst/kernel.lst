1065   05D5 06            sysret  
1066   05D6             
1067   05D6             ; filename in D (userspace data)
1068   05D6             ; permission in BL
1069   05D6             fs_chmod:
1070   05D6 DD            push bl
1071   05D7 FD 4E         mov si, d
1072   05D9 FD 4F 9F 1B   mov di, user_data
1073   05DD 38 80 00      mov c, 128
1074   05E0 04            load                        ; load filename from user-space
1075   05E1 14 B4 16      mov a, [current_dirID]
1076   05E4 77            inc a                       ; metadata sector
1077   05E5 27            mov b, a
1078   05E6 38 00 00      mov c, 0                    ; reset LBA to 0
1079   05E9 22 01         mov ah, $01                 ; disk read
1080   05EB 3B 9F 27      mov d, transient_area
1081   05EE 07 38 04      call ide_read_sect          ; read directory
1082   05F1 FD 10         cla
1083   05F3 42 AC 16      mov [index], a              ; reset file counter
1084   05F6             fs_chmod_L1:
1085   05F6 FD 4E         mov si, d
1086   05F8 FD 4F 9F 1B   mov di, user_data
1087   05FC 07 BD 0F      call _strcmp
1088   05FF C6 16 06      je fs_chmod_found_entry
1089   0602 58 20 00      add d, 32
1090   0605 14 AC 16      mov a, [index]
1091   0608 77            inc a
1092   0609 42 AC 16      mov [index], a
1093   060C AF 10 00      cmp a, FST_FILES_PER_DIR
1094   060F C7 F6 05      jne fs_chmod_L1
1095   0612 EA            pop bl
1096   0613 0A 2F 06      jmp fs_chmod_not_found
1097   0616             fs_chmod_found_entry:  
1098   0616 FD 79         mov g, b                    ; save LBA
1099   0618 EA            pop bl                      ; retrieve saved permission value
1100   0619 1F 18 00      mov al, [d + 24]            ; read file permissions
1101   061C 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1102   061E 8C            or al, bl                   ; set new permissions
1103   061F 3F 18 00      mov [d + 24], al            ; write new permissions
1104   0622 38 00 00      mov c, 0
1105   0625 3B 9F 27      mov d, transient_area
1106   0628 22 01         mov ah, $01                 ; disk write 1 sect
1107   062A FD 27         mov b, g                    ; retrieve LBA
1108   062C 07 5E 04      call ide_write_sect         ; write sector
1109   062F             fs_chmod_not_found:
1110   062F 06            sysret
