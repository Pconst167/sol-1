1076   05EB 42 EA 16      mov [current_dirID], a      ; set current directory LBA to ROOT
1077   05EE 06            sysret  
1078   05EF             
1079   05EF             ; filename in D (userspace data)
1080   05EF             ; permission in BL
1081   05EF             fs_chmod:
1082   05EF DD            push bl
1083   05F0 FD 4E         mov si, d
1084   05F2 FD 4F D5 1B   mov di, user_data
1085   05F6 38 80 00      mov c, 128
1086   05F9 04            load                        ; load filename from user-space
1087   05FA 14 EA 16      mov a, [current_dirID]
1088   05FD 77            inc a                       ; metadata sector
1089   05FE 27            mov b, a
1090   05FF 38 00 00      mov c, 0                    ; reset LBA to 0
1091   0602 22 01         mov ah, $01                 ; disk read
1092   0604 3B D5 2F      mov d, transient_area
1093   0607 07 4E 04      call ide_read_sect          ; read directory
1094   060A FD 10         cla
1095   060C 42 E2 16      mov [index], a              ; reset file counter
1096   060F             fs_chmod_L1:
1097   060F FD 4E         mov si, d
1098   0611 FD 4F D5 1B   mov di, user_data
1099   0615 07 DD 0F      call _strcmp
1100   0618 C6 2F 06      je fs_chmod_found_entry
1101   061B 58 20 00      add d, 32
1102   061E 14 E2 16      mov a, [index]
1103   0621 77            inc a
1104   0622 42 E2 16      mov [index], a
1105   0625 AF 10 00      cmp a, FST_FILES_PER_DIR
1106   0628 C7 0F 06      jne fs_chmod_L1
1107   062B EA            pop bl
1108   062C 0A 48 06      jmp fs_chmod_not_found
1109   062F             fs_chmod_found_entry:  
1110   062F FD 79         mov g, b                    ; save LBA
1111   0631 EA            pop bl                      ; retrieve saved permission value
1112   0632 1F 18 00      mov al, [d + 24]            ; read file permissions
1113   0635 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1114   0637 8C            or al, bl                   ; set new permissions
1115   0638 3F 18 00      mov [d + 24], al            ; write new permissions
1116   063B 38 00 00      mov c, 0
1117   063E 3B D5 2F      mov d, transient_area
1118   0641 22 01         mov ah, $01                 ; disk write 1 sect
1119   0643 FD 27         mov b, g                    ; retrieve LBA
1120   0645 07 74 04      call ide_write_sect         ; write sector
1121   0648             fs_chmod_not_found:
1122   0648 06            sysret
1123   0649             
1124   0649             
1125   0649             ;------------------------------------------------------------------------------------------------------;
1126   0649             ; CREATE NEW DIRECTORY
1127   0649             ;------------------------------------------------------------------------------------------------------;
1128   0649             ; search list for NULL name entry. add new directory to list
1129   0649             fs_mkdir:
1130   0649 FD 4E         mov si, d
1131   064B FD 4F D5 1B   mov di, user_data
1132   064F 38 00 02      mov c, 512
1133   0652 04            load                        ; load data from user-space
1134   0653 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1135   0656                                           ; when checking for NULL name, since root has a NULL name)
1136   0656 38 00 00      mov c, 0                    ; reset LBA to 0
1137   0659             fs_mkdir_L1:  
1138   0659 22 01         mov ah, $01                 ; disk read
1139   065B 3B D5 2F      mov d, transient_area
1140   065E 07 4E 04      call ide_read_sect          ; read sector
1141   0661 BD 00         cmp byte[d], 0              ; check for NULL
1142   0663 C6 6C 06      je fs_mkdir_found_null
1143   0666 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1144   0669 0A 59 06      jmp fs_mkdir_L1
1145   066C             fs_mkdir_found_null:
1146   066C             ;create header file by grabbing dir name from parameter
1147   066C D8            push b                      ; save new directory's LBA
1148   066D 38 40 00      mov c, 64
1149   0670 FD 4D D5 1B   mov si, user_data
1150   0674 FD 4F D5 2F   mov di, transient_area
1151   0678 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1152   067A 14 EA 16      mov a, [current_dirID]
1153   067D 42 15 30      mov [transient_area + 64], a    ; store parent directory LBA
1154   0680 19 00         mov al, 0
1155   0682 FD 4F D5 31   mov di, transient_area + 512
1156   0686 38 00 02      mov c, 512
1157   0689 FD F7         rep stosb                       ; clean buffer
1158   068B 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1159   068E             ; write directory entry sectors
1160   068E 3B D5 2F      mov d, transient_area
1161   0691 22 02         mov ah, $02                     ; disk write, 2 sectors
1162   0693 07 74 04      call ide_write_sect             ; write sector
1163   0696             ; now we need to add the new directory to the list, insIDE the current directory
1164   0696 14 EA 16      mov a, [current_dirID]
1165   0699 53 01 00      add a, 1
1166   069C 27            mov b, a                        ; metadata sector
1167   069D 38 00 00      mov c, 0
1168   06A0 FD 79         mov g, b                        ; save LBA
1169   06A2 3B D5 2F      mov d, transient_area
1170   06A5 22 01         mov ah, $01                     ; disk read
1171   06A7 07 4E 04      call ide_read_sect              ; read metadata sector
1172   06AA             fs_mkdir_L2:
1173   06AA BD 00         cmp byte[d], 0
1174   06AC C6 B5 06      je fs_mkdir_found_null2
1175   06AF 58 20 00      add d, FST_ENTRY_SIZE
1176   06B2 0A AA 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1177   06B5             fs_mkdir_found_null2:
1178   06B5 FD 4D D5 1B   mov si, user_data
1179   06B9 FD 50         mov di, d
1180   06BB 07 F2 0F      call _strcpy                    ; copy directory name
1181   06BE 58 18 00      add d, 24                       ; goto ATTRIBUTES
1182   06C1 19 0B         mov al, %00001011               ; directory, no execute, write, read
1183   06C3 3E            mov [d], al      
1184   06C4 79            inc d
1185   06C5 E5            pop b
1186   06C6 D8            push b                          ; push LBA back
1187   06C7 FD 43         mov [d], b                      ; save LBA
1188   06C9             ; set file creation date  
1189   06C9 58 04 00      add d, 4
1190   06CC 19 04         mov al, 4
1191   06CE 05 01         syscall sys_rtc
1192   06D0 1A            mov al, ah
1193   06D1 3E            mov [d], al                     ; set day
1194   06D2 79            inc d
1195   06D3 19 05         mov al, 5
1196   06D5 05 01         syscall sys_rtc
1197   06D7 1A            mov al, ah
1198   06D8 3E            mov [d], al                     ; set month
1199   06D9 79            inc d
1200   06DA 19 06         mov al, 6
1201   06DC 05 01         syscall sys_rtc
1202   06DE 1A            mov al, ah
1203   06DF 3E            mov [d], al                     ; set year
1204   06E0             ; write sector into disk for new directory entry
1205   06E0 FD 27         mov b, g
1206   06E2 38 00 00      mov c, 0
1207   06E5 3B D5 2F      mov d, transient_area
1208   06E8 22 01         mov ah, $01                     ; disk write, 1 sector
1209   06EA 07 74 04      call ide_write_sect             ; write sector
1210   06ED             
1211   06ED             ; after adding the new directory's information to its parent directory's list
1212   06ED             ; we need to now enter the new directory, and to it add two new directories!
1213   06ED             ; which directories do we need to add ? '..' and '.' are the directories needed.
1214   06ED             ; importantly, note that these two new directories are only entries in the list
1215   06ED             ; and do not have actual physical entries in the disk as real directories.
1216   06ED             ; i.e. they only exist as list entries in the new directory created so that
1217   06ED             ; the new directory can reference its parent and itself.
1218   06ED             ; We need to add both '..' and '.'
1219   06ED             ; this first section is for '..' and on the section below we do the same for '.'
1220   06ED E4            pop a                         ; retrieve the new directory's LBA  
1221   06EE D7            push a                        ; and save again
1222   06EF 53 01 00      add a, 1
1223   06F2 27            mov b, a                      ; metadata sector
1224   06F3 38 00 00      mov c, 0
1225   06F6 FD 79         mov g, b                      ; save LBA
1226   06F8 3B D5 2F      mov d, transient_area
1227   06FB 22 01         mov ah, $01                   ; disk read
1228   06FD 07 4E 04      call ide_read_sect            ; read metadata sector
1229   0700             fs_mkdir_L3:
1230   0700 BD 00         cmp byte[d], 0
1231   0702 C6 0B 07      je fs_mkdir_found_null3
1232   0705 58 20 00      add d, FST_ENTRY_SIZE
1233   0708 0A 00 07      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1234   070B             fs_mkdir_found_null3:
1235   070B FD 4D F7 16   mov si, s_parent_dir
1236   070F FD 50         mov di, d
1237   0711 07 F2 0F      call _strcpy                  ; copy directory name
1238   0714 58 18 00      add d, 24                     ; goto ATTRIBUTES
1239   0717 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1240   0719 3E            mov [d], al      
1241   071A 79            inc d
1242   071B 29 EA 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1243   071E FD 43         mov [d], b                    ; save LBA
1244   0720             ; set file creation date  
1245   0720 58 04 00      add d, 4
1246   0723 19 04         mov al, 4
1247   0725 05 01         syscall sys_rtc
1248   0727 1A            mov al, ah
1249   0728 3E            mov [d], al                   ; set day
1250   0729 79            inc d
1251   072A 19 05         mov al, 5
1252   072C 05 01         syscall sys_rtc
1253   072E 1A            mov al, ah
1254   072F 3E            mov [d], al                   ; set month
1255   0730 79            inc d
1256   0731 19 06         mov al, 6
1257   0733 05 01         syscall sys_rtc
1258   0735 1A            mov al, ah
1259   0736 3E            mov [d], al                   ; set year
1260   0737             ; write sector into disk for new directory entry
1261   0737 FD 27         mov b, g
1262   0739 38 00 00      mov c, 0
1263   073C 3B D5 2F      mov d, transient_area
1264   073F 22 01         mov ah, $01                   ; disk write, 1 sector
1265   0741 07 74 04      call ide_write_sect           ; write sector
1266   0744             ;;;;;;;;;;;;;
1267   0744             ; like we did above for '..', we need to now add the '.' directory to the list.
1268   0744             ;------------------------------------------------------------------------------------------------------;
1269   0744 E4            pop a                         ; retrieve the new directory's LBA  
1270   0745 D7            push a
1271   0746 53 01 00      add a, 1
1272   0749 27            mov b, a                      ; metadata sector
1273   074A 38 00 00      mov c, 0
1274   074D FD 79         mov g, b                      ; save LBA
1275   074F 3B D5 2F      mov d, transient_area
1276   0752 22 01         mov ah, $01                   ; disk read
1277   0754 07 4E 04      call ide_read_sect            ; read metadata sector
1278   0757             fs_mkdir_L4:
1279   0757 BD 00         cmp byte[d], 0
1280   0759 C6 62 07      je fs_mkdir_found_null4
1281   075C 58 20 00      add d, FST_ENTRY_SIZE
1282   075F 0A 57 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1283   0762             fs_mkdir_found_null4:
