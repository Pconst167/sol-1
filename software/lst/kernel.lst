0868   04B2             ; IO Syscall
0869   04B2             ;----------------------------------------------------------------------------------------------------;
0870   04B2             ; Baud  Divisor
0871   04B2             ; 50    2304
0872   04B2             ; 110   1047
0873   04B2             ; 300    384
0874   04B2             ; 600    192
0875   04B2             ; 1200    96
0876   04B2             ; 9600    12
0877   04B2             ; 19200    6
0878   04B2             ; 38400    3
