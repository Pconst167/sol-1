0595   02E5             syscall_rtc_get:
0596   02E5 6A A9         add al, $A9             ; generate RTC address to get to address A9 of clock
0597   02E7 22 FF         mov ah, $FF    
0598   02E9 3C            mov d, a                ; get to FFA9 + offset
0599   02EA F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0600   02EE 1E            mov al, [d]             ; get data
0601   02EF F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
0602   02F3 23            mov ah, al
0603   02F4 E7            pop d
0604   02F5 E8            pop al
0605   02F6 06            sysret
0606   02F7             syscall_rtc_set:
