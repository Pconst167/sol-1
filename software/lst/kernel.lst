0583   02DE             ; RTC Services Syscall
0584   02DE             ; RTC I/O bank = FFA0 to FFAF
0585   02DE             ; FFA0 to FFA7 is scratch RAM
0586   02DE             ; Control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0587   02DE             ; al = 0..6 -> get
0588   02DE             ; al = 7..D -> set
0589   02DE             ; ------------------------------------------------------------------------------------------------------------------;
0590   02DE             syscall_rtc:
