0962   0569 22 3C         mov ah, '<'
0963   056B 07 B6 10      call _putchar
0964   056E 22 20         mov ah, ' '
0965   0570 07 B6 10      call _putchar
0966   0573 29 12 17      mov b, [fifo_out]
0967   0576 07 3A 12      call print_u16x
0968   0579 22 20         mov ah, ' '
0969   057B 07 B6 10      call _putchar
0970   057E 29 10 17      mov b, [fifo_in]
0971   0581 07 3A 12      call print_u16x
0972   0584 22 0A         mov ah, $0A
0973   0586 07 B6 10      call _putchar
0974   0589 10 FF 1D      mov a, fifo
0975   058C 42 10 17      mov [fifo_in], a
0976   058F 42 12 17      mov [fifo_out], a   ; reset fifo pointers
0977   0592 22 11         mov ah, XON
0978   0594 07 B6 10      call _putchar
0979   0597 0A 5D 05      jmp syscall_io_getch_cont
