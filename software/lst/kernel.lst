1005   057E             ;------------------------------------------------------------------------------------------------------;
1006   057E             ; FILE SYSTEM DATA
1007   057E             ;------------------------------------------------------------------------------------------------------;
1008   057E             ; infor for : IDE SERVICES INTERRUPT
1009   057E             ; IDE read/write 512-byte sector
1010   057E             ; al = option
1011   057E             ; user buffer pointer in D
1012   057E             ; AH = number of sectors
1013   057E             ; CB = LBA bytes 3..0  
1014   057E             ;------------------------------------------------------------------------------------------------------;
1015   057E             ; FILE SYSTEM DATA STRUCTURE
1016   057E             ;------------------------------------------------------------------------------------------------------;
1017   057E             ; for a directory we have the header first, followed by metadata
1018   057E             ; header 1 sector (512 bytes)
1019   057E             ; metadata 1 sector (512 bytes)
1020   057E             ; HEADER ENTRIES:
1021   057E             ; filename (64)
1022   057E             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1023   057E             ;
1024   057E             ; metadata entries:
1025   057E             ; filename (24)
1026   057E             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1027   057E             ; LBA (2)
1028   057E             ; size (2)
1029   057E             ; day (1)
1030   057E             ; month (1)
1031   057E             ; year (1)
1032   057E             ; packet size = 32 bytes
1033   057E             ;
1034   057E             ; first directory on disk is the root directory '/'
1035   057E             file_system_jmptbl:
1036   057E E9 05         .dw fs_mkfs                   ; 0
1037   0580 00 00         .dw 0                         ; 1
1038   0582 4B 06         .dw fs_mkdir                  ; 2
1039   0584 C4 09         .dw fs_cd                     ; 3
1040   0586 CC 09         .dw fs_ls                     ; 4
1041   0588 00 00         .dw 0                  ; 5
1042   058A 7E 0B         .dw fs_mkbin                  ; 6
1043   058C 45 0C         .dw fs_pwd                    ; 7
1044   058E 62 0C         .dw fs_cat                    ; 8
1045   0590 BE 0C         .dw fs_rmdir                  ; 9
1046   0592 1A 0D         .dw fs_rm                     ; 10
1047   0594 D9 0A         .dw fs_starcom                ; 11
1048   0596 00 00         .dw 0                         ; 12
1049   0598 00 00         .dw 0                         ; 13
1050   059A F1 05         .dw fs_chmod                  ; 14
1051   059C 82 0D         .dw fs_mv                     ; 15
1052   059E EA 05         .dw fs_cd_root                ; 16
1053   05A0 C0 09         .dw fs_get_curr_dirID         ; 17
1054   05A2 9C 07         .dw fs_dir_id_to_path         ; 18
1055   05A4 02 08         .dw fs_path_to_dir_id_user    ; 19
1056   05A6 1C 09         .dw fs_load_from_path_user    ; 20  
1057   05A8 8C 08         .dw fs_filepath_exists_user   ; 21
