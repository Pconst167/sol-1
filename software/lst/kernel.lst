1113   0630             ;------------------------------------------------------------------------------------------------------;
1114   0630             ; CREATE NEW DIRECTORY
1115   0630             ;------------------------------------------------------------------------------------------------------;
1116   0630             ; search list for NULL name entry. add new directory to list
1117   0630             fs_mkdir:
1118   0630 FD 4E         mov si, d
1119   0632 FD 4F 9F 1B   mov di, user_data
1120   0636 38 00 02      mov c, 512
1121   0639 04            load                        ; load data from user-space
1122   063A 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1123   063D                                           ; when checking for NULL name, since root has a NULL name)
1124   063D 38 00 00      mov c, 0                    ; reset LBA to 0
1125   0640             fs_mkdir_L1:  
1126   0640 22 01         mov ah, $01                 ; disk read
1127   0642 3B 9F 27      mov d, transient_area
1128   0645 07 38 04      call ide_read_sect          ; read sector
1129   0648 BD 00         cmp byte[d], 0              ; check for NULL
1130   064A C6 53 06      je fs_mkdir_found_null
1131   064D 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1132   0650 0A 40 06      jmp fs_mkdir_L1
1133   0653             fs_mkdir_found_null:
1134   0653             ;create header file by grabbing dir name from parameter
1135   0653 D8            push b                      ; save new directory's LBA
1136   0654 38 40 00      mov c, 64
1137   0657 FD 4D 9F 1B   mov si, user_data
1138   065B FD 4F 9F 27   mov di, transient_area
1139   065F FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1140   0661 14 B4 16      mov a, [current_dirID]
1141   0664 42 DF 27      mov [transient_area + 64], a    ; store parent directory LBA
1142   0667 19 00         mov al, 0
1143   0669 FD 4F 9F 29   mov di, transient_area + 512
1144   066D 38 00 02      mov c, 512
1145   0670 FD F7         rep stosb                       ; clean buffer
1146   0672 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1147   0675             ; write directory entry sectors
1148   0675 3B 9F 27      mov d, transient_area
1149   0678 22 02         mov ah, $02                     ; disk write, 2 sectors
1150   067A 07 5E 04      call ide_write_sect             ; write sector
1151   067D             ; now we need to add the new directory to the list, insIDE the current directory
1152   067D 14 B4 16      mov a, [current_dirID]
1153   0680 53 01 00      add a, 1
1154   0683 27            mov b, a                        ; metadata sector
1155   0684 38 00 00      mov c, 0
1156   0687 FD 79         mov g, b                        ; save LBA
1157   0689 3B 9F 27      mov d, transient_area
1158   068C 22 01         mov ah, $01                     ; disk read
1159   068E 07 38 04      call ide_read_sect              ; read metadata sector
1160   0691             fs_mkdir_L2:
1161   0691 BD 00         cmp byte[d], 0
1162   0693 C6 9C 06      je fs_mkdir_found_null2
1163   0696 58 20 00      add d, FST_ENTRY_SIZE
1164   0699 0A 91 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1165   069C             fs_mkdir_found_null2:
1166   069C FD 4D 9F 1B   mov si, user_data
1167   06A0 FD 50         mov di, d
1168   06A2 07 D2 0F      call _strcpy                    ; copy directory name
1169   06A5 58 18 00      add d, 24                       ; goto ATTRIBUTES
1170   06A8 19 0B         mov al, %00001011               ; directory, no execute, write, read
1171   06AA 3E            mov [d], al      
1172   06AB 79            inc d
1173   06AC E5            pop b
1174   06AD D8            push b                          ; push LBA back
1175   06AE FD 43         mov [d], b                      ; save LBA
1176   06B0             ; set file creation date  
1177   06B0 58 04 00      add d, 4
1178   06B3 19 04         mov al, 4
1179   06B5 05 01         syscall sys_rtc
1180   06B7 1A            mov al, ah
1181   06B8 3E            mov [d], al                     ; set day
1182   06B9 79            inc d
1183   06BA 19 05         mov al, 5
1184   06BC 05 01         syscall sys_rtc
1185   06BE 1A            mov al, ah
1186   06BF 3E            mov [d], al                     ; set month
1187   06C0 79            inc d
1188   06C1 19 06         mov al, 6
1189   06C3 05 01         syscall sys_rtc
1190   06C5 1A            mov al, ah
1191   06C6 3E            mov [d], al                     ; set year
1192   06C7             ; write sector into disk for new directory entry
1193   06C7 FD 27         mov b, g
1194   06C9 38 00 00      mov c, 0
1195   06CC 3B 9F 27      mov d, transient_area
1196   06CF 22 01         mov ah, $01                     ; disk write, 1 sector
1197   06D1 07 5E 04      call ide_write_sect             ; write sector
1198   06D4             
1199   06D4             ; after adding the new directory's information to its parent directory's list
1200   06D4             ; we need to now enter the new directory, and to it add two new directories!
1201   06D4             ; which directories do we need to add ? '..' and '.' are the directories needed.
1202   06D4             ; importantly, note that these two new directories are only entries in the list
1203   06D4             ; and do not have actual physical entries in the disk as real directories.
1204   06D4             ; i.e. they only exist as list entries in the new directory created so that
1205   06D4             ; the new directory can reference its parent and itself.
1206   06D4             ; We need to add both '..' and '.'
1207   06D4             ; this first section is for '..' and on the section below we do the same for '.'
1208   06D4 E4            pop a                         ; retrieve the new directory's LBA  
1209   06D5 D7            push a                        ; and save again
1210   06D6 53 01 00      add a, 1
1211   06D9 27            mov b, a                      ; metadata sector
1212   06DA 38 00 00      mov c, 0
1213   06DD FD 79         mov g, b                      ; save LBA
1214   06DF 3B 9F 27      mov d, transient_area
1215   06E2 22 01         mov ah, $01                   ; disk read
1216   06E4 07 38 04      call ide_read_sect            ; read metadata sector
1217   06E7             fs_mkdir_L3:
1218   06E7 BD 00         cmp byte[d], 0
1219   06E9 C6 F2 06      je fs_mkdir_found_null3
1220   06EC 58 20 00      add d, FST_ENTRY_SIZE
1221   06EF 0A E7 06      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1222   06F2             fs_mkdir_found_null3:
1223   06F2 FD 4D C1 16   mov si, s_parent_dir
1224   06F6 FD 50         mov di, d
1225   06F8 07 D2 0F      call _strcpy                  ; copy directory name
1226   06FB 58 18 00      add d, 24                     ; goto ATTRIBUTES
1227   06FE 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1228   0700 3E            mov [d], al      
1229   0701 79            inc d
1230   0702 29 B4 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1231   0705 FD 43         mov [d], b                    ; save LBA
1232   0707             ; set file creation date  
1233   0707 58 04 00      add d, 4
1234   070A 19 04         mov al, 4
1235   070C 05 01         syscall sys_rtc
1236   070E 1A            mov al, ah
1237   070F 3E            mov [d], al                   ; set day
1238   0710 79            inc d
1239   0711 19 05         mov al, 5
1240   0713 05 01         syscall sys_rtc
1241   0715 1A            mov al, ah
1242   0716 3E            mov [d], al                   ; set month
1243   0717 79            inc d
1244   0718 19 06         mov al, 6
1245   071A 05 01         syscall sys_rtc
1246   071C 1A            mov al, ah
1247   071D 3E            mov [d], al                   ; set year
1248   071E             ; write sector into disk for new directory entry
1249   071E FD 27         mov b, g
1250   0720 38 00 00      mov c, 0
1251   0723 3B 9F 27      mov d, transient_area
1252   0726 22 01         mov ah, $01                   ; disk write, 1 sector
1253   0728 07 5E 04      call ide_write_sect           ; write sector
1254   072B             ;;;;;;;;;;;;;
1255   072B             ; like we did above for '..', we need to now add the '.' directory to the list.
1256   072B             ;------------------------------------------------------------------------------------------------------;
1257   072B E4            pop a                         ; retrieve the new directory's LBA  
1258   072C D7            push a
1259   072D 53 01 00      add a, 1
1260   0730 27            mov b, a                      ; metadata sector
1261   0731 38 00 00      mov c, 0
1262   0734 FD 79         mov g, b                      ; save LBA
1263   0736 3B 9F 27      mov d, transient_area
1264   0739 22 01         mov ah, $01                   ; disk read
1265   073B 07 38 04      call ide_read_sect            ; read metadata sector
1266   073E             fs_mkdir_L4:
1267   073E BD 00         cmp byte[d], 0
1268   0740 C6 49 07      je fs_mkdir_found_null4
1269   0743 58 20 00      add d, FST_ENTRY_SIZE
1270   0746 0A 3E 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1271   0749             fs_mkdir_found_null4:
1272   0749 FD 4D C4 16   mov si, s_current_dir
1273   074D FD 50         mov di, d
1274   074F 07 D2 0F      call _strcpy                  ; copy directory name
1275   0752 58 18 00      add d, 24                     ; goto ATTRIBUTES
1276   0755 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1277   0757 3E            mov [d], al      
1278   0758 79            inc d
1279   0759 E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1280   075A FD 43         mov [d], b                    ; save LBA
1281   075C             ; set file creation date  
1282   075C 58 04 00      add d, 4
1283   075F 19 04         mov al, 4
1284   0761 05 01         syscall sys_rtc
1285   0763 1A            mov al, ah
1286   0764 3E            mov [d], al                   ; set day
1287   0765 79            inc d
1288   0766 19 05         mov al, 5
1289   0768 05 01         syscall sys_rtc
1290   076A 1A            mov al, ah
1291   076B 3E            mov [d], al                   ; set month
1292   076C 79            inc d
1293   076D 19 06         mov al, 6
1294   076F 05 01         syscall sys_rtc
1295   0771 1A            mov al, ah
1296   0772 3E            mov [d], al                   ; set year
1297   0773             ; write sector into disk for new directory entry
1298   0773 FD 27         mov b, g
1299   0775 38 00 00      mov c, 0
1300   0778 3B 9F 27      mov d, transient_area
1301   077B 22 01         mov ah, $01                   ; disk write, 1 sector
