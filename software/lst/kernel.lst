0920   04E9             syscall_io:
0921   04E9 FD 0A E3 04   jmp [syscall_io_jmp + al]
0922   04ED             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0923   04ED             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0924   04ED             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0925   04ED             syscall_io_uart_setup:
0926   04ED 1D C0 16      mov al, [sys_uart0_lcr]
0927   04F0 8B 80         or al, $80                ; set DLAB access bit
0928   04F2 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 2 stop, no parity by default
0929   04F5 1D C3 16      mov al, [sys_uart0_div0]
0930   04F8 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0931   04FB 1D C4 16      mov al, [sys_uart0_div1]
0932   04FE 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
0933   0501             
0934   0501 1D C0 16      mov al, [sys_uart0_lcr]
0935   0504 87 7F         and al, $7F               ; clear DLAB access bit 
0936   0506 3D 83 FF      mov [_UART0_LCR], al
0937   0509 1D C1 16      mov al, [sys_uart0_inten]
0938   050C 3D 81 FF      mov [_UART0_IER], al      ; interrupts
0939   050F 1D C2 16      mov al, [sys_uart0_fifoen]
0940   0512 3D 82 FF      mov [_UART0_FCR], al      ; FIFO control
