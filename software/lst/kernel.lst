0606   02FB             syscall_rtc_get:
0607   02FB 6A A9         add al, $A9             ; generate RTC address to get to address A9 of clock
0608   02FD 22 FF         mov ah, $FF    
0609   02FF 3C            mov d, a                ; get to FFA9 + offset
0610   0300 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0611   0304 1E            mov al, [d]             ; get data
0612   0305 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
0613   0309 23            mov ah, al
0614   030A E7            pop d
0615   030B E8            pop al
0616   030C 06            sysret
