0605   0AC0 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0606   0AC4 1E            mov al, [d]             ; get data
0607   0AC5 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
