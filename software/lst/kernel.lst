1077   05E6             
1078   05E6             ;------------------------------------------------------------------------------------------------------;
1079   05E6             ; CREATE NEW DIRECTORY
1080   05E6             ;------------------------------------------------------------------------------------------------------;
1081   05E6             ; search list for NULL name entry. add new directory to list
1082   05E6             fs_mkdir:
1083   05E6 FD 4E         mov si, d
1084   05E8 FD 4F 55 1B   mov di, user_data
1085   05EC 38 00 02      mov c, 512
1086   05EF 04            load                        ; load data from user-space
1087   05F0 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1088   05F3                                           ; when checking for NULL name, since root has a NULL name)
1089   05F3 38 00 00      mov c, 0                    ; reset LBA to 0
1090   05F6             fs_mkdir_L1:  
1091   05F6 22 01         mov ah, $01                 ; disk read
1092   05F8 3B 55 37      mov d, transient_area
1093   05FB 07 27 04      call ide_read_sect          ; read sector
1094   05FE BD 00         cmp byte[d], 0              ; check for NULL
1095   0600 C6 09 06      je fs_mkdir_found_null
1096   0603 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1097   0606 0A F6 05      jmp fs_mkdir_L1
1098   0609             fs_mkdir_found_null:
1099   0609             ;create header file by grabbing dir name from parameter
1100   0609 D8            push b                      ; save new directory's LBA
1101   060A 38 40 00      mov c, 64
1102   060D FD 4D 55 1B   mov si, user_data
1103   0611 FD 4F 55 37   mov di, transient_area
1104   0615 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1105   0617 14 6A 16      mov a, [current_dirID]
1106   061A 42 95 37      mov [transient_area + 64], a    ; store parent directory LBA
1107   061D 19 00         mov al, 0
1108   061F FD 4F 55 39   mov di, transient_area + 512
1109   0623 38 00 02      mov c, 512
1110   0626 FD F7         rep stosb                       ; clean buffer
1111   0628 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1112   062B             ; write directory entry sectors
1113   062B 3B 55 37      mov d, transient_area
1114   062E 22 02         mov ah, $02                     ; disk write, 2 sectors
1115   0630 07 4D 04      call ide_write_sect             ; write sector
1116   0633             ; now we need to add the new directory to the list, insIDE the current directory
1117   0633 14 6A 16      mov a, [current_dirID]
1118   0636 53 01 00      add a, 1
1119   0639 27            mov b, a                        ; metadata sector
1120   063A 38 00 00      mov c, 0
1121   063D FD 79         mov g, b                        ; save LBA
1122   063F 3B 55 37      mov d, transient_area
1123   0642 22 01         mov ah, $01                     ; disk read
1124   0644 07 27 04      call ide_read_sect              ; read metadata sector
1125   0647             fs_mkdir_L2:
1126   0647 BD 00         cmp byte[d], 0
1127   0649 C6 52 06      je fs_mkdir_found_null2
1128   064C 58 20 00      add d, FST_ENTRY_SIZE
1129   064F 0A 47 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1130   0652             fs_mkdir_found_null2:
1131   0652 FD 4D 55 1B   mov si, user_data
1132   0656 FD 50         mov di, d
1133   0658 07 88 0F      call _strcpy                    ; copy directory name
1134   065B 58 18 00      add d, 24                       ; goto ATTRIBUTES
1135   065E 19 0B         mov al, %00001011               ; directory, no execute, write, read
1136   0660 3E            mov [d], al      
1137   0661 79            inc d
1138   0662 E5            pop b
1139   0663 D8            push b                          ; push LBA back
1140   0664 FD 43         mov [d], b                      ; save LBA
1141   0666             ; set file creation date  
1142   0666 58 04 00      add d, 4
1143   0669 19 04         mov al, 4
1144   066B 05 01         syscall sys_rtc
1145   066D 1A            mov al, ah
1146   066E 3E            mov [d], al                     ; set day
1147   066F 79            inc d
1148   0670 19 05         mov al, 5
1149   0672 05 01         syscall sys_rtc
1150   0674 1A            mov al, ah
1151   0675 3E            mov [d], al                     ; set month
1152   0676 79            inc d
1153   0677 19 06         mov al, 6
1154   0679 05 01         syscall sys_rtc
1155   067B 1A            mov al, ah
1156   067C 3E            mov [d], al                     ; set year
1157   067D             ; write sector into disk for new directory entry
1158   067D FD 27         mov b, g
1159   067F 38 00 00      mov c, 0
1160   0682 3B 55 37      mov d, transient_area
1161   0685 22 01         mov ah, $01                     ; disk write, 1 sector
1162   0687 07 4D 04      call ide_write_sect             ; write sector
1163   068A             
1164   068A             ; after adding the new directory's information to its parent directory's list
1165   068A             ; we need to now enter the new directory, and to it add two new directories!
1166   068A             ; which directories do we need to add ? '..' and '.' are the directories needed.
1167   068A             ; importantly, note that these two new directories are only entries in the list
1168   068A             ; and do not have actual physical entries in the disk as real directories.
1169   068A             ; i.e. they only exist as list entries in the new directory created so that
1170   068A             ; the new directory can reference its parent and itself.
1171   068A             ; We need to add both '..' and '.'
1172   068A             ; this first section is for '..' and on the section below we do the same for '.'
1173   068A E4            pop a                         ; retrieve the new directory's LBA  
1174   068B D7            push a                        ; and save again
1175   068C 53 01 00      add a, 1
1176   068F 27            mov b, a                      ; metadata sector
1177   0690 38 00 00      mov c, 0
1178   0693 FD 79         mov g, b                      ; save LBA
1179   0695 3B 55 37      mov d, transient_area
1180   0698 22 01         mov ah, $01                   ; disk read
1181   069A 07 27 04      call ide_read_sect            ; read metadata sector
1182   069D             fs_mkdir_L3:
1183   069D BD 00         cmp byte[d], 0
1184   069F C6 A8 06      je fs_mkdir_found_null3
1185   06A2 58 20 00      add d, FST_ENTRY_SIZE
1186   06A5 0A 9D 06      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1187   06A8             fs_mkdir_found_null3:
1188   06A8 FD 4D 77 16   mov si, s_parent_dir
1189   06AC FD 50         mov di, d
1190   06AE 07 88 0F      call _strcpy                  ; copy directory name
1191   06B1 58 18 00      add d, 24                     ; goto ATTRIBUTES
1192   06B4 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1193   06B6 3E            mov [d], al      
1194   06B7 79            inc d
1195   06B8 29 6A 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1196   06BB FD 43         mov [d], b                    ; save LBA
1197   06BD             ; set file creation date  
1198   06BD 58 04 00      add d, 4
1199   06C0 19 04         mov al, 4
1200   06C2 05 01         syscall sys_rtc
1201   06C4 1A            mov al, ah
1202   06C5 3E            mov [d], al                   ; set day
1203   06C6 79            inc d
1204   06C7 19 05         mov al, 5
1205   06C9 05 01         syscall sys_rtc
1206   06CB 1A            mov al, ah
1207   06CC 3E            mov [d], al                   ; set month
1208   06CD 79            inc d
1209   06CE 19 06         mov al, 6
1210   06D0 05 01         syscall sys_rtc
1211   06D2 1A            mov al, ah
1212   06D3 3E            mov [d], al                   ; set year
1213   06D4             ; write sector into disk for new directory entry
1214   06D4 FD 27         mov b, g
1215   06D6 38 00 00      mov c, 0
1216   06D9 3B 55 37      mov d, transient_area
1217   06DC 22 01         mov ah, $01                   ; disk write, 1 sector
1218   06DE 07 4D 04      call ide_write_sect           ; write sector
1219   06E1             ;;;;;;;;;;;;;
1220   06E1             ; like we did above for '..', we need to now add the '.' directory to the list.
1221   06E1             ;------------------------------------------------------------------------------------------------------;
1222   06E1 E4            pop a                         ; retrieve the new directory's LBA  
1223   06E2 D7            push a
1224   06E3 53 01 00      add a, 1
1225   06E6 27            mov b, a                      ; metadata sector
1226   06E7 38 00 00      mov c, 0
1227   06EA FD 79         mov g, b                      ; save LBA
1228   06EC 3B 55 37      mov d, transient_area
1229   06EF 22 01         mov ah, $01                   ; disk read
1230   06F1 07 27 04      call ide_read_sect            ; read metadata sector
1231   06F4             fs_mkdir_L4:
1232   06F4 BD 00         cmp byte[d], 0
1233   06F6 C6 FF 06      je fs_mkdir_found_null4
1234   06F9 58 20 00      add d, FST_ENTRY_SIZE
1235   06FC 0A F4 06      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1236   06FF             fs_mkdir_found_null4:
1237   06FF FD 4D 7A 16   mov si, s_current_dir
1238   0703 FD 50         mov di, d
1239   0705 07 88 0F      call _strcpy                  ; copy directory name
1240   0708 58 18 00      add d, 24                     ; goto ATTRIBUTES
1241   070B 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1242   070D 3E            mov [d], al      
1243   070E 79            inc d
1244   070F E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1245   0710 FD 43         mov [d], b                    ; save LBA
1246   0712             ; set file creation date  
1247   0712 58 04 00      add d, 4
1248   0715 19 04         mov al, 4
1249   0717 05 01         syscall sys_rtc
1250   0719 1A            mov al, ah
1251   071A 3E            mov [d], al                   ; set day
1252   071B 79            inc d
1253   071C 19 05         mov al, 5
1254   071E 05 01         syscall sys_rtc
1255   0720 1A            mov al, ah
1256   0721 3E            mov [d], al                   ; set month
1257   0722 79            inc d
1258   0723 19 06         mov al, 6
1259   0725 05 01         syscall sys_rtc
1260   0727 1A            mov al, ah
1261   0728 3E            mov [d], al                   ; set year
1262   0729             ; write sector into disk for new directory entry
1263   0729 FD 27         mov b, g
1264   072B 38 00 00      mov c, 0
1265   072E 3B 55 37      mov d, transient_area
1266   0731 22 01         mov ah, $01                   ; disk write, 1 sector
1267   0733 07 4D 04      call ide_write_sect           ; write sector
1268   0736             fs_mkdir_end:
1269   0736 06            sysret
1270   0737             
1271   0737             ;------------------------------------------------------------------------------------------------------;
1272   0737             ; get path from a given directory dirID
1273   0737             ; pseudo code:
1274   0737             ;  fs_dir_id_to_path(int dirID, char *D){
1275   0737             ;    if(dirID == 0){
1276   0737             ;      reverse path in D;
1277   0737             ;      return;
1278   0737             ;    }
1279   0737             ;    else{
1280   0737             ;      copy directory name to end of D;
1281   0737             ;      add '/' to end of D;
1282   0737             ;      parentID = get parent directory ID;
1283   0737             ;      fs_dir_id_to_path(parentID, D);
1284   0737             ;    }
1285   0737             ;  }
1286   0737             ; A = dirID
1287   0737             ; D = generated path string pointer
1288   0737             ;------------------------------------------------------------------------------------------------------;
1289   0737             ; sample path: /usr/bin
1290   0737             fs_dir_id_to_path:
1291   0737 3B D5 1A      mov d, filename
1292   073A 19 00         mov al, 0
1293   073C 3E            mov [d], al                     ; initialize path string 
1294   073D 14 6A 16      mov a, [current_dirID]
1295   0740 07 4D 07      call fs_dir_id_to_path_E0
1296   0743 3B D5 1A      mov d, filename
1297   0746 07 1C 0F      call _strrev
1298   0749 07 30 11      call _puts
1299   074C 06            sysret
1300   074D             fs_dir_id_to_path_E0:
1301   074D 07 6C 07      call get_dirname_from_dirID
1302   0750 FD 4D 7C 16   mov si, s_fslash
1303   0754 FD 50         mov di, d
1304   0756 07 96 0F      call _strcat                    ; add '/' to end of path
1305   0759 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1306   075C C6 6B 07      je fs_dir_id_to_path_root
1307   075F 07 89 07      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1308   0762 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1309   0765 C6 6B 07      je fs_dir_id_to_path_root
1310   0768 07 4D 07      call fs_dir_id_to_path_E0     ; recursively call itself
1311   076B             fs_dir_id_to_path_root:
1312   076B 09            ret
1313   076C             
1314   076C             ;------------------------------------------------------------------------------------------------------;
1315   076C             ; in_puts:
1316   076C             ; A = directory ID
1317   076C             ; out_puts:
1318   076C             ; D = pointer to directory name string
1319   076C             ;------------------------------------------------------------------------------------------------------;
1320   076C             get_dirname_from_dirID:
1321   076C D7            push a
1322   076D D8            push b
1323   076E DA            push d
1324   076F 27            mov b, a
1325   0770 38 00 00      mov c, 0                      ; reset LBA to 0
1326   0773 22 01         mov ah, $01                   ; disk read
1327   0775 3B 55 35      mov d, transient_area - 512
1328   0778 07 27 04      call ide_read_sect            ; read directory
1329   077B 07 1C 0F      call _strrev                  ; reverse dir name before copying
1330   077E FD 4E         mov si, d
1331   0780 E7            pop d                         ; destination address = D value pushed at beginning
1332   0781 FD 50         mov di, d
1333   0783 07 96 0F      call _strcat                  ; copy filename to D
1334   0786 E5            pop b
1335   0787 E4            pop a
1336   0788 09            ret
1337   0789             
1338   0789             ;------------------------------------------------------------------------------------------------------;
1339   0789             ; in_puts:
1340   0789             ; A = directory ID
1341   0789             ; out_puts:
1342   0789             ; A = parent directory ID
1343   0789             ;------------------------------------------------------------------------------------------------------;
1344   0789             get_parentID_from_dirID:
1345   0789 D8            push b
1346   078A DA            push d
1347   078B 27            mov b, a
1348   078C 38 00 00      mov c, 0                      ; reset LBA to 0
1349   078F 22 01         mov ah, $01                   ; disk read
1350   0791 3B 55 35      mov d, transient_area - 512
1351   0794 07 27 04      call ide_read_sect            ; read directory
1352   0797 16 40 00      mov a, [d + 64]               ; copy parent ID value to A
1353   079A E7            pop d
1354   079B E5            pop b
1355   079C 09            ret
1356   079D             
1357   079D             ;------------------------------------------------------------------------------------------------------;
1358   079D             ; get dirID from a given path string
1359   079D             ; in_puts:
1360   079D             ; D = path pointer 
1361   079D             ; out_puts:
1362   079D             ; A = dirID
1363   079D             ; if dir non existent, A = FFFF (fail code)
1364   079D             ; /usr/local/bin    - absolute
1365   079D             ; local/bin/games    - relative
1366   079D             ;------------------------------------------------------------------------------------------------------;
1367   079D             fs_path_to_dir_id_user:
1368   079D FD 4E         mov si, d
1369   079F FD 4F 55 1B   mov di, user_data
1370   07A3 38 00 02      mov c, 512
1371   07A6 04            load
1372   07A7 07 AB 07      call get_dirID_from_path
1373   07AA 06            sysret
1374   07AB             get_dirID_from_path:
1375   07AB 26 55 1B      mov b, user_data
1376   07AE FD 42 55 15   mov [prog], b                  ; token pointer set to path string
1377   07B2 07 B6 13      call get_token
1378   07B5 31 58 15      mov bl, [tok]
1379   07B8 C1 01         cmp bl, TOK_FSLASH
1380   07BA C6 C6 07      je get_dirID_from_path_abs 
1381   07BD 14 6A 16      mov a, [current_dirID]
1382   07C0 07 3C 15      call _putback
1383   07C3 0A C9 07      jmp get_dirID_from_path_E0
1384   07C6             get_dirID_from_path_abs:
1385   07C6 10 20 00      mov a, root_id
1386   07C9             get_dirID_from_path_E0:
1387   07C9 07 B6 13      call get_token
1388   07CC 31 57 15      mov bl, [toktyp]
1389   07CF C1 00         cmp bl, TOKTYP_IDENTIFIER
1390   07D1 C7 22 08      jne get_dirID_from_path_end   ; check if there are tokens after '/'. i.e. is this a 'cd /' command?
1391   07D4             
1392   07D4 FD 4D 59 15   mov si, tokstr
1393   07D8 FD 4F D5 1A   mov di, filename
1394   07DC 07 88 0F      call _strcpy        
1395   07DF 77            inc a                         ; metadata sector
1396   07E0 27            mov b, a
1397   07E1 38 00 00      mov c, 0                      ; reset LBA to 0
1398   07E4 22 01         mov ah, $01                   ; disk read
