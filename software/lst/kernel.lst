0910   04F6 1D 85 FF      mov al, [_UART0_LSR]         ; read Line Status Register
0911   04F9 93 20         test al, $20                 ; isolate Transmitter Empty
0912   04FB C6 F6 04      jz syscall_io_putchar_L0    
0913   04FE 1A            mov al, ah
0914   04FF 3D 80 FF      mov [_UART0_DATA], al        ; write char to Transmitter Holding Register
0915   0502 06            sysret
