1022   05F0             ; FILE SYSTEM DATA STRUCTURE
1023   05F0             ;------------------------------------------------------------------------------------------------------;
1024   05F0             ; for a directory we have the header first, followed by metadata
1025   05F0             ; header 1 sector (512 bytes)
1026   05F0             ; metadata 1 sector (512 bytes)
1027   05F0             ; HEADER ENTRIES:
1028   05F0             ; filename (64)
1029   05F0             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1030   05F0             ;
1031   05F0             ; metadata entries:
1032   05F0             ; filename (24)
1033   05F0             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1034   05F0             ; LBA (2)
1035   05F0             ; size (2)
1036   05F0             ; day (1)
1037   05F0             ; month (1)
1038   05F0             ; year (1)
1039   05F0             ; packet size = 32 bytes
1040   05F0             ;
1041   05F0             ; first directory on disk is the root directory '/'
