0723   03CF             ; IDE Services Syscall
0724   03CF             ; al = option
0725   03CF             ; 0 = IDE reset, 1 = IDE sleep, 2 = read sector, 3 = write sector
0726   03CF             ; IDE read/write sector
0727   03CF             ; 512 bytes
0728   03CF             ; User buffer pointer in D
0729   03CF             ; AH = number of sectors
0730   03CF             ; CB = LBA bytes 3..0
0731   03CF             ; ------------------------------------------------------------------------------------------------------------------;
