0976   059A             ;------------------------------------------------------------------------------------------------------;
0977   059A             ; FILE SYSTEM DATA
0978   059A             ;------------------------------------------------------------------------------------------------------;
0979   059A             ; infor for : IDE SERVICES INTERRUPT
0980   059A             ; IDE read/write 512-byte sector
0981   059A             ; al = option
0982   059A             ; user buffer pointer in D
0983   059A             ; AH = number of sectors
0984   059A             ; CB = LBA bytes 3..0  
0985   059A             ;------------------------------------------------------------------------------------------------------;
0986   059A             ; FILE SYSTEM DATA STRUCTURE
0987   059A             ;------------------------------------------------------------------------------------------------------;
0988   059A             ; for a directory we have the header first, followed by metadata
0989   059A             ; header 1 sector (512 bytes)
0990   059A             ; metadata 1 sector (512 bytes)
0991   059A             ; HEADER ENTRIES:
0992   059A             ; filename (64)
0993   059A             ; parent dir LBA (2) -  to be used for faster backwards navigation...
0994   059A             ;
0995   059A             ; metadata entries:
0996   059A             ; filename (24)
0997   059A             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
0998   059A             ; LBA (2)
0999   059A             ; size (2)
1000   059A             ; day (1)
1001   059A             ; month (1)
1002   059A             ; year (1)
1003   059A             ; packet size = 32 bytes
1004   059A             ;
1005   059A             ; first directory on disk is the root directory '/'
1006   059A             file_system_jmptbl:
1007   059A 05 06         .dw fs_mkfs                   ; 0
1008   059C 00 00         .dw 0                         ; 1
1009   059E 67 06         .dw fs_mkdir                  ; 2
1010   05A0 E0 09         .dw fs_cd                     ; 3
1011   05A2 E8 09         .dw fs_ls                     ; 4
1012   05A4 00 00         .dw 0                  ; 5
1013   05A6 9A 0B         .dw fs_mkbin                  ; 6
1014   05A8 61 0C         .dw fs_pwd                    ; 7
1015   05AA 7E 0C         .dw fs_cat                    ; 8
1016   05AC DA 0C         .dw fs_rmdir                  ; 9
1017   05AE 36 0D         .dw fs_rm                     ; 10
1018   05B0 F5 0A         .dw fs_starcom                ; 11
1019   05B2 00 00         .dw 0                         ; 12
1020   05B4 00 00         .dw 0                         ; 13
1021   05B6 0D 06         .dw fs_chmod                  ; 14
1022   05B8 9E 0D         .dw fs_mv                     ; 15
1023   05BA 06 06         .dw fs_cd_root                ; 16
1024   05BC DC 09         .dw fs_get_curr_dirID         ; 17
1025   05BE B8 07         .dw fs_dir_id_to_path         ; 18
1026   05C0 1E 08         .dw fs_path_to_dir_id_user    ; 19
1027   05C2 38 09         .dw fs_load_from_path_user    ; 20  
1028   05C4 A8 08         .dw fs_filepath_exists_user   ; 21
