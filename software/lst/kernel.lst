0819   0473             ;----------------------------------------------------------------------------------------------------;
0820   0473             ide_read:
0821   0473 DA            push d
0822   0474             ide_read_loop:
0823   0474 1D D7 FF      mov al, [_ide_R7]  
0824   0477 93 80         test al, 80h                     ; BUSY FLAG
0825   0479 C7 74 04      jnz ide_read_loop               ; wait loop
