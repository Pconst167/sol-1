1038   0610 DD            push bl
1039   0611 31 03 17      mov bl, [sys_debug_mode]
1040   0614               ; debug block
1041   0614 C1 00         cmp bl, 0
1042   0616 EA            pop bl
1043   0617 C6 2B 06      je syscall_filesystem_jmp
1044   061A DA            push d
1045   061B DD            push bl
1046   061C 3B F0 05      mov d, s_syscall_fs_dbg0
1047   061F 07 E2 11      call _puts
1048   0622 2F            mov bl, al
1049   0623 07 7E 12      call print_u8x
1050   0626 07 8F 11      call printnl
