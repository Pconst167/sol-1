2677   18A3             proc_table_convert:
2678   18A3 CA 1A         .dw proc_state_table + 0
2679   18A5 DE 1A         .dw proc_state_table + 20
2680   18A7 F2 1A         .dw proc_state_table + 40
2681   18A9 06 1B         .dw proc_state_table + 60
2682   18AB 1A 1B         .dw proc_state_table + 80
2683   18AD 2E 1B         .dw proc_state_table + 100
2684   18AF 42 1B         .dw proc_state_table + 120
2685   18B1 56 1B         .dw proc_state_table + 140
