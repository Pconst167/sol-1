2589   17FE             syscall_spawn_proc:
2590   17FE             ; we save the active process first  
2591   17FE 4B            pusha
2592   17FF 22 00         mov ah, 0
2593   1801 1D EE 18      mov al, [active_proc_index]
2594   1804 FD 99         shl a              ; x2
2595   1806 B7 7B 18      mov a, [proc_table_convert + a]    ; get process state table's start index
2596   1809               
2597   1809 4F            mov di, a
2598   180A 48            mov a, sp
2599   180B 77            inc a
2600   180C 4D            mov si, a
2601   180D 38 14 00      mov c, 20
2602   1810 FD F5         rep movsb                          ; save process state!
2603   1812             ; restore kernel stack position to point before interrupt arrived
2604   1812 51 14 00      add sp, 20
2605   1815               
2606   1815 FD 4E         mov si, d                          ; copy the file path
2607   1817 FD 4F F2 1F   mov di, temp_data
2608   181B 38 00 02      mov c, 512
2609   181E 04            load
2610   181F 11            mov a, b
2611   1820 4D            mov si, a                          ; copy the arguments
2612   1821 FD 4F F2 41   mov di, scrap_sector
2613   1825 38 00 02      mov c, 512
2614   1828 04            load
2615   1829 07 04 11      call loadfile_from_path            ; load the process file from disk by path (path is in temp_data)
2616   182C                                                  ; the file data is loaded into transient_area
2617   182C             ; now we allocate a new process  
2618   182C 07 5D 17      call find_free_proc                ; index in A
2619   182F 01            setptb 
2620   1830 07 6F 17      call proc_memory_map               ; map process memory pages
2621   1833             ; copy arguments into process's memory
2622   1833 FD 4D F2 41   mov si, scrap_sector
2623   1837 FD 4F 00 00   mov di, 0
2624   183B 38 00 02      mov c, 512
2625   183E 03            store
2626   183F             ; now copy process binary data into process's memory
2627   183F FD 4D F2 43   mov si, transient_area
2628   1843 FD 4F 00 04   mov di, TEXT_ORG              ; code origin address for all user processes
2629   1847 38 00 40      mov c, FS_FILE_SIZE                ; size of memory space to copy, which is equal to the max file size in disk (for now)
2630   184A 03            store                              ; copy process data
2631   184B                 
2632   184B 07 5D 17      call find_free_proc                ; index in A
2633   184E 3D EE 18      mov [active_proc_index], al        ; set new active process
2634   1851 FD 9D 05      shl a, 5                           ; x32
2635   1854 53 F2 1B      add a, proc_names
2636   1857 4F            mov di, a
2637   1858 FD 4D F2 1F   mov si, temp_data                  ; copy and store process filename
2638   185C 07 A8 00      call _strcpy
2639   185F               
2640   185F 07 5D 17      call find_free_proc                ; index in A
2641   1862 3C            mov d, a
2642   1863 19 01         mov al, 1
2643   1865 3F E2 1B      mov [d + proc_availab_table], al   ; make process busy
2644   1868               
2645   1868 1D ED 18      mov al, [nbr_active_procs]         ; increase nbr of active processes
2646   186B 7A            inc al
2647   186C 3D ED 18      mov [nbr_active_procs], al
2648   186F             ; launch process
2649   186F FD D7 FF FF   push word $FFFF 
2650   1873 FD DB 0E      push byte %00001110                ; dma_ack = 0, interrupts enabled = 1, mode = user, paging = on, halt=0, display_reg_load=0, dir=0
2651   1876 FD D7 00 04   push word TEXT_ORG
2652   187A 06            sysret
2653   187B             
2654   187B             proc_table_convert:
2655   187B A2 1A         .dw proc_state_table + 0
2656   187D B6 1A         .dw proc_state_table + 20
2657   187F CA 1A         .dw proc_state_table + 40
2658   1881 DE 1A         .dw proc_state_table + 60
2659   1883 F2 1A         .dw proc_state_table + 80
2660   1885 06 1B         .dw proc_state_table + 100
2661   1887 1A 1B         .dw proc_state_table + 120
2662   1889 2E 1B         .dw proc_state_table + 140
2663   188B               
2664   188B             ; ************************************************************
2665   188B             ; GET HEX FILE
2666   188B             ; di = destination address
2667   188B             ; return length in bytes in C
2668   188B             ; ************************************************************
2669   188B             _load_hex:
2670   188B D2            push bp
2671   188C 9B            mov bp, sp
2672   188D D7            push a
2673   188E D8            push b
2674   188F DA            push d
2675   1890 E2            push si
2676   1891 E3            push di
2677   1892 52 00 80      sub sp, $8000      ; string data block
2678   1895 38 00 00      mov c, 0
2679   1898 48            mov a, sp
2680   1899 77            inc a
2681   189A 3C            mov d, a          ; start of string data block
2682   189B 07 32 01      call _gets        ; get program string
2683   189E 4D            mov si, a
2684   189F             __load_hex_loop:
2685   189F F6            lodsb             ; load from [SI] to AL
2686   18A0 B9 00         cmp al, 0         ; check if ASCII 0
2687   18A2 C6 B0 18      jz __load_hex_ret
2688   18A5 36            mov bh, al
2689   18A6 F6            lodsb
2690   18A7 2F            mov bl, al
2691   18A8 07 E1 00      call _atoi        ; convert ASCII byte in B to int (to AL)
2692   18AB F7            stosb             ; store AL to [DI]
2693   18AC 78            inc c
2694   18AD 0A 9F 18      jmp __load_hex_loop
2695   18B0             __load_hex_ret:
2696   18B0 51 00 80      add sp, $8000
2697   18B3 F0            pop di
2698   18B4 EF            pop si
2699   18B5 E7            pop d
2700   18B6 E5            pop b
2701   18B7 E4            pop a
2702   18B8 9C            mov sp, bp
2703   18B9 F1            pop bp
2704   18BA 09            ret
2705   18BB             
2706   18BB             ; ************************************************************
2707   18BB             ; GET HEX FILE WITHOUT ECHO
2708   18BB             ; di = destination address
2709   18BB             ; return length in bytes in C
2710   18BB             ; ************************************************************
2711   18BB             _load_hex_sil:
2712   18BB D2            push bp
2713   18BC 9B            mov bp, sp
2714   18BD D7            push a
2715   18BE D8            push b
2716   18BF DA            push d
2717   18C0 E2            push si
2718   18C1 E3            push di
2719   18C2 52 00 80      sub sp, $8000      ; string data block
2720   18C5 38 00 00      mov c, 0
2721   18C8 48            mov a, sp
2722   18C9 77            inc a
2723   18CA 3C            mov d, a          ; start of string data block
2724   18CB 07 D9 01      call _gets_sil        ; get program string silently
2725   18CE 4D            mov si, a
2726   18CF             __load_hex_sil_loop:
2727   18CF F6            lodsb             ; load from [SI] to AL
2728   18D0 B9 00         cmp al, 0         ; check if ASCII 0
2729   18D2 C6 E0 18      jz __load_hex_sil_ret
2730   18D5 36            mov bh, al
2731   18D6 F6            lodsb
2732   18D7 2F            mov bl, al
2733   18D8 07 E1 00      call _atoi        ; convert ASCII byte in B to int (to AL)
2734   18DB F7            stosb             ; store AL to [DI]
2735   18DC 78            inc c
2736   18DD 0A CF 18      jmp __load_hex_sil_loop
2737   18E0             __load_hex_sil_ret:
2738   18E0 51 00 80      add sp, $8000
2739   18E3 F0            pop di
2740   18E4 EF            pop si
2741   18E5 E7            pop d
2742   18E6 E5            pop b
2743   18E7 E4            pop a
2744   18E8 9C            mov sp, bp
2745   18E9 F1            pop bp
2746   18EA 09            ret
2747   18EB             
2748   18EB             ; synopsis: look insIDE a certain DIRECTORY for files/directories
2749   18EB             ; BEFORE CALLING THIS FUNCTION, CD INTO REQUIRED DIRECTORY
2750   18EB             ; for each entry insIDE DIRECTORY:
2751   18EB             ;  if entry is a file:
2752   18EB             ;    compare filename to searched filename
2753   18EB             ;    if filenames are the same, print filename
2754   18EB             ;  else if entry is a directory:
2755   18EB             ;    cd to the given directory
2756   18EB             ;    recursively call cmd_find
2757   18EB             ;    cd outsIDE previous directory
2758   18EB             ;  if current entry == last entry, return
2759   18EB             ; endfor
2760   18EB             f_find:
2761   18EB 09            ret
