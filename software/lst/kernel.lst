2688   18AC 1B 1B         .dw proc_state_table + 80
2689   18AE 2F 1B         .dw proc_state_table + 100
2690   18B0 43 1B         .dw proc_state_table + 120
2691   18B2 57 1B         .dw proc_state_table + 140
