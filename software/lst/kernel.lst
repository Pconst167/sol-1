1060   0630 10 20 00      mov a, root_id
1061   0633 42 14 17      mov [current_dirID], a      ; set current directory LBA to ROOT
1062   0636 06            sysret  
1063   0637             
1064   0637             ; filename in D (userspace data)
1065   0637             ; permission in BL
1066   0637             fs_chmod:
1067   0637 DD            push bl
1068   0638 FD 4E         mov si, d
1069   063A FD 4F FF 1B   mov di, user_data
1070   063E 38 80 00      mov c, 128
1071   0641 04            load                        ; load filename from user-space
1072   0642 14 14 17      mov a, [current_dirID]
1073   0645 77            inc a                       ; metadata sector
1074   0646 27            mov b, a
1075   0647 38 00 00      mov c, 0                    ; reset LBA to 0
1076   064A 22 01         mov ah, $01                 ; disk read
1077   064C 3B FF 23      mov d, transient_area
1078   064F 07 78 04      call ide_read_sect          ; read directory
1079   0652 FD 10         cla
1080   0654 42 0C 17      mov [index], a              ; reset file counter
1081   0657             fs_chmod_L1:
1082   0657 FD 4E         mov si, d
1083   0659 FD 4F FF 1B   mov di, user_data
1084   065D 07 25 10      call _strcmp
1085   0660 C6 77 06      je fs_chmod_found_entry
1086   0663 58 20 00      add d, 32
1087   0666 14 0C 17      mov a, [index]
1088   0669 77            inc a
1089   066A 42 0C 17      mov [index], a
1090   066D AF 10 00      cmp a, FST_FILES_PER_DIR
1091   0670 C7 57 06      jne fs_chmod_L1
1092   0673 EA            pop bl
1093   0674 0A 90 06      jmp fs_chmod_not_found
1094   0677             fs_chmod_found_entry:  
1095   0677 FD 79         mov g, b                    ; save LBA
1096   0679 EA            pop bl                      ; retrieve saved permission value
1097   067A 1F 18 00      mov al, [d + 24]            ; read file permissions
1098   067D 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1099   067F 8C            or al, bl                   ; set new permissions
1100   0680 3F 18 00      mov [d + 24], al            ; write new permissions
1101   0683 38 00 00      mov c, 0
1102   0686 3B FF 23      mov d, transient_area
1103   0689 22 01         mov ah, $01                 ; disk write 1 sect
1104   068B FD 27         mov b, g                    ; retrieve LBA
1105   068D 07 9E 04      call ide_write_sect         ; write sector
1106   0690             fs_chmod_not_found:
1107   0690 06            sysret
1108   0691             
1109   0691             
1110   0691             ;------------------------------------------------------------------------------------------------------;
1111   0691             ; CREATE NEW DIRECTORY
1112   0691             ;------------------------------------------------------------------------------------------------------;
1113   0691             ; search list for NULL name entry. add new directory to list
1114   0691             fs_mkdir:
1115   0691 FD 4E         mov si, d
1116   0693 FD 4F FF 1B   mov di, user_data
1117   0697 38 00 02      mov c, 512
1118   069A 04            load                        ; load data from user-space
1119   069B 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1120   069E                                           ; when checking for NULL name, since root has a NULL name)
1121   069E 38 00 00      mov c, 0                    ; reset LBA to 0
1122   06A1             fs_mkdir_L1:  
1123   06A1 22 01         mov ah, $01                 ; disk read
1124   06A3 3B FF 23      mov d, transient_area
1125   06A6 07 78 04      call ide_read_sect          ; read sector
1126   06A9 BD 00         cmp byte[d], 0              ; check for NULL
1127   06AB C6 B4 06      je fs_mkdir_found_null
1128   06AE 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1129   06B1 0A A1 06      jmp fs_mkdir_L1
1130   06B4             fs_mkdir_found_null:
1131   06B4             ;create header file by grabbing dir name from parameter
1132   06B4 D8            push b                      ; save new directory's LBA
1133   06B5 38 40 00      mov c, 64
1134   06B8 FD 4D FF 1B   mov si, user_data
1135   06BC FD 4F FF 23   mov di, transient_area
1136   06C0 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1137   06C2 14 14 17      mov a, [current_dirID]
1138   06C5 42 3F 24      mov [transient_area + 64], a    ; store parent directory LBA
1139   06C8 19 00         mov al, 0
1140   06CA FD 4F FF 25   mov di, transient_area + 512
1141   06CE 38 00 02      mov c, 512
1142   06D1 FD F7         rep stosb                       ; clean buffer
1143   06D3 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1144   06D6             ; write directory entry sectors
1145   06D6 3B FF 23      mov d, transient_area
1146   06D9 22 02         mov ah, $02                     ; disk write, 2 sectors
1147   06DB 07 9E 04      call ide_write_sect             ; write sector
1148   06DE             ; now we need to add the new directory to the list, insIDE the current directory
1149   06DE 14 14 17      mov a, [current_dirID]
1150   06E1 53 01 00      add a, 1
1151   06E4 27            mov b, a                        ; metadata sector
1152   06E5 38 00 00      mov c, 0
1153   06E8 FD 79         mov g, b                        ; save LBA
1154   06EA 3B FF 23      mov d, transient_area
1155   06ED 22 01         mov ah, $01                     ; disk read
1156   06EF 07 78 04      call ide_read_sect              ; read metadata sector
1157   06F2             fs_mkdir_L2:
1158   06F2 BD 00         cmp byte[d], 0
1159   06F4 C6 FD 06      je fs_mkdir_found_null2
1160   06F7 58 20 00      add d, FST_ENTRY_SIZE
1161   06FA 0A F2 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1162   06FD             fs_mkdir_found_null2:
1163   06FD FD 4D FF 1B   mov si, user_data
1164   0701 FD 50         mov di, d
1165   0703 07 3A 10      call _strcpy                    ; copy directory name
1166   0706 58 18 00      add d, 24                       ; goto ATTRIBUTES
1167   0709 19 0B         mov al, %00001011               ; directory, no execute, write, read
1168   070B 3E            mov [d], al      
1169   070C 79            inc d
1170   070D E5            pop b
1171   070E D8            push b                          ; push LBA back
1172   070F FD 43         mov [d], b                      ; save LBA
1173   0711             ; set file creation date  
1174   0711 58 04 00      add d, 4
1175   0714 19 04         mov al, 4
1176   0716 05 01         syscall sys_rtc
1177   0718 1A            mov al, ah
1178   0719 3E            mov [d], al                     ; set day
1179   071A 79            inc d
1180   071B 19 05         mov al, 5
1181   071D 05 01         syscall sys_rtc
1182   071F 1A            mov al, ah
1183   0720 3E            mov [d], al                     ; set month
1184   0721 79            inc d
1185   0722 19 06         mov al, 6
1186   0724 05 01         syscall sys_rtc
1187   0726 1A            mov al, ah
1188   0727 3E            mov [d], al                     ; set year
1189   0728             ; write sector into disk for new directory entry
1190   0728 FD 27         mov b, g
1191   072A 38 00 00      mov c, 0
1192   072D 3B FF 23      mov d, transient_area
1193   0730 22 01         mov ah, $01                     ; disk write, 1 sector
1194   0732 07 9E 04      call ide_write_sect             ; write sector
1195   0735             
1196   0735             ; after adding the new directory's information to its parent directory's list
1197   0735             ; we need to now enter the new directory, and to it add two new directories!
1198   0735             ; which directories do we need to add ? '..' and '.' are the directories needed.
1199   0735             ; importantly, note that these two new directories are only entries in the list
1200   0735             ; and do not have actual physical entries in the disk as real directories.
1201   0735             ; i.e. they only exist as list entries in the new directory created so that
1202   0735             ; the new directory can reference its parent and itself.
1203   0735             ; We need to add both '..' and '.'
1204   0735             ; this first section is for '..' and on the section below we do the same for '.'
1205   0735 E4            pop a                         ; retrieve the new directory's LBA  
1206   0736 D7            push a                        ; and save again
1207   0737 53 01 00      add a, 1
1208   073A 27            mov b, a                      ; metadata sector
1209   073B 38 00 00      mov c, 0
1210   073E FD 79         mov g, b                      ; save LBA
1211   0740 3B FF 23      mov d, transient_area
1212   0743 22 01         mov ah, $01                   ; disk read
1213   0745 07 78 04      call ide_read_sect            ; read metadata sector
1214   0748             fs_mkdir_L3:
1215   0748 BD 00         cmp byte[d], 0
1216   074A C6 53 07      je fs_mkdir_found_null3
1217   074D 58 20 00      add d, FST_ENTRY_SIZE
1218   0750 0A 48 07      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1219   0753             fs_mkdir_found_null3:
1220   0753 FD 4D 21 17   mov si, s_parent_dir
1221   0757 FD 50         mov di, d
1222   0759 07 3A 10      call _strcpy                  ; copy directory name
1223   075C 58 18 00      add d, 24                     ; goto ATTRIBUTES
1224   075F 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1225   0761 3E            mov [d], al      
1226   0762 79            inc d
1227   0763 29 14 17      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1228   0766 FD 43         mov [d], b                    ; save LBA
1229   0768             ; set file creation date  
1230   0768 58 04 00      add d, 4
1231   076B 19 04         mov al, 4
1232   076D 05 01         syscall sys_rtc
1233   076F 1A            mov al, ah
1234   0770 3E            mov [d], al                   ; set day
1235   0771 79            inc d
1236   0772 19 05         mov al, 5
1237   0774 05 01         syscall sys_rtc
1238   0776 1A            mov al, ah
1239   0777 3E            mov [d], al                   ; set month
1240   0778 79            inc d
1241   0779 19 06         mov al, 6
1242   077B 05 01         syscall sys_rtc
1243   077D 1A            mov al, ah
1244   077E 3E            mov [d], al                   ; set year
1245   077F             ; write sector into disk for new directory entry
1246   077F FD 27         mov b, g
1247   0781 38 00 00      mov c, 0
1248   0784 3B FF 23      mov d, transient_area
1249   0787 22 01         mov ah, $01                   ; disk write, 1 sector
1250   0789 07 9E 04      call ide_write_sect           ; write sector
1251   078C             ;;;;;;;;;;;;;
1252   078C             ; like we did above for '..', we need to now add the '.' directory to the list.
1253   078C             ;------------------------------------------------------------------------------------------------------;
1254   078C E4            pop a                         ; retrieve the new directory's LBA  
1255   078D D7            push a
1256   078E 53 01 00      add a, 1
1257   0791 27            mov b, a                      ; metadata sector
1258   0792 38 00 00      mov c, 0
1259   0795 FD 79         mov g, b                      ; save LBA
1260   0797 3B FF 23      mov d, transient_area
1261   079A 22 01         mov ah, $01                   ; disk read
1262   079C 07 78 04      call ide_read_sect            ; read metadata sector
1263   079F             fs_mkdir_L4:
1264   079F BD 00         cmp byte[d], 0
1265   07A1 C6 AA 07      je fs_mkdir_found_null4
1266   07A4 58 20 00      add d, FST_ENTRY_SIZE
1267   07A7 0A 9F 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1268   07AA             fs_mkdir_found_null4:
1269   07AA FD 4D 24 17   mov si, s_current_dir
1270   07AE FD 50         mov di, d
1271   07B0 07 3A 10      call _strcpy                  ; copy directory name
1272   07B3 58 18 00      add d, 24                     ; goto ATTRIBUTES
1273   07B6 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1274   07B8 3E            mov [d], al      
1275   07B9 79            inc d
1276   07BA E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1277   07BB FD 43         mov [d], b                    ; save LBA
1278   07BD             ; set file creation date  
1279   07BD 58 04 00      add d, 4
1280   07C0 19 04         mov al, 4
1281   07C2 05 01         syscall sys_rtc
1282   07C4 1A            mov al, ah
1283   07C5 3E            mov [d], al                   ; set day
1284   07C6 79            inc d
1285   07C7 19 05         mov al, 5
1286   07C9 05 01         syscall sys_rtc
1287   07CB 1A            mov al, ah
1288   07CC 3E            mov [d], al                   ; set month
1289   07CD 79            inc d
1290   07CE 19 06         mov al, 6
1291   07D0 05 01         syscall sys_rtc
1292   07D2 1A            mov al, ah
1293   07D3 3E            mov [d], al                   ; set year
1294   07D4             ; write sector into disk for new directory entry
1295   07D4 FD 27         mov b, g
1296   07D6 38 00 00      mov c, 0
1297   07D9 3B FF 23      mov d, transient_area
1298   07DC 22 01         mov ah, $01                   ; disk write, 1 sector
1299   07DE 07 9E 04      call ide_write_sect           ; write sector
1300   07E1             fs_mkdir_end:
1301   07E1 06            sysret
1302   07E2             
1303   07E2             ;------------------------------------------------------------------------------------------------------;
1304   07E2             ; get path from a given directory dirID
1305   07E2             ; pseudo code:
1306   07E2             ;  fs_dir_id_to_path(int dirID, char *D){
1307   07E2             ;    if(dirID == 0){
1308   07E2             ;      reverse path in D;
1309   07E2             ;      return;
1310   07E2             ;    }
1311   07E2             ;    else{
1312   07E2             ;      copy directory name to end of D;
1313   07E2             ;      add '/' to end of D;
1314   07E2             ;      parentID = get parent directory ID;
1315   07E2             ;      fs_dir_id_to_path(parentID, D);
1316   07E2             ;    }
1317   07E2             ;  }
1318   07E2             ; A = dirID
1319   07E2             ; D = generated path string pointer
1320   07E2             ;------------------------------------------------------------------------------------------------------;
1321   07E2             ; sample path: /usr/bin
1322   07E2             fs_dir_id_to_path:
1323   07E2 3B 7F 1B      mov d, filename
1324   07E5 19 00         mov al, 0
1325   07E7 3E            mov [d], al                     ; initialize path string 
1326   07E8 14 14 17      mov a, [current_dirID]
1327   07EB 07 F8 07      call fs_dir_id_to_path_E0
1328   07EE 3B 7F 1B      mov d, filename
1329   07F1 07 CE 0F      call _strrev
1330   07F4 07 E2 11      call _puts
1331   07F7 06            sysret
1332   07F8             fs_dir_id_to_path_E0:
1333   07F8 07 17 08      call get_dirname_from_dirID
1334   07FB FD 4D 26 17   mov si, s_fslash
1335   07FF FD 50         mov di, d
1336   0801 07 48 10      call _strcat                    ; add '/' to end of path
1337   0804 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1338   0807 C6 16 08      je fs_dir_id_to_path_root
1339   080A 07 34 08      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1340   080D AF 20 00      cmp a, root_id               ; check if we are at the root directory
1341   0810 C6 16 08      je fs_dir_id_to_path_root
1342   0813 07 F8 07      call fs_dir_id_to_path_E0     ; recursively call itself
1343   0816             fs_dir_id_to_path_root:
1344   0816 09            ret
1345   0817             
1346   0817             ;------------------------------------------------------------------------------------------------------;
1347   0817             ; in_puts:
1348   0817             ; A = directory ID
1349   0817             ; out_puts:
1350   0817             ; D = pointer to directory name string
1351   0817             ;------------------------------------------------------------------------------------------------------;
1352   0817             get_dirname_from_dirID:
1353   0817 D7            push a
1354   0818 D8            push b
1355   0819 DA            push d
1356   081A 27            mov b, a
1357   081B 38 00 00      mov c, 0                      ; reset LBA to 0
1358   081E 22 01         mov ah, $01                   ; disk read
1359   0820 3B FF 21      mov d, transient_area - 512
1360   0823 07 78 04      call ide_read_sect            ; read directory
1361   0826 07 CE 0F      call _strrev                  ; reverse dir name before copying
1362   0829 FD 4E         mov si, d
1363   082B E7            pop d                         ; destination address = D value pushed at beginning
1364   082C FD 50         mov di, d
1365   082E 07 48 10      call _strcat                  ; copy filename to D
1366   0831 E5            pop b
1367   0832 E4            pop a
1368   0833 09            ret
1369   0834             
1370   0834             ;------------------------------------------------------------------------------------------------------;
1371   0834             ; in_puts:
1372   0834             ; A = directory ID
1373   0834             ; out_puts:
1374   0834             ; A = parent directory ID
1375   0834             ;------------------------------------------------------------------------------------------------------;
1376   0834             get_parentID_from_dirID:
1377   0834 D8            push b
1378   0835 DA            push d
1379   0836 27            mov b, a
1380   0837 38 00 00      mov c, 0                      ; reset LBA to 0
1381   083A 22 01         mov ah, $01                   ; disk read
1382   083C 3B FF 21      mov d, transient_area - 512
1383   083F 07 78 04      call ide_read_sect            ; read directory
