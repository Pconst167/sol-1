1132   064B             
1133   064B             ;------------------------------------------------------------------------------------------------------;
1134   064B             ; CREATE NEW DIRECTORY
1135   064B             ;------------------------------------------------------------------------------------------------------;
1136   064B             ; search list for NULL name entry. add new directory to list
1137   064B             fs_mkdir:
1138   064B FD 4E         mov si, d
1139   064D FD 4F BA 1B   mov di, user_data
1140   0651 38 00 02      mov c, 512
1141   0654 04            load                        ; load data from user-space
1142   0655 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1143   0658                                           ; when checking for NULL name, since root has a NULL name)
1144   0658 38 00 00      mov c, 0                    ; reset LBA to 0
1145   065B             fs_mkdir_L1:  
1146   065B 22 01         mov ah, $01                 ; disk read
1147   065D 3B BA 27      mov d, transient_area
1148   0660 07 58 04      call ide_read_sect          ; read sector
1149   0663 BD 00         cmp byte[d], 0              ; check for NULL
1150   0665 C6 6E 06      je fs_mkdir_found_null
1151   0668 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1152   066B 0A 5B 06      jmp fs_mkdir_L1
1153   066E             fs_mkdir_found_null:
1154   066E             ;create header file by grabbing dir name from parameter
1155   066E D8            push b                      ; save new directory's LBA
1156   066F 38 40 00      mov c, 64
1157   0672 FD 4D BA 1B   mov si, user_data
1158   0676 FD 4F BA 27   mov di, transient_area
1159   067A FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1160   067C 14 CF 16      mov a, [current_dirID]
1161   067F 42 FA 27      mov [transient_area + 64], a    ; store parent directory LBA
1162   0682 19 00         mov al, 0
1163   0684 FD 4F BA 29   mov di, transient_area + 512
1164   0688 38 00 02      mov c, 512
1165   068B FD F7         rep stosb                       ; clean buffer
1166   068D 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1167   0690             ; write directory entry sectors
1168   0690 3B BA 27      mov d, transient_area
1169   0693 22 02         mov ah, $02                     ; disk write, 2 sectors
1170   0695 07 7E 04      call ide_write_sect             ; write sector
1171   0698             ; now we need to add the new directory to the list, insIDE the current directory
1172   0698 14 CF 16      mov a, [current_dirID]
1173   069B 53 01 00      add a, 1
1174   069E 27            mov b, a                        ; metadata sector
1175   069F 38 00 00      mov c, 0
1176   06A2 FD 79         mov g, b                        ; save LBA
1177   06A4 3B BA 27      mov d, transient_area
1178   06A7 22 01         mov ah, $01                     ; disk read
1179   06A9 07 58 04      call ide_read_sect              ; read metadata sector
1180   06AC             fs_mkdir_L2:
1181   06AC BD 00         cmp byte[d], 0
