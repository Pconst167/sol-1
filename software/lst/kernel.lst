0582   0A98 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0583   0A9C 1E            mov al, [d]             ; get data
0584   0A9D F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
