0592   02CA             ; RTC Services Syscall
0593   02CA             ; RTC I/O bank = FFA0 to FFAF
0594   02CA             ; FFA0 to FFA7 is scratch RAM
0595   02CA             ; Control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0596   02CA             ; al = 0..6 -> get
0597   02CA             ; al = 7..D -> set
0598   02CA             ; ------------------------------------------------------------------------------------------------------------------;
0599   02CA             syscall_rtc:
0600   02CA DB            push al
0601   02CB DA            push d
0602   02CC B9 06         cmp al, 6
0603   02CE D1 E3 02      jgu syscall_rtc_set
0604   02D1             syscall_rtc_get:
0605   02D1 6A A9         add al, $A9             ; generate RTC address to get to address A9 of clock
0606   02D3 22 FF         mov ah, $FF    
0607   02D5 3C            mov d, a                ; get to FFA9 + offset
0608   02D6 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0609   02DA 1E            mov al, [d]             ; get data
0610   02DB F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
0611   02DF 23            mov ah, al
0612   02E0 E7            pop d
0613   02E1 E8            pop al
0614   02E2 06            sysret
0615   02E3             syscall_rtc_set:
0616   02E3 DD            push bl
0617   02E4 99            mov bl, ah              ; set data asIDE
0618   02E5 6A A2         add al, $A2             ; generate RTC address to get to address A9 of clock
0619   02E7 22 FF         mov ah, $FF    
0620   02E9 3C            mov d, a                ; get to FFA9 + offset
0621   02EA 1B            mov al, bl              ; get data back
0622   02EB F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0623   02EF 3E            mov [d], al             ; set data
0624   02F0 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0625   02F4 EA            pop bl
0626   02F5 E7            pop d
0627   02F6 E8            pop al
0628   02F7 06            sysret
