1078   05F2             ;------------------------------------------------------------------------------------------------------;
1079   05F2             ; CREATE NEW DIRECTORY
1080   05F2             ;------------------------------------------------------------------------------------------------------;
1081   05F2             ; search list for NULL name entry. add new directory to list
1082   05F2             fs_mkdir:
1083   05F2 FD 4E         mov si, d
1084   05F4 FD 4F 61 1B   mov di, user_data
1085   05F8 38 00 02      mov c, 512
1086   05FB 04            load                        ; load data from user-space
1087   05FC 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1088   05FF                                           ; when checking for NULL name, since root has a NULL name)
1089   05FF 38 00 00      mov c, 0                    ; reset LBA to 0
1090   0602             fs_mkdir_L1:  
1091   0602 22 01         mov ah, $01                 ; disk read
1092   0604 3B 61 3F      mov d, transient_area
1093   0607 07 27 04      call ide_read_sect          ; read sector
1094   060A BD 00         cmp byte[d], 0              ; check for NULL
1095   060C C6 15 06      je fs_mkdir_found_null
1096   060F 55 02 00      add b, FST_SECTORS_PER_DIR  ; skip directory
1097   0612 0A 02 06      jmp fs_mkdir_L1
1098   0615             fs_mkdir_found_null:
1099   0615             ;create header file by grabbing dir name from parameter
1100   0615 D8            push b                      ; save new directory's LBA
1101   0616 38 40 00      mov c, 64
1102   0619 FD 4D 61 1B   mov si, user_data
1103   061D FD 4F 61 3F   mov di, transient_area
1104   0621 FD F5         rep movsb                   ; copy dirname from user_data to transient_area
1105   0623 14 76 16      mov a, [current_dirID]
1106   0626 42 A1 3F      mov [transient_area + 64], a    ; store parent directory LBA
1107   0629 19 00         mov al, 0
1108   062B FD 4F 61 41   mov di, transient_area + 512
1109   062F 38 00 02      mov c, 512
1110   0632 FD F7         rep stosb                       ; clean buffer
1111   0634 38 00 00      mov c, 0                        ; reset LBA(c) to 0
1112   0637             ; write directory entry sectors
1113   0637 3B 61 3F      mov d, transient_area
1114   063A 22 02         mov ah, $02                     ; disk write, 2 sectors
1115   063C 07 4D 04      call ide_write_sect             ; write sector
1116   063F             ; now we need to add the new directory to the list, insIDE the current directory
1117   063F 14 76 16      mov a, [current_dirID]
1118   0642 53 01 00      add a, 1
1119   0645 27            mov b, a                        ; metadata sector
1120   0646 38 00 00      mov c, 0
1121   0649 FD 79         mov g, b                        ; save LBA
1122   064B 3B 61 3F      mov d, transient_area
1123   064E 22 01         mov ah, $01                     ; disk read
1124   0650 07 27 04      call ide_read_sect              ; read metadata sector
1125   0653             fs_mkdir_L2:
1126   0653 BD 00         cmp byte[d], 0
1127   0655 C6 5E 06      je fs_mkdir_found_null2
1128   0658 58 20 00      add d, FST_ENTRY_SIZE
1129   065B 0A 53 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1130   065E             fs_mkdir_found_null2:
1131   065E FD 4D 61 1B   mov si, user_data
1132   0662 FD 50         mov di, d
1133   0664 07 94 0F      call _strcpy                    ; copy directory name
1134   0667 58 18 00      add d, 24                       ; goto ATTRIBUTES
1135   066A 19 0B         mov al, %00001011               ; directory, no execute, write, read
1136   066C 3E            mov [d], al      
1137   066D 79            inc d
1138   066E E5            pop b
1139   066F D8            push b                          ; push LBA back
1140   0670 FD 43         mov [d], b                      ; save LBA
1141   0672             ; set file creation date  
1142   0672 58 04 00      add d, 4
1143   0675 19 04         mov al, 4
1144   0677 05 01         syscall sys_rtc
1145   0679 1A            mov al, ah
1146   067A 3E            mov [d], al                     ; set day
1147   067B 79            inc d
1148   067C 19 05         mov al, 5
1149   067E 05 01         syscall sys_rtc
1150   0680 1A            mov al, ah
1151   0681 3E            mov [d], al                     ; set month
1152   0682 79            inc d
1153   0683 19 06         mov al, 6
1154   0685 05 01         syscall sys_rtc
1155   0687 1A            mov al, ah
1156   0688 3E            mov [d], al                     ; set year
1157   0689             ; write sector into disk for new directory entry
1158   0689 FD 27         mov b, g
1159   068B 38 00 00      mov c, 0
1160   068E 3B 61 3F      mov d, transient_area
1161   0691 22 01         mov ah, $01                     ; disk write, 1 sector
1162   0693 07 4D 04      call ide_write_sect             ; write sector
1163   0696             
1164   0696             ; after adding the new directory's information to its parent directory's list
1165   0696             ; we need to now enter the new directory, and to it add two new directories!
1166   0696             ; which directories do we need to add ? '..' and '.' are the directories needed.
1167   0696             ; importantly, note that these two new directories are only entries in the list
1168   0696             ; and do not have actual physical entries in the disk as real directories.
1169   0696             ; i.e. they only exist as list entries in the new directory created so that
1170   0696             ; the new directory can reference its parent and itself.
1171   0696             ; We need to add both '..' and '.'
1172   0696             ; this first section is for '..' and on the section below we do the same for '.'
1173   0696 E4            pop a                         ; retrieve the new directory's LBA  
1174   0697 D7            push a                        ; and save again
1175   0698 53 01 00      add a, 1
1176   069B 27            mov b, a                      ; metadata sector
1177   069C 38 00 00      mov c, 0
1178   069F FD 79         mov g, b                      ; save LBA
1179   06A1 3B 61 3F      mov d, transient_area
1180   06A4 22 01         mov ah, $01                   ; disk read
1181   06A6 07 27 04      call ide_read_sect            ; read metadata sector
1182   06A9             fs_mkdir_L3:
1183   06A9 BD 00         cmp byte[d], 0
1184   06AB C6 B4 06      je fs_mkdir_found_null3
1185   06AE 58 20 00      add d, FST_ENTRY_SIZE
1186   06B1 0A A9 06      jmp fs_mkdir_L3              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1187   06B4             fs_mkdir_found_null3:
1188   06B4 FD 4D 83 16   mov si, s_parent_dir
1189   06B8 FD 50         mov di, d
1190   06BA 07 94 0F      call _strcpy                  ; copy directory name
1191   06BD 58 18 00      add d, 24                     ; goto ATTRIBUTES
1192   06C0 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1193   06C2 3E            mov [d], al      
1194   06C3 79            inc d
1195   06C4 29 76 16      mov b, [current_dirID]        ; retrieve the parent directorys LBA
1196   06C7 FD 43         mov [d], b                    ; save LBA
1197   06C9             ; set file creation date  
1198   06C9 58 04 00      add d, 4
1199   06CC 19 04         mov al, 4
1200   06CE 05 01         syscall sys_rtc
1201   06D0 1A            mov al, ah
1202   06D1 3E            mov [d], al                   ; set day
1203   06D2 79            inc d
1204   06D3 19 05         mov al, 5
1205   06D5 05 01         syscall sys_rtc
1206   06D7 1A            mov al, ah
1207   06D8 3E            mov [d], al                   ; set month
1208   06D9 79            inc d
1209   06DA 19 06         mov al, 6
1210   06DC 05 01         syscall sys_rtc
1211   06DE 1A            mov al, ah
1212   06DF 3E            mov [d], al                   ; set year
1213   06E0             ; write sector into disk for new directory entry
1214   06E0 FD 27         mov b, g
1215   06E2 38 00 00      mov c, 0
1216   06E5 3B 61 3F      mov d, transient_area
1217   06E8 22 01         mov ah, $01                   ; disk write, 1 sector
1218   06EA 07 4D 04      call ide_write_sect           ; write sector
1219   06ED             ;;;;;;;;;;;;;
1220   06ED             ; like we did above for '..', we need to now add the '.' directory to the list.
1221   06ED             ;------------------------------------------------------------------------------------------------------;
1222   06ED E4            pop a                         ; retrieve the new directory's LBA  
1223   06EE D7            push a
1224   06EF 53 01 00      add a, 1
1225   06F2 27            mov b, a                      ; metadata sector
1226   06F3 38 00 00      mov c, 0
1227   06F6 FD 79         mov g, b                      ; save LBA
1228   06F8 3B 61 3F      mov d, transient_area
1229   06FB 22 01         mov ah, $01                   ; disk read
1230   06FD 07 27 04      call ide_read_sect            ; read metadata sector
1231   0700             fs_mkdir_L4:
