0590   0AB4             ; RTC I/O bank = FFA0 to FFAF
0591   0AB4             ; FFA0 to FFA7 is scratch RAM
0592   0AB4             ; control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0593   0AB4             ; al = 0..6 -> get
0594   0AB4             ; al = 7..D -> set
