0566   0A8C             ; RTC SERVICES INTERRUPT
0567   0A8C             ; RTC I/O bank = FFA0 to FFAF
0568   0A8C             ; FFA0 to FFA7 is scratch RAM
0569   0A8C             ; control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0570   0A8C             ; al = 0..6 -> get
0571   0A8C             ; al = 7..D -> set
