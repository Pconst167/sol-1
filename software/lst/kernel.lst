1318   079A             ;------------------------------------------------------------------------------------------------------;
1319   079A             ; get path from a given directory dirID
1320   079A             ; pseudo code:
1321   079A             ;  fs_dir_id_to_path(int dirID, char *D){
1322   079A             ;    if(dirID == 0){
1323   079A             ;      reverse path in D;
1324   079A             ;      return;
1325   079A             ;    }
1326   079A             ;    else{
1327   079A             ;      copy directory name to end of D;
1328   079A             ;      add '/' to end of D;
1329   079A             ;      parentID = get parent directory ID;
1330   079A             ;      fs_dir_id_to_path(parentID, D);
1331   079A             ;    }
1332   079A             ;  }
1333   079A             ; A = dirID
1334   079A             ; D = generated path string pointer
1335   079A             ;------------------------------------------------------------------------------------------------------;
1336   079A             ; sample path: /usr/bin
1337   079A             fs_dir_id_to_path:
1338   079A 3B 55 1B      mov d, filename
1339   079D 19 00         mov al, 0
1340   079F 3E            mov [d], al                     ; initialize path string 
1341   07A0 14 EA 16      mov a, [current_dirID]
1342   07A3 07 B0 07      call fs_dir_id_to_path_E0
1343   07A6 3B 55 1B      mov d, filename
1344   07A9 07 86 0F      call _strrev
1345   07AC 07 B8 11      call _puts
1346   07AF 06            sysret
1347   07B0             fs_dir_id_to_path_E0:
1348   07B0 07 CF 07      call get_dirname_from_dirID
1349   07B3 FD 4D FC 16   mov si, s_fslash
1350   07B7 FD 50         mov di, d
1351   07B9 07 00 10      call _strcat                    ; add '/' to end of path
1352   07BC AF 20 00      cmp a, root_id               ; check if we are at the root directory
1353   07BF C6 CE 07      je fs_dir_id_to_path_root
1354   07C2 07 EC 07      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1355   07C5 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1356   07C8 C6 CE 07      je fs_dir_id_to_path_root
1357   07CB 07 B0 07      call fs_dir_id_to_path_E0     ; recursively call itself
1358   07CE             fs_dir_id_to_path_root:
1359   07CE 09            ret
1360   07CF             
1361   07CF             ;------------------------------------------------------------------------------------------------------;
1362   07CF             ; in_puts:
1363   07CF             ; A = directory ID
1364   07CF             ; out_puts:
1365   07CF             ; D = pointer to directory name string
1366   07CF             ;------------------------------------------------------------------------------------------------------;
1367   07CF             get_dirname_from_dirID:
1368   07CF D7            push a
1369   07D0 D8            push b
1370   07D1 DA            push d
1371   07D2 27            mov b, a
1372   07D3 38 00 00      mov c, 0                      ; reset LBA to 0
1373   07D6 22 01         mov ah, $01                   ; disk read
1374   07D8 3B D5 2D      mov d, transient_area - 512
1375   07DB 07 4E 04      call ide_read_sect            ; read directory
1376   07DE 07 86 0F      call _strrev                  ; reverse dir name before copying
1377   07E1 FD 4E         mov si, d
1378   07E3 E7            pop d                         ; destination address = D value pushed at beginning
1379   07E4 FD 50         mov di, d
1380   07E6 07 00 10      call _strcat                  ; copy filename to D
1381   07E9 E5            pop b
1382   07EA E4            pop a
1383   07EB 09            ret
1384   07EC             
1385   07EC             ;------------------------------------------------------------------------------------------------------;
1386   07EC             ; in_puts:
1387   07EC             ; A = directory ID
1388   07EC             ; out_puts:
1389   07EC             ; A = parent directory ID
1390   07EC             ;------------------------------------------------------------------------------------------------------;
