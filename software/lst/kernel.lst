1013   05F0             ; FILE SYSTEM DATA
1014   05F0             ;------------------------------------------------------------------------------------------------------;
1015   05F0             ; infor for : IDE SERVICES INTERRUPT
1016   05F0             ; IDE read/write 512-byte sector
1017   05F0             ; al = option
1018   05F0             ; user buffer pointer in D
1019   05F0             ; AH = number of sectors
1020   05F0             ; CB = LBA bytes 3..0  
