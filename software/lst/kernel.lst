0624   0AD4 1B            mov al, bl              ; get data back
0625   0AD5 F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0626   0AD9 3E            mov [d], al             ; set data
0627   0ADA F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0628   0ADE EA            pop bl
0629   0ADF E7            pop d
0630   0AE0 E8            pop al
0631   0AE1 06            sysret
