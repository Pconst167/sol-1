0001   0000             ; ------------------------------------------------------------------------------------------------------------------;
0002   0000             ; Solarium - Sol-1 Homebrew Minicomputer Operating System Kernel.
0003   0000             ; ------------------------------------------------------------------------------------------------------------------;
0004   0000             ; Memory Map
0005   0000             ; ------------------------------------------------------------------------------------------------------------------;
0006   0000             ; 0000    ROM BEGIN
0007   0000             ; ....
0008   0000             ; 7FFF    ROM END
0009   0000             ;
0010   0000             ; 8000    RAM begin
0011   0000             ; ....
0012   0000             ; F7FF    Stack root
0013   0000             ; ------------------------------------------------------------------------------------------------------------------;
0014   0000             ; I/O MAP
0015   0000             ; ------------------------------------------------------------------------------------------------------------------;
0016   0000             ; FF80    UART 0    (16550)
0017   0000             ; FF90    UART 1    (16550)
0018   0000             ; FFA0    RTC       (M48T02)
0019   0000             ; FFB0    PIO 0     (8255)
0020   0000             ; FFC0    PIO 1     (8255)
0021   0000             ; FFD0    IDE       (Compact Flash / PATA)
0022   0000             ; FFE0    Timer     (8253)
0023   0000             ; FFF0    BIOS CONFIGURATION NV-RAM STORE AREA
0024   0000             ; ------------------------------------------------------------------------------------------------------------------;
0025   0000             
0026   0000             ; ------------------------------------------------------------------------------------------------------------------;
0027   0000             ; System Constants
0028   0000             ; ------------------------------------------------------------------------------------------------------------------;
0029   0000             _UART0_DATA       .equ $FF80            ; data
0030   0000             _UART0_DLAB_0     .equ $FF80            ; divisor latch low byte
0031   0000             _UART0_DLAB_1     .equ $FF81            ; divisor latch high byte
0032   0000             _UART0_IER        .equ $FF81            ; Interrupt enable register
0033   0000             _UART0_FCR        .equ $FF82            ; FIFO control register
0034   0000             _UART0_LCR        .equ $FF83            ; line control register
0035   0000             _UART0_LSR        .equ $FF85            ; line status register
0036   0000             
0037   0000             _UART1_DATA       .equ $FF90            ; data
0038   0000             _UART1_DLAB_0     .equ $FF90            ; divisor latch low byte
0039   0000             _UART1_DLAB_1     .equ $FF91            ; divisor latch high byte
0040   0000             _UART1_IER        .equ $FF91            ; Interrupt enable register
0041   0000             _UART1_FCR        .equ $FF92            ; FIFO control register
0042   0000             _UART1_LCR        .equ $FF93            ; line control register
0043   0000             _UART1_LSR        .equ $FF95            ; line status register
0044   0000             
0045   0000             XON               .equ $11
0046   0000             XOFF              .equ $13
0047   0000             
0048   0000             _ide_BASE         .equ $FFD0            ; IDE BASE
0049   0000             _ide_R0           .equ _ide_BASE + 0    ; DATA PORT
0050   0000             _ide_R1           .equ _ide_BASE + 1    ; READ: ERROR CODE, WRITE: FEATURE
0051   0000             _ide_R2           .equ _ide_BASE + 2    ; NUMBER OF SECTORS TO TRANSFER
0052   0000             _ide_R3           .equ _ide_BASE + 3    ; SECTOR ADDRESS LBA 0 [0:7]
0053   0000             _ide_R4           .equ _ide_BASE + 4    ; SECTOR ADDRESS LBA 1 [8:15]
0054   0000             _ide_R5           .equ _ide_BASE + 5    ; SECTOR ADDRESS LBA 2 [16:23]
0055   0000             _ide_R6           .equ _ide_BASE + 6    ; SECTOR ADDRESS LBA 3 [24:27 (LSB)]
0056   0000             _ide_R7           .equ _ide_BASE + 7    ; READ: STATUS, WRITE: COMMAND
0057   0000             
0058   0000             _7SEG_DISPLAY     .equ $FFB0            ; BIOS POST CODE HEX DISPLAY (2 DIGITS)
0059   0000             _BIOS_POST_CTRL   .equ $FFB3            ; BIOS POST DISPLAY CONTROL REGISTER, 80h = As Output
0060   0000             _PIO_A            .equ $FFB0    
0061   0000             _PIO_B            .equ $FFB1
0062   0000             _PIO_C            .equ $FFB2
0063   0000             _PIO_CONTROL      .equ $FFB3            ; PIO CONTROL PORT
0064   0000             
0065   0000             _TIMER_C_0        .equ $FFE0            ; TIMER COUNTER 0
0066   0000             _TIMER_C_1        .equ $FFE1            ; TIMER COUNTER 1
0067   0000             _TIMER_C_2        .equ $FFE2            ; TIMER COUNTER 2
0068   0000             _TIMER_CTRL       .equ $FFE3            ; TIMER CONTROL REGISTER
0069   0000             
0070   0000             STACK_BEGIN       .equ $F7FF            ; beginning of stack
0071   0000             FIFO_SIZE         .equ 1024
0072   0000             
0073   0000             TEXT_ORG          .equ $400
0074   0000             ; ------------------------------------------------------------------------------------------------------------------;
0075   0000             
0076   0000             
0077   0000             ; For the next iteration:
0078   0000             ; boot-sector(1) | kernel-sectors(32) | inode-bitmap | rawdata-bitmap | inode-table | raw-disk-data
0079   0000             ; inode-table format:
0080   0000             ;  file-type(f, d)
0081   0000             ;  permissons
0082   0000             ;  link-count
0083   0000             ;  filesize
0084   0000             ;  time-stamps
0085   0000             ;  15 data block pointers
0086   0000             ;  single-indirect pointer
0087   0000             
0088   0000             ; FILE ENTRY ATTRIBUTES
0089   0000             ; filename (24)
0090   0000             ; attributes (1)       :|0|0|file_type(3bits)|x|w|r|
0091   0000             ; LBA (2)              : location of raw data for file entry, or dirID for directory entry
0092   0000             ; size (2)             : filesize
0093   0000             ; day (1)           
0094   0000             ; month (1)
0095   0000             ; year (1)
0096   0000             ; packet size = 32 bytes  : total packet size in bytes
0097   0000             
0098   0000             FST_ENTRY_SIZE          .equ 32  ; bytes
0099   0000             FST_FILES_PER_SECT      .equ (512 / FST_ENTRY_SIZE)
0100   0000             FST_FILES_PER_DIR       .equ (512 / FST_ENTRY_SIZE)
0101   0000             FST_NBR_DIRECTORIES     .equ 64
0102   0000                                     ; 1 sector for header, the rest is for the list of files/dirs
0103   0000             FST_SECTORS_PER_DIR     .equ (1 + (FST_ENTRY_SIZE * FST_FILES_PER_DIR / 512))    
0104   0000             FST_TOTAL_SECTORS       .equ (FST_SECTORS_PER_DIR * FST_NBR_DIRECTORIES)
0105   0000             FST_LBA_START           .equ 32
0106   0000             FST_LBA_END             .equ (FST_LBA_START + FST_TOTAL_SECTORS - 1)
0107   0000             
0108   0000             FS_NBR_FILES            .equ (FST_NBR_DIRECTORIES * FST_FILES_PER_DIR)
0109   0000             FS_SECTORS_PER_FILE     .equ 32         ; the first sector is always a header with a NULL parameter (first byte)
0110   0000                                                     ; so that we know which blocks are free or taken
0111   0000             FS_FILE_SIZE            .equ (FS_SECTORS_PER_FILE * 512)                  
0112   0000             FS_TOTAL_SECTORS        .equ (FS_NBR_FILES * FS_SECTORS_PER_FILE)
0113   0000             FS_LBA_START            .equ (FST_LBA_END + 1)
0114   0000             FS_LBA_END              .equ (FS_LBA_START + FS_NBR_FILES - 1)
0115   0000             
0116   0000             root_id:                .equ FST_LBA_START
0117   0000             
0118   0000             ; ------------------------------------------------------------------------------------------------------------------;
0119   0000             ; GLOBAL SYSTEM VARIABLES
0120   0000             ; ------------------------------------------------------------------------------------------------------------------;
0121   0000             
0122   0000             ; ------------------------------------------------------------------------------------------------------------------;
0123   0000             ; IRQ Table
0124   0000             ; Highest priority at lowest address
0125   0000             ; ------------------------------------------------------------------------------------------------------------------;
0126   0000 3A 00       .dw int_0
0127   0002 3B 00       .dw int_1
0128   0004 3C 00       .dw int_2
0129   0006 3D 00       .dw int_3
0130   0008 3E 00       .dw int_4
0131   000A 3F 00       .dw int_5
0132   000C 40 00       .dw int_6
0133   000E 8C 00       .dw int_7
0134   0010             
0135   0010             ; ------------------------------------------------------------------------------------------------------------------;
0136   0010             ; Reset Vector
0137   0010             ; ------------------------------------------------------------------------------------------------------------------;
0138   0010 0F 0E       .dw kernel_reset_vector
0139   0012             
0140   0012             ; ------------------------------------------------------------------------------------------------------------------;
0141   0012             ; Exception Vector Table
0142   0012             ; Total of 7 entries, starting at address $0012
0143   0012             ; ------------------------------------------------------------------------------------------------------------------;
0144   0012 9F 01       .dw trap_privilege
0145   0014 BC 02       .dw trap_div_zero
0146   0016 C9 02       .dw trap_undef_opcode
0147   0018 00 00       .dw 0
0148   001A 00 00       .dw 0
0149   001C 00 00       .dw 0
0150   001E 00 00       .dw 0
0151   0020             
0152   0020             ; ------------------------------------------------------------------------------------------------------------------;
0153   0020             ; System Call Vector Table
0154   0020             ; Starts at address $0020
0155   0020             ; ------------------------------------------------------------------------------------------------------------------;
0156   0020 AB 01       .dw syscall_break
0157   0022 CA 02       .dw syscall_rtc
0158   0024 04 04       .dw syscall_ide
0159   0026 DF 04       .dw syscall_io
0160   0028 E6 05       .dw syscall_file_system
0161   002A E6 0E       .dw syscall_spawn_proc
0162   002C 64 01       .dw syscall_list_procs
0163   002E FC 02       .dw syscall_datetime
0164   0030 20 01       .dw syscall_reboot
0165   0032 B0 0E       .dw syscall_pause_proc
0166   0034 2C 01       .dw syscall_resume_proc
0167   0036 6D 0E       .dw syscall_terminate_proc
0168   0038 F4 00       .dw syscall_system
0169   003A             
0170   003A             ; ------------------------------------------------------------------------------------------------------------------;
0171   003A             ; System Call Aliases
0172   003A             ; ------------------------------------------------------------------------------------------------------------------;
0173   003A             sys_break            .equ 0
0174   003A             sys_rtc              .equ 1
0175   003A             sys_ide              .equ 2
0176   003A             sys_io               .equ 3
0177   003A             sys_filesystem       .equ 4
0178   003A             sys_spawn_proc       .equ 5
0179   003A             sys_list             .equ 6
0180   003A             sys_datetime         .equ 7
0181   003A             sys_reboot           .equ 8
0182   003A             sys_pause_proc       .equ 9
0183   003A             sys_resume_proc      .equ 10
0184   003A             sys_terminate_proc   .equ 11
0185   003A             sys_system           .equ 12
0186   003A             
0187   003A             ; ------------------------------------------------------------------------------------------------------------------;
0188   003A             ; Alias Exports
0189   003A             ; ------------------------------------------------------------------------------------------------------------------;
0190   003A             .export TEXT_ORG
0191   003A             .export sys_break
0192   003A             .export sys_ide
0193   003A             .export sys_io
0194   003A             .export sys_filesystem
0195   003A             .export sys_spawn_proc
0196   003A             .export sys_list
0197   003A             .export sys_rtc
0198   003A             .export sys_datetime
0199   003A             .export sys_reboot
0200   003A             .export sys_pause_proc
0201   003A             .export sys_resume_proc
0202   003A             .export sys_terminate_proc
0203   003A             .export sys_system
0204   003A             
0205   003A             ; ------------------------------------------------------------------------------------------------------------------;
0206   003A             ; IRQs' Code Block
0207   003A             ; ------------------------------------------------------------------------------------------------------------------;
0208   003A             int_0:
0209   003A 06            sysret
0210   003B             int_1:
0211   003B 06            sysret
0212   003C             int_2:
0213   003C 06            sysret
0214   003D             int_3:
0215   003D 06            sysret
0216   003E             int_4:
0217   003E 06            sysret
0218   003F             int_5:
0219   003F 06            sysret
0220   0040             
0221   0040             ; ------------------------------------------------------------------------------------------------------------------;
0222   0040             ; Process Swapping
0223   0040             ; ------------------------------------------------------------------------------------------------------------------;
0224   0040             int_6:  
0225   0040 4B            pusha ; save all registers into kernel stack
0226   0041 22 00         mov ah, 0
0227   0043 1D E9 16      mov al, [active_proc_index]
0228   0046 FD 99         shl a              ; x2
0229   0048 B7 63 0F      mov a, [proc_table_convert + a]  ; get process state start index
0230   004B 4F            mov di, a
0231   004C 48            mov a, sp
0232   004D 77            inc a
0233   004E 4D            mov si, a
0234   004F 38 14 00      mov c, 20
0235   0052 FD F5         rep movsb          ; save process state!
0236   0054             ; restore kernel stack position to point before interrupt arrived
0237   0054 51 14 00      add sp, 20
0238   0057             ; now load next process in queue
0239   0057 1D E9 16      mov al, [active_proc_index]
0240   005A 31 E8 16      mov bl, [nbr_active_procs]
0241   005D BA            cmp al, bl
0242   005E C6 65 00      je int6_cycle_back
0243   0061 7A            inc al            ; next process is next in the series
0244   0062 0A 67 00      jmp int6_continue
0245   0065             int6_cycle_back:
0246   0065 19 01         mov al, 1        ; next process = process 1
0247   0067             int6_continue:
0248   0067 3D E9 16      mov [active_proc_index], al    ; set next active proc
0249   006A             
0250   006A             ; calculate LUT entry for next process
0251   006A 22 00         mov ah, 0
0252   006C FD 99         shl a              ; x2
0253   006E B7 63 0F      mov a, [proc_table_convert + a]    ; get process state start index  
0254   0071               
0255   0071 4D            mov si, a            ; source is proc state block
0256   0072 48            mov a, sp
0257   0073 5F 13 00      sub a, 19
0258   0076 4F            mov di, a            ; destination is kernel stack
0259   0077             ; restore SP
0260   0077 7D            dec a
0261   0078 47            mov sp, a
0262   0079 38 14 00      mov c, 20
0263   007C FD F5         rep movsb
0264   007E             ; set VM process
0265   007E 1D E9 16      mov al, [active_proc_index]
0266   0081 01            setptb
0267   0082 F2 E0 FF 00   mov byte[_TIMER_C_0], 0        ; load counter 0 low byte
0268   0086 F2 E0 FF 10   mov byte[_TIMER_C_0], $10        ; load counter 0 high byte
0269   008A 4C            popa
0270   008B 06            sysret
0271   008C             
0272   008C             ; ------------------------------------------------------------------------------------------------------------------;
0273   008C             ; UART0 Interrupt
0274   008C             ; ------------------------------------------------------------------------------------------------------------------;
0275   008C             int_7:
0276   008C D7            push a
0277   008D D8            push b
0278   008E DA            push d
0279   008F E1            pushf
0280   0090 14 EE 16      mov a, [fifo_in]
0281   0093 3C            mov d, a
0282   0094 31 80 FF      mov bl, [_UART0_DATA]  ; get character
0283   0097 C1 03         cmp bl, $03        ; CTRL-C
0284   0099 C6 DF 00      je CTRLC
0285   009C C1 1A         cmp bl, $1A        ; CTRL-Z
0286   009E C6 E5 00      je CTRLZ
0287   00A1 FD 3E         mov [d], bl        ; add to fifo
0288   00A3 77            inc a
0289   00A4 42 EE 16      mov [fifo_in], a
0290   00A7 AF DD 21      cmp a, fifo + FIFO_SIZE
0291   00AA C6 B2 00      je int_7_xoff
0292   00AD             int_7_continue1:  
0293   00AD EE            popf
0294   00AE E7            pop d
0295   00AF E5            pop b
0296   00B0 E4            pop a  
0297   00B1 06            sysret
0298   00B2             
0299   00B2             int_7_xoff:    
0300   00B2 22 13         mov ah, XOFF  
0301   00B4 07 8C 10      call _putchar
0302   00B7 22 0A         mov ah, $0A
0303   00B9 07 8C 10      call _putchar
0304   00BC 22 3E         mov ah, '>'
0305   00BE 07 8C 10      call _putchar
0306   00C1 22 20         mov ah, ' '
0307   00C3 07 8C 10      call _putchar
0308   00C6 29 F0 16      mov b, [fifo_out]
0309   00C9 07 14 12      call print_u16x
0310   00CC 22 20         mov ah, ' '
0311   00CE 07 8C 10      call _putchar
0312   00D1 29 EE 16      mov b, [fifo_in]
0313   00D4 07 14 12      call print_u16x
0314   00D7 22 0A         mov ah, $0A
0315   00D9 07 8C 10      call _putchar
0316   00DC 0A AD 00      jmp int_7_continue1
0317   00DF             
0318   00DF             CTRLC:
0319   00DF 51 05 00      add sp, 5
0320   00E2 0A 6D 0E      jmp syscall_terminate_proc
0321   00E5             CTRLZ:
0322   00E5 EE            popf
0323   00E6 E7            pop d
0324   00E7 E5            pop b
0325   00E8 E4            pop a
0326   00E9 0A B0 0E      jmp syscall_pause_proc    ; pause current process and go back to the shell
0327   00EC             
0328   00EC             ; ------------------------------------------------------------------------------------------------------------------;
0329   00EC             ; System Syscalls
0330   00EC             ; ------------------------------------------------------------------------------------------------------------------;
0331   00EC             system_jmptbl:
0332   00EC 1E 01         .dw system_uname
0333   00EE 1F 01         .dw system_whoami
0334   00F0 1B 01         .dw system_setparam
0335   00F2 F8 00         .dw system_bootloader_install
0336   00F4             syscall_system:
0337   00F4 FD 0A EC 00   jmp [system_jmptbl + al]
0338   00F8             
0339   00F8             ; kernel LBA address in 'b'
0340   00F8             system_bootloader_install:
0341   00F8 D8            push b
0342   00F9 26 00 00      mov b, 0
0343   00FC 38 00 00      mov c, 0
0344   00FF 22 01         mov ah, $01                 ; 1 sector
0345   0101 3B DD 23      mov d, transient_area
0346   0104 07 4E 04      call ide_read_sect          ; read sector
0347   0107 E5            pop b
0348   0108 FD 44 FE 01   mov [d + 510], b            ; update LBA address
0349   010C 26 00 00      mov b, 0
0350   010F 38 00 00      mov c, 0
0351   0112 22 01         mov ah, $01                 ; 1 sector
0352   0114 3B DD 23      mov d, transient_area
0353   0117 07 74 04      call ide_write_sect         ; write sector
0354   011A 06            sysret
0355   011B             
0356   011B             ; param register address in register d
0357   011B             ; param value in register bl
0358   011B             system_setparam:
0359   011B FD 3E         mov [d], bl
0360   011D 06            sysret
0361   011E             
0362   011E             system_uname:
0363   011E 06            sysret
0364   011F             
0365   011F             system_whoami:
0366   011F 06            sysret
0367   0120             
0368   0120             ; REBOOT SYSTEM
0369   0120             syscall_reboot:
0370   0120 FD D7 FF FF   push word $FFFF 
0371   0124 FD DB 00      push byte %00000000             ; dma_ack = 0, interrupts disabled, mode = supervisor, paging = off, halt=0, display_reg_load=0, dir=0
0372   0127 FD D7 C0 01   push word BIOS_RESET_VECTOR    ; and then push RESET VECTOR of the shell to the stack
0373   012B 06            sysret
0374   012C             
0375   012C             ;------------------------------------------------------------------------------------------------------;;
0376   012C             ; switch to another process
0377   012C             ; inputs:
0378   012C             ; AL = new process number
0379   012C             ;------------------------------------------------------------------------------------------------------;;
0380   012C             syscall_resume_proc:
0381   012C FD 78         mov g, a                            ; save the process number
0382   012E 4B            pusha                               ; save all registers into kernel stack
0383   012F 22 00         mov ah, 0
0384   0131 1D E9 16      mov al, [active_proc_index]
0385   0134 FD 99         shl a              ; x2
0386   0136 B7 63 0F      mov a, [proc_table_convert + a]     ; get process state start index
0387   0139 4F            mov di, a
0388   013A 48            mov a, sp
0389   013B 77            inc a
0390   013C 4D            mov si, a
0391   013D 38 14 00      mov c, 20
0392   0140 FD F5         rep movsb                           ; save process state!
0393   0142             ; restore kernel stack position to point before interrupt arrived
0394   0142 51 14 00      add sp, 20
0395   0145             ; now load the new process number!
0396   0145 FD 12         mov a, g                            ; retrieve the process number argument that was saved in the beginning
0397   0147 3D E9 16      mov [active_proc_index], al         ; set new active proc
0398   014A             ; calculate LUT entry for next process
0399   014A 22 00         mov ah, 0
0400   014C FD 99         shl a                               ; x2
0401   014E B7 63 0F      mov a, [proc_table_convert + a]     ; get process state start index  
0402   0151 4D            mov si, a                           ; source is proc state block
0403   0152 48            mov a, sp
0404   0153 5F 13 00      sub a, 19
0405   0156 4F            mov di, a                           ; destination is kernel stack
0406   0157             ; restore SP
0407   0157 7D            dec a
0408   0158 47            mov sp, a
0409   0159 38 14 00      mov c, 20
0410   015C FD F5         rep movsb
0411   015E             ; set VM process
0412   015E 1D E9 16      mov al, [active_proc_index]
0413   0161 01            setptb
0414   0162 4C            popa
0415   0163 06            sysret
0416   0164             
0417   0164             syscall_list_procs:
0418   0164 3B 0E 17      mov d, s_ps_header
0419   0167 07 B8 11      call _puts
0420   016A 3B 4E 19      mov d, proc_availab_table + 1
0421   016D 38 01 00      mov c, 1
0422   0170             list_procs_L0:  
0423   0170 BD 01         cmp byte[d], 1
0424   0172 C7 96 01      jne list_procs_next
0425   0175 2D            mov b, d
0426   0176 61 4D 19      sub b, proc_availab_table
0427   0179 FD 9F 05      shl b, 5
0428   017C DA            push d
0429   017D D8            push b
0430   017E 28            mov b, c
0431   017F 07 58 12      call print_u8x
0432   0182 22 20         mov ah, ' '
0433   0184 07 8C 10      call _putchar
0434   0187 07 8C 10      call _putchar
0435   018A E5            pop b
0436   018B 74            mov d, b
0437   018C 58 5D 19      add d, proc_names
0438   018F 07 B8 11      call _puts
0439   0192 07 65 11      call printnl
0440   0195 E7            pop d
0441   0196             list_procs_next:
0442   0196 79            inc d
0443   0197 78            inc c
0444   0198 C2 09 00      cmp c, 9
0445   019B C7 70 01      jne list_procs_L0
0446   019E             list_procs_end:
0447   019E 06            sysret
0448   019F             
0449   019F             ; ------------------------------------------------------------------------------------------------------------------;
0450   019F             ; Exceptions' Code Block
0451   019F             ; ------------------------------------------------------------------------------------------------------------------;
0452   019F             ; Privilege
0453   019F             ; ------------------------------------------------------------------------------------------------------------------;
0454   019F             trap_privilege:
0455   019F 0A 20 01      jmp syscall_reboot
0456   01A2 DA            push d
0457   01A3 3B 50 17      mov d, s_priviledge
0458   01A6 07 B8 11      call _puts
0459   01A9 E7            pop d
0460   01AA 06            sysret
0461   01AB             
0462   01AB             ; ------------------------------------------------------------------------------------------------------------------;
0463   01AB             ; Breakpoint
0464   01AB             ; IMPORTANT: values in the stack are being pushed in big endian. i.e.: MSB at low address
0465   01AB             ; and LSB at high address. *** NEED TO CORRECT THIS IN THE MICROCODE and make it little endian again ***
0466   01AB             ; ------------------------------------------------------------------------------------------------------------------;
0467   01AB             syscall_break:
0468   01AB 4B            pusha
0469   01AC             syscall_break_prompt:
0470   01AC 3B 66 02      mov d, s_break1
0471   01AF 07 B8 11      call _puts
0472   01B2 07 65 11      call printnl
0473   01B5 07 BA 12      call scan_u16d
0474   01B8 AF 00 00      cmp a, 0
0475   01BB C6 C6 01      je syscall_break_regs
0476   01BE AF 01 00      cmp a, 1
0477   01C1 C6 E9 01      je syscall_break_mem
0478   01C4             syscall_break_end:  
0479   01C4 4C            popa
0480   01C5 06            sysret
0481   01C6             syscall_break_regs:
0482   01C6 48            mov a, sp
0483   01C7 53 0E 00      add a, 14               ; back-track 7 registers
0484   01CA 3C            mov d, a
0485   01CB 3A 07         mov cl, 7
0486   01CD             syscall_regs_L0:
0487   01CD 2A            mov b, [d]
0488   01CE FD AB         swp b
0489   01D0 07 14 12      call print_u16x         ; print register value
0490   01D3 07 65 11      call printnl
0491   01D6 63 02 00      sub d, 2
0492   01D9 71 01         sub cl, 1
0493   01DB C3 00         cmp cl, 0
0494   01DD C7 CD 01      jne syscall_regs_L0
0495   01E0 0A AC 01      jmp syscall_break_prompt
0496   01E3 07 65 11      call printnl
0497   01E6 0A AC 01      jmp syscall_break_prompt
0498   01E9             syscall_break_mem:
0499   01E9 07 65 11      call printnl
0500   01EC 07 36 12      call scan_u16x
0501   01EF 4D            mov si, a               ; data source from user space
0502   01F0 FD 4F DD 21   mov di, scrap_sector    ; destination in kernel space
