0008+  00D3             ; CONVERT ASCII 'O'..'F' TO INTEGER 0..15
0009+  00D3             ; ASCII in BL
0010+  00D3             ; result in AL
0011+  00D3             ; ascii for F = 0100 0110
0012+  00D3             ; ascii for 9 = 0011 1001
0013+  00D3             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0014+  00D3             hex_ascii_encode:
0015+  00D3 1B            mov al, bl
0016+  00D4 93 40         test al, $40        ; test if letter or number
0017+  00D6 C7 DC 00      jnz hex_letter
0018+  00D9 87 0F         and al, $0F        ; get number
0019+  00DB 09            ret
0020+  00DC             hex_letter:
0021+  00DC 87 0F         and al, $0F        ; get letter
0022+  00DE 6A 09         add al, 9
0023+  00E0 09            ret
