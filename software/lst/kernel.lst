1333   080E             ;------------------------------------------------------------------------------------------------------;
1334   080E             ; get path from a given directory dirID
1335   080E             ; pseudo code:
1336   080E             ;  fs_dir_id_to_path(int dirID, char *D){
1337   080E             ;    if(dirID == 0){
1338   080E             ;      reverse path in D;
1339   080E             ;      return;
1340   080E             ;    }
1341   080E             ;    else{
1342   080E             ;      copy directory name to end of D;
1343   080E             ;      add '/' to end of D;
1344   080E             ;      parentID = get parent directory ID;
1345   080E             ;      fs_dir_id_to_path(parentID, D);
1346   080E             ;    }
1347   080E             ;  }
1348   080E             ; A = dirID
1349   080E             ; D = generated path string pointer
1350   080E             ;------------------------------------------------------------------------------------------------------;
1351   080E             ; sample path: /usr/bin
1352   080E             fs_dir_id_to_path:
1353   080E 3B C9 1B      mov d, filename
1354   0811 19 00         mov al, 0
1355   0813 3E            mov [d], al                     ; initialize path string 
1356   0814 14 5E 17      mov a, [current_dirID]
1357   0817 07 24 08      call fs_dir_id_to_path_E0
1358   081A 3B C9 1B      mov d, filename
1359   081D 07 FA 0F      call _strrev
1360   0820 07 2C 12      call _puts
