0962   054A C6 45 05      jz syscall_io_getche_L1
0963   054D 3D 80 FF      mov [_UART0_DATA], al        ; write char to Transmitter Holding Register
0964   0550             syscall_io_getche_end:
0965   0550 19 01         mov al, 1
0966   0552 E7            pop d
0967   0553 E5            pop b
0968   0554 06            sysret
