0621   0311 22 FF         mov ah, $FF    
0622   0313 3C            mov d, a                ; get to FFA9 + offset
0623   0314 1B            mov al, bl              ; get data back
0624   0315 F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0625   0319 3E            mov [d], al             ; set data
0626   031A F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0627   031E EA            pop bl
0628   031F E7            pop d
0629   0320 E8            pop al
0630   0321 06            sysret
