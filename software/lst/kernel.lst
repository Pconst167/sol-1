0722   03BE             ; IDE Services Syscall
0723   03BE             ; al = option
0724   03BE             ; 0 = IDE reset, 1 = IDE sleep, 2 = read sector, 3 = write sector
0725   03BE             ; IDE read/write sector
0726   03BE             ; 512 bytes
0727   03BE             ; User buffer pointer in D
