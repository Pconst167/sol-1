0205   003A             ; ------------------------------------------------------------------------------------------------------------------;
0206   003A             ; IRQs' Code Block
0207   003A             ; ------------------------------------------------------------------------------------------------------------------;
0208   003A             int_0:
0209   003A 06            sysret
0210   003B             int_1:
0211   003B 06            sysret
0212   003C             int_2:
0213   003C 06            sysret
0214   003D             int_3:
0215   003D 06            sysret
0216   003E             int_4:
0217   003E 06            sysret
0218   003F             int_5:
0219   003F 06            sysret
0220   0040             
0221   0040             ; ------------------------------------------------------------------------------------------------------------------;
0222   0040             ; Process Swapping
0223   0040             ; ------------------------------------------------------------------------------------------------------------------;
0224   0040             int_6:  
0225   0040 4B            pusha ; save all registers into kernel stack
0226   0041 22 00         mov ah, 0
0227   0043 1D C6 16      mov al, [active_proc_index]
0228   0046 FD 99         shl a              ; x2
0229   0048 B7 47 0F      mov a, [proc_table_convert + a]  ; get process state start index
0230   004B 4F            mov di, a
0231   004C 48            mov a, sp
0232   004D 77            inc a
0233   004E 4D            mov si, a
0234   004F 38 14 00      mov c, 20
0235   0052 FD F5         rep movsb          ; save process state!
0236   0054             ; restore kernel stack position to point before interrupt arrived
0237   0054 51 14 00      add sp, 20
0238   0057             ; now load next process in queue
0239   0057 1D C6 16      mov al, [active_proc_index]
0240   005A 31 C5 16      mov bl, [nbr_active_procs]
0241   005D BA            cmp al, bl
0242   005E C6 65 00      je int6_cycle_back
0243   0061 7A            inc al            ; next process is next in the series
0244   0062 0A 67 00      jmp int6_continue
0245   0065             int6_cycle_back:
0246   0065 19 01         mov al, 1        ; next process = process 1
0247   0067             int6_continue:
0248   0067 3D C6 16      mov [active_proc_index], al    ; set next active proc
0249   006A             
0250   006A             ; calculate LUT entry for next process
0251   006A 22 00         mov ah, 0
0252   006C FD 99         shl a              ; x2
0253   006E B7 47 0F      mov a, [proc_table_convert + a]    ; get process state start index  
0254   0071               
0255   0071 4D            mov si, a            ; source is proc state block
0256   0072 48            mov a, sp
0257   0073 5F 13 00      sub a, 19
0258   0076 4F            mov di, a            ; destination is kernel stack
0259   0077             ; restore SP
0260   0077 7D            dec a
0261   0078 47            mov sp, a
0262   0079 38 14 00      mov c, 20
0263   007C FD F5         rep movsb
0264   007E             ; set VM process
0265   007E 1D C6 16      mov al, [active_proc_index]
0266   0081 01            setptb
0267   0082 F2 E0 FF 00   mov byte[_TIMER_C_0], 0        ; load counter 0 low byte
0268   0086 F2 E0 FF 10   mov byte[_TIMER_C_0], $10        ; load counter 0 high byte
0269   008A 4C            popa
0270   008B 06            sysret
0271   008C             
0272   008C             ; ------------------------------------------------------------------------------------------------------------------;
0273   008C             ; UART0 Interrupt
0274   008C             ; ------------------------------------------------------------------------------------------------------------------;
0275   008C 0A 6F 76 65 s_int_7_oe: .db "\noverrun error.\n", 0
0275   0090 72 72 75 6E 
0275   0094 20 65 72 72 
0275   0098 6F 72 2E 0A 
0275   009C 00 
0276   009D             int_7:
0277   009D D7            push a
0278   009E D8            push b
0279   009F DA            push d
0280   00A0 E1            pushf
0281   00A1             ; check for overrun error
0282   00A1 14 85 FF      mov a, [_UART0_LSR]
0283   00A4 87 02         and al, $02
0284   00A6 C7 DC 00      jnz int_7_oe
0285   00A9             int_7_write_char:
0286   00A9 14 CB 16      mov a, [fifo_in]
0287   00AC 3C            mov d, a
0288   00AD 31 80 FF      mov bl, [_UART0_DATA]  ; get character
0289   00B0 C1 03         cmp bl, $03        ; CTRL-C
0290   00B2 C6 E5 00      je CTRLC
0291   00B5 C1 1A         cmp bl, $1A        ; CTRL-Z
0292   00B7 C6 EB 00      je CTRLZ
0293   00BA FD 3E         mov [d], bl        ; add to fifo
0294   00BC 77            inc a
0295   00BD 42 CB 16      mov [fifo_in], a
0296   00C0 AF 7A 25      cmp a, fifo + FIFO_SIZE - 64
0297   00C3 C6 CB 00      je int_7_xoff
0298   00C6             int_7_continue1:  
0299   00C6 EE            popf
0300   00C7 E7            pop d
0301   00C8 E5            pop b
0302   00C9 E4            pop a  
0303   00CA 06            sysret
0304   00CB             int_7_xoff:    
0305   00CB             int_7_xoff_L0:
0306   00CB             ; send XOFF
0307   00CB 1D 85 FF      mov al, [_UART0_LSR]         ; read Line Status Register
0308   00CE 93 20         test al, $20                 ; isolate Transmitter Empty
0309   00D0 C6 CB 00      jz int_7_xoff_L0    
0310   00D3 F2 80 FF 13   mov byte [_UART0_DATA], XOFF        ; write char to Transmitter Holding Register
0311   00D7             ; commented out to save cpu time
0312   00D7             ; print fifo information
0313   00D7             ;  mov ah, 'I'
0314   00D7             ;  call _putchar
0315   00D7             ;  mov ah, ' '
0316   00D7             ;  call _putchar
0317   00D7             ;  mov b, [fifo_out]
0318   00D7             ;  call print_u16x
0319   00D7             ;  mov ah, ' '
0320   00D7             ;  call _putchar
0321   00D7             ;  mov b, [fifo_in]
0322   00D7             ;  call print_u16x
0323   00D7             ;  mov ah, $0A
0324   00D7             ;  call _putchar
0325   00D7 EE            popf
0326   00D8 E7            pop d
0327   00D9 E5            pop b
0328   00DA E4            pop a  
0329   00DB 06            sysret
0330   00DC             int_7_oe:
0331   00DC 3B 8C 00      mov d, s_int_7_oe
0332   00DF 07 95 11      call _puts
0333   00E2 0A A9 00      jmp int_7_write_char
0334   00E5             CTRLC:
0335   00E5 51 05 00      add sp, 5
0336   00E8 0A 51 0E      jmp syscall_terminate_proc
0337   00EB             CTRLZ:
0338   00EB EE            popf
0339   00EC E7            pop d
0340   00ED E5            pop b
0341   00EE E4            pop a
0342   00EF 0A 94 0E      jmp syscall_pause_proc    ; pause current process and go back to the shell
0343   00F2             
0344   00F2             ; ------------------------------------------------------------------------------------------------------------------;
0345   00F2             ; System Syscalls
0346   00F2             ; ------------------------------------------------------------------------------------------------------------------;
0347   00F2             system_jmptbl:
0348   00F2 28 01         .dw system_uname
0349   00F4 29 01         .dw system_whoami
0350   00F6 25 01         .dw system_setparam
0351   00F8 02 01         .dw system_bootloader_install
0352   00FA 00 01         .dw system_getparam
0353   00FC             syscall_system:
0354   00FC FD 0A F2 00   jmp [system_jmptbl + al]
0355   0100             
0356   0100             ; param register address in register d
0357   0100             ; param value in register bl
0358   0100             system_getparam:
0359   0100 32            mov bl, [d]
0360   0101 06            sysret
0361   0102             
0362   0102             ; kernel LBA address in 'b'
0363   0102             system_bootloader_install:
0364   0102 D8            push b
0365   0103 26 00 00      mov b, 0
0366   0106 38 00 00      mov c, 0
0367   0109 22 01         mov ah, $01                 ; 1 sector
0368   010B 3B BA 27      mov d, transient_area
0369   010E 07 58 04      call ide_read_sect          ; read sector
0370   0111 E5            pop b
0371   0112 FD 44 FE 01   mov [d + 510], b            ; update LBA address
0372   0116 26 00 00      mov b, 0
0373   0119 38 00 00      mov c, 0
0374   011C 22 01         mov ah, $01                 ; 1 sector
0375   011E 3B BA 27      mov d, transient_area
0376   0121 07 7E 04      call ide_write_sect         ; write sector
0377   0124 06            sysret
0378   0125             
0379   0125             ; param register address in register d
0380   0125             ; param value in register bl
0381   0125             system_setparam:
0382   0125 FD 3E         mov [d], bl
0383   0127 06            sysret
0384   0128             
0385   0128             system_uname:
0386   0128 06            sysret
0387   0129             
0388   0129             system_whoami:
0389   0129 06            sysret
0390   012A             
0391   012A             ; REBOOT SYSTEM
0392   012A             syscall_reboot:
0393   012A FD D7 FF FF   push word $FFFF 
0394   012E FD DB 00      push byte %00000000             ; dma_ack = 0, interrupts disabled, mode = supervisor, paging = off, halt=0, display_reg_load=0, dir=0
0395   0131 FD D7 C0 01   push word BIOS_RESET_VECTOR    ; and then push RESET VECTOR of the shell to the stack
0396   0135 06            sysret
0397   0136             
0398   0136             ;------------------------------------------------------------------------------------------------------;;
0399   0136             ; switch to another process
0400   0136             ; inputs:
0401   0136             ; AL = new process number
0402   0136             ;------------------------------------------------------------------------------------------------------;;
0403   0136             syscall_resume_proc:
0404   0136 FD 78         mov g, a                            ; save the process number
0405   0138 4B            pusha                               ; save all registers into kernel stack
0406   0139 22 00         mov ah, 0
0407   013B 1D C6 16      mov al, [active_proc_index]
0408   013E FD 99         shl a              ; x2
0409   0140 B7 47 0F      mov a, [proc_table_convert + a]     ; get process state start index
0410   0143 4F            mov di, a
0411   0144 48            mov a, sp
0412   0145 77            inc a
0413   0146 4D            mov si, a
0414   0147 38 14 00      mov c, 20
0415   014A FD F5         rep movsb                           ; save process state!
0416   014C             ; restore kernel stack position to point before interrupt arrived
0417   014C 51 14 00      add sp, 20
0418   014F             ; now load the new process number!
0419   014F FD 12         mov a, g                            ; retrieve the process number argument that was saved in the beginning
0420   0151 3D C6 16      mov [active_proc_index], al         ; set new active proc
0421   0154             ; calculate LUT entry for next process
0422   0154 22 00         mov ah, 0
0423   0156 FD 99         shl a                               ; x2
0424   0158 B7 47 0F      mov a, [proc_table_convert + a]     ; get process state start index  
0425   015B 4D            mov si, a                           ; source is proc state block
0426   015C 48            mov a, sp
0427   015D 5F 13 00      sub a, 19
0428   0160 4F            mov di, a                           ; destination is kernel stack
0429   0161             ; restore SP
0430   0161 7D            dec a
0431   0162 47            mov sp, a
0432   0163 38 14 00      mov c, 20
0433   0166 FD F5         rep movsb
0434   0168             ; set VM process
0435   0168 1D C6 16      mov al, [active_proc_index]
0436   016B 01            setptb
0437   016C 4C            popa
0438   016D 06            sysret
0439   016E             
0440   016E             syscall_list_procs:
0441   016E 3B EB 16      mov d, s_ps_header
0442   0171 07 95 11      call _puts
0443   0174 3B 2B 19      mov d, proc_availab_table + 1
0444   0177 38 01 00      mov c, 1
0445   017A             list_procs_L0:  
0446   017A BD 01         cmp byte[d], 1
0447   017C C7 A0 01      jne list_procs_next
0448   017F 2D            mov b, d
0449   0180 61 2A 19      sub b, proc_availab_table
0450   0183 FD 9F 05      shl b, 5
0451   0186 DA            push d
0452   0187 D8            push b
0453   0188 28            mov b, c
0454   0189 07 35 12      call print_u8x
0455   018C 22 20         mov ah, ' '
0456   018E 07 69 10      call _putchar
0457   0191 07 69 10      call _putchar
0458   0194 E5            pop b
0459   0195 74            mov d, b
0460   0196 58 3A 19      add d, proc_names
0461   0199 07 95 11      call _puts
0462   019C 07 42 11      call printnl
0463   019F E7            pop d
0464   01A0             list_procs_next:
0465   01A0 79            inc d
0466   01A1 78            inc c
0467   01A2 C2 09 00      cmp c, 9
0468   01A5 C7 7A 01      jne list_procs_L0
0469   01A8             list_procs_end:
0470   01A8 06            sysret
0471   01A9             
0472   01A9             ; ------------------------------------------------------------------------------------------------------------------;
0473   01A9             ; Exceptions' Code Block
0474   01A9             ; ------------------------------------------------------------------------------------------------------------------;
0475   01A9             ; Privilege
0476   01A9             ; ------------------------------------------------------------------------------------------------------------------;
0477   01A9             trap_privilege:
0478   01A9 0A 2A 01      jmp syscall_reboot
0479   01AC DA            push d
0480   01AD 3B 2D 17      mov d, s_priviledge
0481   01B0 07 95 11      call _puts
0482   01B3 E7            pop d
0483   01B4 06            sysret
0484   01B5             
0485   01B5             ; ------------------------------------------------------------------------------------------------------------------;
0486   01B5             ; Breakpoint
0487   01B5             ; IMPORTANT: values in the stack are being pushed in big endian. i.e.: MSB at low address
0488   01B5             ; and LSB at high address. *** NEED TO CORRECT THIS IN THE MICROCODE and make it little endian again ***
0489   01B5             ; ------------------------------------------------------------------------------------------------------------------;
0490   01B5             syscall_break:
0491   01B5 4B            pusha
0492   01B6             syscall_break_prompt:
0493   01B6 3B 70 02      mov d, s_break1
0494   01B9 07 95 11      call _puts
0495   01BC 07 42 11      call printnl
