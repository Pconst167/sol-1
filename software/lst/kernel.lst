0997   0597             ;------------------------------------------------------------------------------------------------------;
0998   0597             ; FILE SYSTEM DATA
0999   0597             ;------------------------------------------------------------------------------------------------------;
1000   0597             ; infor for : IDE SERVICES INTERRUPT
1001   0597             ; IDE read/write 512-byte sector
1002   0597             ; al = option
1003   0597             ; user buffer pointer in D
1004   0597             ; AH = number of sectors
1005   0597             ; CB = LBA bytes 3..0  
1006   0597             ;------------------------------------------------------------------------------------------------------;
1007   0597             ; FILE SYSTEM DATA STRUCTURE
1008   0597             ;------------------------------------------------------------------------------------------------------;
1009   0597             ; for a directory we have the header first, followed by metadata
1010   0597             ; header 1 sector (512 bytes)
1011   0597             ; metadata 1 sector (512 bytes)
1012   0597             ; HEADER ENTRIES:
1013   0597             ; filename (64)
1014   0597             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1015   0597             ;
1016   0597             ; metadata entries:
1017   0597             ; filename (24)
1018   0597             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1019   0597             ; LBA (2)
1020   0597             ; size (2)
1021   0597             ; day (1)
1022   0597             ; month (1)
1023   0597             ; year (1)
1024   0597             ; packet size = 32 bytes
1025   0597             ;
1026   0597             ; first directory on disk is the root directory '/'
1027   0597             file_system_jmptbl:
1028   0597 02 06         .dw fs_mkfs                   ; 0
1029   0599 00 00         .dw 0                         ; 1
1030   059B 64 06         .dw fs_mkdir                  ; 2
1031   059D DD 09         .dw fs_cd                     ; 3
1032   059F E5 09         .dw fs_ls                     ; 4
1033   05A1 00 00         .dw 0                  ; 5
1034   05A3 97 0B         .dw fs_mkbin                  ; 6
1035   05A5 5E 0C         .dw fs_pwd                    ; 7
1036   05A7 7B 0C         .dw fs_cat                    ; 8
1037   05A9 D7 0C         .dw fs_rmdir                  ; 9
1038   05AB 33 0D         .dw fs_rm                     ; 10
1039   05AD F2 0A         .dw fs_starcom                ; 11
1040   05AF 00 00         .dw 0                         ; 12
1041   05B1 00 00         .dw 0                         ; 13
1042   05B3 0A 06         .dw fs_chmod                  ; 14
1043   05B5 9B 0D         .dw fs_mv                     ; 15
1044   05B7 03 06         .dw fs_cd_root                ; 16
1045   05B9 D9 09         .dw fs_get_curr_dirID         ; 17
1046   05BB B5 07         .dw fs_dir_id_to_path         ; 18
1047   05BD 1B 08         .dw fs_path_to_dir_id_user    ; 19
1048   05BF 35 09         .dw fs_load_from_path_user    ; 20  
1049   05C1 A5 08         .dw fs_filepath_exists_user   ; 21
1050   05C3             
