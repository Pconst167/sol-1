1056   05CC C1 00         cmp bl, 0
1057   05CE EA            pop bl
1058   05CF C6 E3 05      je syscall_filesystem_jmp
1059   05D2 DA            push d
1060   05D3 DD            push bl
1061   05D4 3B A8 05      mov d, s_syscall_fs_dbg0
1062   05D7 07 B8 11      call _puts
1063   05DA 2F            mov bl, al
1064   05DB 07 54 12      call print_u8x
1065   05DE 07 65 11      call printnl
1066   05E1 EA            pop bl
1067   05E2 E7            pop d
1068   05E3             syscall_filesystem_jmp:
