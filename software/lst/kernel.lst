0980   054A 07 69 10      call _putchar
0981   054D 22 20         mov ah, ' '
0982   054F 07 69 10      call _putchar
0983   0552 29 CD 16      mov b, [fifo_out]
0984   0555 07 F1 11      call print_u16x
0985   0558 22 20         mov ah, ' '
0986   055A 07 69 10      call _putchar
0987   055D 29 CB 16      mov b, [fifo_in]
0988   0560 07 F1 11      call print_u16x
0989   0563 22 0A         mov ah, $0A
0990   0565 07 69 10      call _putchar
