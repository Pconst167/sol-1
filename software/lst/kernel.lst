0892   04F5             syscall_io:
0893   04F5 FD 0A ED 04   jmp [io_jmp + al]
0894   04F9             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0895   04F9             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0896   04F9             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0897   04F9             io_uart_setup:
0898   04F9 1D FB 16      mov al, [sys_uart0_lcr]
0899   04FC 8B 80         or al, $80                ; set DLAB access bit
0900   04FE 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 1 stop, no parity by default
0901   0501 1D FE 16      mov al, [sys_uart0_div0]
0902   0504 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0903   0507 1D FF 16      mov al, [sys_uart0_div1]
0904   050A 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
