1013   057C DD            push bl
1014   057D 3B 51 05      mov d, s_syscall_fs_dbg0
1015   0580 07 3C 11      call _puts
1016   0583 2F            mov bl, al
1017   0584 07 DC 11      call print_u8x
1018   0587 07 E9 10      call printnl
