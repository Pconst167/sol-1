1234   0705 58 20 00      add d, FST_ENTRY_SIZE
1235   0708 0A 00 07      jmp fs_mkdir_L4              ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1236   070B             fs_mkdir_found_null4:
