0188   0811 B9 03         cmp al, $03        ; CTRL-C
0189   0813 C6 AA 08      je CTRLC
0190   0816 B9 1A         cmp al, $1A        ; CTRL-Z
0191   0818 C6 B0 08      je CTRLZ
0192   081B 3E            mov [d], al        ; add to fifo
0193   081C 14 1B 19      mov a, [fifo_pi]
0194   081F 77            inc a
0195   0820 AF 1A 32      cmp a, fifo + FIFO_SIZE         ; check if pointer reached the end of the fifo
0196   0823 C7 29 08      jne int_0_continue
0197   0826 10 1A 22      mov a, fifo  
