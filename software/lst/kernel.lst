2587   180C 22 00         mov ah, 0
2588   180E FD 99         shl a                             ; x2
2589   1810 B7 A3 18      mov a, [proc_table_convert + a]   ; get process state start index  
2590   1813               
2591   1813 4D            mov si, a                         ; source is proc state block
2592   1814 48            mov a, sp
2593   1815 5F 13 00      sub a, 19
2594   1818 4F            mov di, a                         ; destination is kernel stack
2595   1819             ; restore SP
2596   1819 7D            dec a
2597   181A 47            mov sp, a
2598   181B 38 14 00      mov c, 20
2599   181E FD F5         rep movsb
2600   1820             ; set VM process
2601   1820 1D 16 19      mov al, [active_proc_index]
2602   1823 01            setptb
2603   1824                 
2604   1824 4C            popa
2605   1825 06            sysret
2606   1826             
2607   1826             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
2608   1826             ;; spawn a new process
2609   1826             ;; D = path of the process file to be spawned
2610   1826             ;; B = arguments ptr
2611   1826             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
2612   1826             syscall_spawn_proc:
2613   1826             ; we save the active process first  
2614   1826 4B            pusha
2615   1827 22 00         mov ah, 0
2616   1829 1D 16 19      mov al, [active_proc_index]
2617   182C FD 99         shl a              ; x2
2618   182E B7 A3 18      mov a, [proc_table_convert + a]    ; get process state table's start index
2619   1831               
2620   1831 4F            mov di, a
2621   1832 48            mov a, sp
2622   1833 77            inc a
2623   1834 4D            mov si, a
2624   1835 38 14 00      mov c, 20
2625   1838 FD F5         rep movsb                          ; save process state!
2626   183A             ; restore kernel stack position to point before interrupt arrived
2627   183A 51 14 00      add sp, 20
2628   183D               
2629   183D FD 4E         mov si, d                          ; copy the file path
2630   183F FD 4F 1A 20   mov di, temp_data
2631   1843 38 00 02      mov c, 512
2632   1846 04            load
2633   1847 11            mov a, b
2634   1848 4D            mov si, a                          ; copy the arguments
2635   1849 FD 4F 1A 32   mov di, scrap_sector
2636   184D 38 00 02      mov c, 512
2637   1850 04            load
2638   1851 07 2C 11      call loadfile_from_path            ; load the process file from disk by path (path is in temp_data)
2639   1854                                                  ; the file data is loaded into transient_area
2640   1854             ; now we allocate a new process  
2641   1854 07 85 17      call find_free_proc                ; index in A
2642   1857 01            setptb 
2643   1858 07 97 17      call proc_memory_map               ; map process memory pages
2644   185B             ; copy arguments into process's memory
2645   185B FD 4D 1A 32   mov si, scrap_sector
2646   185F FD 4F 00 00   mov di, 0
2647   1863 38 00 02      mov c, 512
2648   1866 03            store
2649   1867             ; now copy process binary data into process's memory
2650   1867 FD 4D 1A 34   mov si, transient_area
2651   186B FD 4F 00 04   mov di, TEXT_ORG              ; code origin address for all user processes
2652   186F 38 00 40      mov c, FS_FILE_SIZE                ; size of memory space to copy, which is equal to the max file size in disk (for now)
2653   1872 03            store                              ; copy process data
2654   1873                 
2655   1873 07 85 17      call find_free_proc                ; index in A
2656   1876 3D 16 19      mov [active_proc_index], al        ; set new active process
2657   1879 FD 9D 05      shl a, 5                           ; x32
2658   187C 53 1A 1C      add a, proc_names
2659   187F 4F            mov di, a
2660   1880 FD 4D 1A 20   mov si, temp_data                  ; copy and store process filename
2661   1884 07 A8 00      call _strcpy
2662   1887               
2663   1887 07 85 17      call find_free_proc                ; index in A
2664   188A 3C            mov d, a
2665   188B 19 01         mov al, 1
2666   188D 3F 0A 1C      mov [d + proc_availab_table], al   ; make process busy
2667   1890               
2668   1890 1D 15 19      mov al, [nbr_active_procs]         ; increase nbr of active processes
2669   1893 7A            inc al
2670   1894 3D 15 19      mov [nbr_active_procs], al
2671   1897             ; launch process
2672   1897 FD D7 FF FF   push word $FFFF 
2673   189B FD DB 0E      push byte %00001110                ; dma_ack = 0, interrupts enabled = 1, mode = user, paging = on, halt=0, display_reg_load=0, dir=0
2674   189E FD D7 00 04   push word TEXT_ORG
2675   18A2 06            sysret
