0912   04FA 87 7F         and al, $7F               ; clear DLAB access bit 
0913   04FC F2 83 FF 03   mov byte[_UART0_LCR], 3      
0914   0500 1D E4 16      mov al, [sys_uart0_inten]
0915   0503 3D 81 FF      mov [_UART0_IER], al      ; enable interrupts
0916   0506 1D E5 16      mov al, [sys_uart0_fifoen]
0917   0509 3D 82 FF      mov [_UART0_FCR], al      ; disable FIFO
