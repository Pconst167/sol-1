1326   079C             ;------------------------------------------------------------------------------------------------------;
1327   079C             ; get path from a given directory dirID
1328   079C             ; pseudo code:
1329   079C             ;  fs_dir_id_to_path(int dirID, char *D){
1330   079C             ;    if(dirID == 0){
1331   079C             ;      reverse path in D;
1332   079C             ;      return;
1333   079C             ;    }
1334   079C             ;    else{
1335   079C             ;      copy directory name to end of D;
1336   079C             ;      add '/' to end of D;
1337   079C             ;      parentID = get parent directory ID;
1338   079C             ;      fs_dir_id_to_path(parentID, D);
1339   079C             ;    }
1340   079C             ;  }
1341   079C             ; A = dirID
1342   079C             ; D = generated path string pointer
1343   079C             ;------------------------------------------------------------------------------------------------------;
1344   079C             ; sample path: /usr/bin
1345   079C             fs_dir_id_to_path:
1346   079C 3B 3A 1B      mov d, filename
1347   079F 19 00         mov al, 0
1348   07A1 3E            mov [d], al                     ; initialize path string 
1349   07A2 14 CF 16      mov a, [current_dirID]
1350   07A5 07 B2 07      call fs_dir_id_to_path_E0
1351   07A8 3B 3A 1B      mov d, filename
1352   07AB 07 81 0F      call _strrev
1353   07AE 07 95 11      call _puts
1354   07B1 06            sysret
1355   07B2             fs_dir_id_to_path_E0:
1356   07B2 07 D1 07      call get_dirname_from_dirID
1357   07B5 FD 4D E1 16   mov si, s_fslash
1358   07B9 FD 50         mov di, d
1359   07BB 07 FB 0F      call _strcat                    ; add '/' to end of path
1360   07BE AF 20 00      cmp a, root_id               ; check if we are at the root directory
1361   07C1 C6 D0 07      je fs_dir_id_to_path_root
1362   07C4 07 EE 07      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1363   07C7 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1364   07CA C6 D0 07      je fs_dir_id_to_path_root
1365   07CD 07 B2 07      call fs_dir_id_to_path_E0     ; recursively call itself
1366   07D0             fs_dir_id_to_path_root:
1367   07D0 09            ret
1368   07D1             
1369   07D1             ;------------------------------------------------------------------------------------------------------;
1370   07D1             ; in_puts:
1371   07D1             ; A = directory ID
1372   07D1             ; out_puts:
1373   07D1             ; D = pointer to directory name string
1374   07D1             ;------------------------------------------------------------------------------------------------------;
1375   07D1             get_dirname_from_dirID:
1376   07D1 D7            push a
1377   07D2 D8            push b
1378   07D3 DA            push d
1379   07D4 27            mov b, a
1380   07D5 38 00 00      mov c, 0                      ; reset LBA to 0
1381   07D8 22 01         mov ah, $01                   ; disk read
1382   07DA 3B BA 25      mov d, transient_area - 512
1383   07DD 07 58 04      call ide_read_sect            ; read directory
1384   07E0 07 81 0F      call _strrev                  ; reverse dir name before copying
1385   07E3 FD 4E         mov si, d
1386   07E5 E7            pop d                         ; destination address = D value pushed at beginning
1387   07E6 FD 50         mov di, d
1388   07E8 07 FB 0F      call _strcat                  ; copy filename to D
1389   07EB E5            pop b
1390   07EC E4            pop a
1391   07ED 09            ret
1392   07EE             
1393   07EE             ;------------------------------------------------------------------------------------------------------;
1394   07EE             ; in_puts:
1395   07EE             ; A = directory ID
1396   07EE             ; out_puts:
1397   07EE             ; A = parent directory ID
1398   07EE             ;------------------------------------------------------------------------------------------------------;
1399   07EE             get_parentID_from_dirID:
1400   07EE D8            push b
1401   07EF DA            push d
1402   07F0 27            mov b, a
1403   07F1 38 00 00      mov c, 0                      ; reset LBA to 0
