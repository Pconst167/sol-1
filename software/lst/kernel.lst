0884   04C9             syscall_io:
0885   04C9 FD 0A C3 04   jmp [syscall_io_jmp + al]
0886   04CD             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0887   04CD             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0888   04CD             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0889   04CD             syscall_io_uart_setup:
0890   04CD 1D A5 16      mov al, [sys_uart0_lcr]
0891   04D0 8B 80         or al, $80                ; set DLAB access bit
0892   04D2 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 2 stop, no parity by default
0893   04D5 1D A8 16      mov al, [sys_uart0_div0]
0894   04D8 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0895   04DB 1D A9 16      mov al, [sys_uart0_div1]
0896   04DE 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
0897   04E1             
0898   04E1 1D A5 16      mov al, [sys_uart0_lcr]
0899   04E4 87 7F         and al, $7F               ; clear DLAB access bit 
0900   04E6 3D 83 FF      mov [_UART0_LCR], al
0901   04E9 1D A6 16      mov al, [sys_uart0_inten]
0902   04EC 3D 81 FF      mov [_UART0_IER], al      ; interrupts
0903   04EF 1D A7 16      mov al, [sys_uart0_fifoen]
0904   04F2 3D 82 FF      mov [_UART0_FCR], al      ; FIFO control
0905   04F5 06            sysret
