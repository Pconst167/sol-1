1143   06BD             ; search list for NULL name entry. add new directory to list
1144   06BD             fs_mkdir:
1145   06BD FD 4E         mov si, d
1146   06BF FD 4F 49 1C   mov di, user_data
1147   06C3 38 00 02      mov c, 512
1148   06C6 04            load                        ; load data from user-space
1149   06C7 26 22 00      mov b, FST_LBA_START + 2    ; start at 2 because LBA  0 is ROOT (this would also cause issues                 
1150   06CA                                           ; when checking for NULL name, since root has a NULL name)
1151   06CA 38 00 00      mov c, 0                    ; reset LBA to 0
1152   06CD             fs_mkdir_L1:  
1153   06CD 22 01         mov ah, $01                 ; disk read
1154   06CF 3B 49 24      mov d, transient_area
1155   06D2 07 6F 04      call ide_read_sect          ; read sector
1156   06D5 BD 00         cmp byte[d], 0              ; check for NULL
