0819   0484             ; pointer in D
0820   0484             ;----------------------------------------------------------------------------------------------------;
0821   0484             ide_read:
0822   0484 DA            push d
0823   0485             ide_read_loop:
0824   0485 1D D7 FF      mov al, [_ide_R7]  
0825   0488 93 80         test al, 80h                     ; BUSY FLAG
0826   048A C7 85 04      jnz ide_read_loop               ; wait loop
