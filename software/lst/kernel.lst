0902   0509             syscall_io:
0903   0509 FD 0A 03 05   jmp [syscall_io_jmp + al]
0904   050D             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0905   050D             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0906   050D             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0907   050D             syscall_io_uart_setup:
0908   050D 1D 05 17      mov al, [sys_uart0_lcr]
0909   0510 8B 80         or al, $80                ; set DLAB access bit
0910   0512 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 1 stop, no parity by default
0911   0515 1D 08 17      mov al, [sys_uart0_div0]
0912   0518 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0913   051B 1D 09 17      mov al, [sys_uart0_div1]
0914   051E 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
0915   0521             
0916   0521 1D 05 17      mov al, [sys_uart0_lcr]
0917   0524 87 7F         and al, $7F               ; clear DLAB access bit 
0918   0526 F2 83 FF 03   mov byte[_UART0_LCR], 3      
0919   052A 1D 06 17      mov al, [sys_uart0_inten]
0920   052D 3D 81 FF      mov [_UART0_IER], al      ; enable interrupts
0921   0530 1D 07 17      mov al, [sys_uart0_fifoen]
0922   0533 3D 82 FF      mov [_UART0_FCR], al      ; disable FIFO
0923   0536 06            sysret
