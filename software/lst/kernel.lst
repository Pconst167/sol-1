0909   04DF 1C 05         .dw syscall_io_getche
0910   04E1             syscall_io:
0911   04E1 FD 0A D9 04   jmp [syscall_io_jmp + al]
0912   04E5             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0913   04E5             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0914   04E5             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0915   04E5             syscall_io_uart_setup:
0916   04E5 1D DB 16      mov al, [sys_uart0_lcr]
0917   04E8 8B 80         or al, $80                ; set DLAB access bit
0918   04EA 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 1 stop, no parity by default
0919   04ED 1D DE 16      mov al, [sys_uart0_div0]
0920   04F0 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0921   04F3 1D DF 16      mov al, [sys_uart0_div1]
0922   04F6 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
0923   04F9             
0924   04F9 1D DB 16      mov al, [sys_uart0_lcr]
0925   04FC 87 7F         and al, $7F               ; clear DLAB access bit 
0926   04FE F2 83 FF 03   mov byte[_UART0_LCR], 3      
0927   0502 1D DC 16      mov al, [sys_uart0_inten]
0928   0505 3D 81 FF      mov [_UART0_IER], al      ; enable interrupts
0929   0508 1D DD 16      mov al, [sys_uart0_fifoen]
0930   050B 3D 82 FF      mov [_UART0_FCR], al      ; disable FIFO
0931   050E 06            sysret
