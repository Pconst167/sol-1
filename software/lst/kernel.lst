0001   0000             ; ------------------------------------------------------------------------------------------------------------------;
0002   0000             ; Solarium - Sol-1 Homebrew Minicomputer Operating System Kernel.
0003   0000             ; ------------------------------------------------------------------------------------------------------------------;
0004   0000             ; Memory Map
0005   0000             ; ------------------------------------------------------------------------------------------------------------------;
0006   0000             ; 0000    ROM BEGIN
0007   0000             ; ....
0008   0000             ; 7FFF    ROM END
0009   0000             ;
0010   0000             ; 8000    RAM begin
0011   0000             ; ....
0012   0000             ; F7FF    Stack root
0013   0000             ; ------------------------------------------------------------------------------------------------------------------;
0014   0000             ; I/O MAP
0015   0000             ; ------------------------------------------------------------------------------------------------------------------;
0016   0000             ; FF80    UART 0    (16550)
0017   0000             ; FF90    UART 1    (16550)
0018   0000             ; FFA0    RTC       (M48T02)
0019   0000             ; FFB0    PIO 0     (8255)
0020   0000             ; FFC0    PIO 1     (8255)
0021   0000             ; FFD0    IDE       (Compact Flash / PATA)
0022   0000             ; FFE0    Timer     (8253)
0023   0000             ; FFF0    BIOS CONFIGURATION NV-RAM STORE AREA
0024   0000             ; ------------------------------------------------------------------------------------------------------------------;
0025   0000             
0026   0000             ; ------------------------------------------------------------------------------------------------------------------;
0027   0000             ; System Constants
0028   0000             ; ------------------------------------------------------------------------------------------------------------------;
0029   0000             _UART0_DATA       .equ $FF80            ; data
0030   0000             _UART0_DLAB_0     .equ $FF80            ; divisor latch low byte
0031   0000             _UART0_DLAB_1     .equ $FF81            ; divisor latch high byte
0032   0000             _UART0_IER        .equ $FF81            ; Interrupt enable register
0033   0000             _UART0_FCR        .equ $FF82            ; FIFO control register
0034   0000             _UART0_LCR        .equ $FF83            ; line control register
0035   0000             _UART0_LSR        .equ $FF85            ; line status register
0036   0000             
0037   0000             _UART1_DATA       .equ $FF90            ; data
0038   0000             _UART1_DLAB_0     .equ $FF90            ; divisor latch low byte
0039   0000             _UART1_DLAB_1     .equ $FF91            ; divisor latch high byte
0040   0000             _UART1_IER        .equ $FF91            ; Interrupt enable register
0041   0000             _UART1_FCR        .equ $FF92            ; FIFO control register
0042   0000             _UART1_LCR        .equ $FF93            ; line control register
0043   0000             _UART1_LSR        .equ $FF95            ; line status register
0044   0000             
0045   0000             _ide_BASE         .equ $FFD0            ; IDE BASE
0046   0000             _ide_R0           .equ _ide_BASE + 0    ; DATA PORT
0047   0000             _ide_R1           .equ _ide_BASE + 1    ; READ: ERROR CODE, WRITE: FEATURE
0048   0000             _ide_R2           .equ _ide_BASE + 2    ; NUMBER OF SECTORS TO TRANSFER
0049   0000             _ide_R3           .equ _ide_BASE + 3    ; SECTOR ADDRESS LBA 0 [0:7]
0050   0000             _ide_R4           .equ _ide_BASE + 4    ; SECTOR ADDRESS LBA 1 [8:15]
0051   0000             _ide_R5           .equ _ide_BASE + 5    ; SECTOR ADDRESS LBA 2 [16:23]
0052   0000             _ide_R6           .equ _ide_BASE + 6    ; SECTOR ADDRESS LBA 3 [24:27 (LSB)]
0053   0000             _ide_R7           .equ _ide_BASE + 7    ; READ: STATUS, WRITE: COMMAND
0054   0000             
0055   0000             _7SEG_DISPLAY     .equ $FFB0            ; BIOS POST CODE HEX DISPLAY (2 DIGITS)
0056   0000             _BIOS_POST_CTRL   .equ $FFB3            ; BIOS POST DISPLAY CONTROL REGISTER, 80h = As Output
0057   0000             _PIO_A            .equ $FFB0    
0058   0000             _PIO_B            .equ $FFB1
0059   0000             _PIO_C            .equ $FFB2
0060   0000             _PIO_CONTROL      .equ $FFB3            ; PIO CONTROL PORT
0061   0000             
0062   0000             _TIMER_C_0        .equ $FFE0            ; TIMER COUNTER 0
0063   0000             _TIMER_C_1        .equ $FFE1            ; TIMER COUNTER 1
0064   0000             _TIMER_C_2        .equ $FFE2            ; TIMER COUNTER 2
0065   0000             _TIMER_CTRL       .equ $FFE3            ; TIMER CONTROL REGISTER
0066   0000             
0067   0000             STACK_BEGIN       .equ $F7FF            ; beginning of stack
0068   0000             FIFO_SIZE         .equ (1024 * 7 + 512)
0069   0000             
0070   0000             TEXT_ORG          .equ $400
0071   0000             ; ------------------------------------------------------------------------------------------------------------------;
0072   0000             
0073   0000             
0074   0000             ; For the next iteration:
0075   0000             ; boot-sector(1) | kernel-sectors(32) | inode-bitmap | rawdata-bitmap | inode-table | raw-disk-data
0076   0000             ; inode-table format:
0077   0000             ;  file-type(f, d)
0078   0000             ;  permissons
0079   0000             ;  link-count
0080   0000             ;  filesize
0081   0000             ;  time-stamps
0082   0000             ;  15 data block pointers
0083   0000             ;  single-indirect pointer
0084   0000             
0085   0000             ; FILE ENTRY ATTRIBUTES
0086   0000             ; filename (24)
0087   0000             ; attributes (1)       :|0|0|file_type(3bits)|x|w|r|
0088   0000             ; LBA (2)              : location of raw data for file entry, or dirID for directory entry
0089   0000             ; size (2)             : filesize
0090   0000             ; day (1)           
0091   0000             ; month (1)
0092   0000             ; year (1)
0093   0000             ; packet size = 32 bytes  : total packet size in bytes
0094   0000             
0095   0000             FST_ENTRY_SIZE          .equ 32  ; bytes
0096   0000             FST_FILES_PER_SECT      .equ (512 / FST_ENTRY_SIZE)
0097   0000             FST_FILES_PER_DIR       .equ (512 / FST_ENTRY_SIZE)
0098   0000             FST_NBR_DIRECTORIES     .equ 64
0099   0000                                     ; 1 sector for header, the rest is for the list of files/dirs
0100   0000             FST_SECTORS_PER_DIR     .equ (1 + (FST_ENTRY_SIZE * FST_FILES_PER_DIR / 512))    
0101   0000             FST_TOTAL_SECTORS       .equ (FST_SECTORS_PER_DIR * FST_NBR_DIRECTORIES)
0102   0000             FST_LBA_START           .equ 32
0103   0000             FST_LBA_END             .equ (FST_LBA_START + FST_TOTAL_SECTORS - 1)
0104   0000             
0105   0000             FS_NBR_FILES            .equ (FST_NBR_DIRECTORIES * FST_FILES_PER_DIR)
0106   0000             FS_SECTORS_PER_FILE     .equ 32         ; the first sector is always a header with a NULL parameter (first byte)
0107   0000                                                     ; so that we know which blocks are free or taken
0108   0000             FS_FILE_SIZE            .equ (FS_SECTORS_PER_FILE * 512)                  
0109   0000             FS_TOTAL_SECTORS        .equ (FS_NBR_FILES * FS_SECTORS_PER_FILE)
0110   0000             FS_LBA_START            .equ (FST_LBA_END + 1)
0111   0000             FS_LBA_END              .equ (FS_LBA_START + FS_NBR_FILES - 1)
0112   0000             
0113   0000             root_id:                .equ FST_LBA_START
0114   0000             
0115   0000             ; ------------------------------------------------------------------------------------------------------------------;
0116   0000             ; GLOBAL SYSTEM VARIABLES
0117   0000             ; ------------------------------------------------------------------------------------------------------------------;
0118   0000             
0119   0000             ; ------------------------------------------------------------------------------------------------------------------;
0120   0000             ; IRQ Table
0121   0000             ; Highest priority at lowest address
0122   0000             ; ------------------------------------------------------------------------------------------------------------------;
0123   0000 3A 00       .dw int_0
0124   0002 3B 00       .dw int_1
0125   0004 3C 00       .dw int_2
0126   0006 3D 00       .dw int_3
0127   0008 3E 00       .dw int_4
0128   000A 3F 00       .dw int_5
0129   000C 40 00       .dw int_6
0130   000E 8C 00       .dw int_7
0131   0010             
0132   0010             ; ------------------------------------------------------------------------------------------------------------------;
0133   0010             ; Reset Vector
0134   0010             ; ------------------------------------------------------------------------------------------------------------------;
0135   0010 0C 0E       .dw kernel_reset_vector
0136   0012             
0137   0012             ; ------------------------------------------------------------------------------------------------------------------;
0138   0012             ; Exception Vector Table
0139   0012             ; Total of 7 entries, starting at address $0012
0140   0012             ; ------------------------------------------------------------------------------------------------------------------;
0141   0012 B3 01       .dw trap_privilege
0142   0014 D0 02       .dw trap_div_zero
0143   0016 DD 02       .dw trap_undef_opcode
0144   0018 00 00       .dw 0
0145   001A 00 00       .dw 0
0146   001C 00 00       .dw 0
0147   001E 00 00       .dw 0
0148   0020             
0149   0020             ; ------------------------------------------------------------------------------------------------------------------;
0150   0020             ; System Call Vector Table
0151   0020             ; Starts at address $0020
0152   0020             ; ------------------------------------------------------------------------------------------------------------------;
0153   0020 BF 01       .dw syscall_breakpoint
0154   0022 DE 02       .dw syscall_rtc
0155   0024 18 04       .dw syscall_ide
0156   0026 F5 04       .dw syscall_io
0157   0028 E3 05       .dw syscall_file_system
0158   002A E3 0E       .dw syscall_spawn_proc
0159   002C 78 01       .dw syscall_list_procs
0160   002E 10 03       .dw syscall_datetime
0161   0030 34 01       .dw syscall_reboot
0162   0032 AD 0E       .dw syscall_pause_proc
0163   0034 40 01       .dw syscall_resume_proc
0164   0036 6A 0E       .dw syscall_terminate_proc
0165   0038 08 01       .dw syscall_system
0166   003A             
0167   003A             ; ------------------------------------------------------------------------------------------------------------------;
0168   003A             ; System Call Aliases
0169   003A             ; ------------------------------------------------------------------------------------------------------------------;
0170   003A             sys_bkpt             .equ 0
0171   003A             sys_rtc              .equ 1
0172   003A             sys_ide              .equ 2
0173   003A             sys_io               .equ 3
0174   003A             sys_filesystem       .equ 4
0175   003A             sys_spawn_proc       .equ 5
0176   003A             sys_list             .equ 6
0177   003A             sys_datetime         .equ 7
0178   003A             sys_reboot           .equ 8
0179   003A             sys_pause_proc       .equ 9
0180   003A             sys_resume_proc      .equ 10
0181   003A             sys_terminate_proc   .equ 11
0182   003A             sys_system           .equ 12
0183   003A             
0184   003A             ; ------------------------------------------------------------------------------------------------------------------;
0185   003A             ; Alias Exports
0186   003A             ; ------------------------------------------------------------------------------------------------------------------;
0187   003A             .export TEXT_ORG
0188   003A             .export sys_bkpt
0189   003A             .export sys_ide
0190   003A             .export sys_io
0191   003A             .export sys_filesystem
0192   003A             .export sys_spawn_proc
0193   003A             .export sys_list
0194   003A             .export sys_rtc
0195   003A             .export sys_datetime
0196   003A             .export sys_reboot
0197   003A             .export sys_pause_proc
0198   003A             .export sys_resume_proc
0199   003A             .export sys_terminate_proc
0200   003A             .export sys_system
0201   003A             
0202   003A             ; ------------------------------------------------------------------------------------------------------------------;
0203   003A             ; IRQs' Code Block
0204   003A             ; ------------------------------------------------------------------------------------------------------------------;
0205   003A             int_0:
0206   003A 06            sysret
0207   003B             int_1:
0208   003B 06            sysret
0209   003C             int_2:
0210   003C 06            sysret
0211   003D             int_3:
0212   003D 06            sysret
0213   003E             int_4:
0214   003E 06            sysret
0215   003F             int_5:
0216   003F 06            sysret
0217   0040             
0218   0040             ; ------------------------------------------------------------------------------------------------------------------;
0219   0040             ; Process Swapping
0220   0040             ; ------------------------------------------------------------------------------------------------------------------;
0221   0040             int_6:  
0222   0040 4B            pusha ; save all registers into kernel stack
0223   0041 22 00         mov ah, 0
0224   0043 1D 01 17      mov al, [active_proc_index]
0225   0046 FD 99         shl a              ; x2
0226   0048 B7 60 0F      mov a, [proc_table_convert + a]  ; get process state start index
0227   004B 4F            mov di, a
0228   004C 48            mov a, sp
0229   004D 77            inc a
0230   004E 4D            mov si, a
0231   004F 38 14 00      mov c, 20
0232   0052 FD F5         rep movsb          ; save process state!
0233   0054             ; restore kernel stack position to point before interrupt arrived
0234   0054 51 14 00      add sp, 20
0235   0057             ; now load next process in queue
0236   0057 1D 01 17      mov al, [active_proc_index]
0237   005A 31 00 17      mov bl, [nbr_active_procs]
0238   005D BA            cmp al, bl
0239   005E C6 65 00      je int6_cycle_back
0240   0061 7A            inc al            ; next process is next in the series
0241   0062 0A 67 00      jmp int6_continue
0242   0065             int6_cycle_back:
0243   0065 19 01         mov al, 1        ; next process = process 1
0244   0067             int6_continue:
0245   0067 3D 01 17      mov [active_proc_index], al    ; set next active proc
0246   006A             
0247   006A             ; calculate LUT entry for next process
0248   006A 22 00         mov ah, 0
0249   006C FD 99         shl a              ; x2
0250   006E B7 60 0F      mov a, [proc_table_convert + a]    ; get process state start index  
0251   0071               
0252   0071 4D            mov si, a            ; source is proc state block
0253   0072 48            mov a, sp
0254   0073 5F 13 00      sub a, 19
0255   0076 4F            mov di, a            ; destination is kernel stack
0256   0077             ; restore SP
0257   0077 7D            dec a
0258   0078 47            mov sp, a
0259   0079 38 14 00      mov c, 20
0260   007C FD F5         rep movsb
0261   007E             ; set VM process
0262   007E 1D 01 17      mov al, [active_proc_index]
0263   0081 01            setptb
0264   0082 F2 E0 FF 00   mov byte[_TIMER_C_0], 0        ; load counter 0 low byte
0265   0086 F2 E0 FF 10   mov byte[_TIMER_C_0], $10        ; load counter 0 high byte
0266   008A 4C            popa
0267   008B 06            sysret
0268   008C             
0269   008C             ; ------------------------------------------------------------------------------------------------------------------;
0270   008C             ; UART0 Interrupt
0271   008C             ; ------------------------------------------------------------------------------------------------------------------;
0272   008C             int_7:
0273   008C D7            push a
0274   008D DA            push d
0275   008E E1            pushf
0276   008F 14 06 17      mov a, [fifo_in]
0277   0092 3C            mov d, a
0278   0093 1D 80 FF      mov al, [_UART0_DATA]  ; get character
0279   0096 B9 03         cmp al, $03        ; CTRL-C
0280   0098 C6 F4 00      je CTRLC
0281   009B B9 1A         cmp al, $1A        ; CTRL-Z
0282   009D C6 FA 00      je CTRLZ
0283   00A0 3E            mov [d], al        ; add to fifo
0284   00A1 14 06 17      mov a, [fifo_in]
0285   00A4 77            inc a
0286   00A5 29 08 17      mov b, [fifo_out]
0287   00A8 B0            cmp a, b
0288   00A9 C6 BC 00      je int_7_fifo_overflow
0289   00AC AF F5 3B      cmp a, fifo + FIFO_SIZE         ; check if pointer reached the end of the fifo
0290   00AF C7 B5 00      jne int_7_continue
0291   00B2 10 F5 1D      mov a, fifo  
0292   00B5             int_7_continue:  
0293   00B5 42 06 17      mov [fifo_in], a      ; update fifo pointer
0294   00B8 EE            popf
0295   00B9 E7            pop d
0296   00BA E4            pop a  
0297   00BB 06            sysret
0298   00BC             int_7_fifo_overflow:
0299   00BC 3B DC 00      mov d, s_fifo_overflow
0300   00BF 07 D8 11      call _puts
0301   00C2 29 06 17      mov b, [fifo_in]
0302   00C5 07 30 12      call print_u16x
0303   00C8 22 3A         mov ah, ':'
0304   00CA 07 8E 10      call _putchar
0305   00CD 29 08 17      mov b, [fifo_out]
0306   00D0 07 30 12      call print_u16x
0307   00D3 07 85 11      call printnl
0308   00D6 10 F5 1D      mov a, fifo  
0309   00D9 0A B5 00      jmp int_7_continue
0310   00DC             
0311   00DC 0A 46 61 74 s_fifo_overflow: .db "\nFatal: FIFO overflow: ", 0
0311   00E0 61 6C 3A 20 
0311   00E4 46 49 46 4F 
0311   00E8 20 6F 76 65 
0311   00EC 72 66 6C 6F 
0311   00F0 77 3A 20 00 
0312   00F4             
0313   00F4             CTRLC:
0314   00F4 51 05 00      add sp, 5
0315   00F7 0A 6A 0E      jmp syscall_terminate_proc
0316   00FA             CTRLZ:
0317   00FA EE            popf
0318   00FB E7            pop d
0319   00FC E4            pop a
0320   00FD 0A AD 0E      jmp syscall_pause_proc    ; pause current process and go back to the shell
0321   0100             
0322   0100             ; ------------------------------------------------------------------------------------------------------------------;
0323   0100             ; System Syscalls
0324   0100             ; ------------------------------------------------------------------------------------------------------------------;
0325   0100             system_jmptbl:
0326   0100 32 01         .dw system_uname
0327   0102 33 01         .dw system_whoami
0328   0104 2F 01         .dw system_setparam
0329   0106 0C 01         .dw system_bootloader_install
0330   0108             syscall_system:
0331   0108 FD 0A 00 01   jmp [system_jmptbl + al]
0332   010C             
0333   010C             ; kernel LBA address in 'b'
0334   010C             system_bootloader_install:
0335   010C D8            push b
0336   010D 26 00 00      mov b, 0
0337   0110 38 00 00      mov c, 0
0338   0113 22 01         mov ah, $01                 ; 1 sector
0339   0115 3B F5 3D      mov d, transient_area
0340   0118 07 62 04      call ide_read_sect          ; read sector
0341   011B E5            pop b
0342   011C FD 44 FE 01   mov [d + 510], b            ; update LBA address
0343   0120 26 00 00      mov b, 0
0344   0123 38 00 00      mov c, 0
0345   0126 22 01         mov ah, $01                 ; 1 sector
0346   0128 3B F5 3D      mov d, transient_area
0347   012B 07 88 04      call ide_write_sect         ; write sector
0348   012E 06            sysret
0349   012F             
0350   012F             ; param register address in register d
0351   012F             ; param value in register bl
0352   012F             system_setparam:
0353   012F FD 3E         mov [d], bl
0354   0131 06            sysret
0355   0132             
0356   0132             system_uname:
0357   0132 06            sysret
0358   0133             
0359   0133             system_whoami:
0360   0133 06            sysret
0361   0134             
0362   0134             ; REBOOT SYSTEM
0363   0134             syscall_reboot:
0364   0134 FD D7 FF FF   push word $FFFF 
0365   0138 FD DB 00      push byte %00000000             ; dma_ack = 0, interrupts disabled, mode = supervisor, paging = off, halt=0, display_reg_load=0, dir=0
0366   013B FD D7 C0 01   push word BIOS_RESET_VECTOR    ; and then push RESET VECTOR of the shell to the stack
0367   013F 06            sysret
0368   0140             
0369   0140             ;------------------------------------------------------------------------------------------------------;;
0370   0140             ; switch to another process
0371   0140             ; inputs:
0372   0140             ; AL = new process number
0373   0140             ;------------------------------------------------------------------------------------------------------;;
0374   0140             syscall_resume_proc:
0375   0140 FD 78         mov g, a                            ; save the process number
0376   0142 4B            pusha                               ; save all registers into kernel stack
0377   0143 22 00         mov ah, 0
0378   0145 1D 01 17      mov al, [active_proc_index]
0379   0148 FD 99         shl a              ; x2
0380   014A B7 60 0F      mov a, [proc_table_convert + a]     ; get process state start index
0381   014D 4F            mov di, a
0382   014E 48            mov a, sp
0383   014F 77            inc a
0384   0150 4D            mov si, a
0385   0151 38 14 00      mov c, 20
0386   0154 FD F5         rep movsb                           ; save process state!
0387   0156             ; restore kernel stack position to point before interrupt arrived
0388   0156 51 14 00      add sp, 20
0389   0159             ; now load the new process number!
0390   0159 FD 12         mov a, g                            ; retrieve the process number argument that was saved in the beginning
0391   015B 3D 01 17      mov [active_proc_index], al         ; set new active proc
0392   015E             ; calculate LUT entry for next process
0393   015E 22 00         mov ah, 0
0394   0160 FD 99         shl a                               ; x2
0395   0162 B7 60 0F      mov a, [proc_table_convert + a]     ; get process state start index  
0396   0165 4D            mov si, a                           ; source is proc state block
0397   0166 48            mov a, sp
0398   0167 5F 13 00      sub a, 19
0399   016A 4F            mov di, a                           ; destination is kernel stack
0400   016B             ; restore SP
0401   016B 7D            dec a
0402   016C 47            mov sp, a
0403   016D 38 14 00      mov c, 20
0404   0170 FD F5         rep movsb
0405   0172             ; set VM process
0406   0172 1D 01 17      mov al, [active_proc_index]
0407   0175 01            setptb
0408   0176 4C            popa
0409   0177 06            sysret
0410   0178             
0411   0178             syscall_list_procs:
0412   0178 3B 26 17      mov d, s_ps_header
0413   017B 07 D8 11      call _puts
0414   017E 3B 66 19      mov d, proc_availab_table + 1
0415   0181 38 01 00      mov c, 1
0416   0184             list_procs_L0:  
0417   0184 BD 01         cmp byte[d], 1
0418   0186 C7 AA 01      jne list_procs_next
0419   0189 2D            mov b, d
0420   018A 61 65 19      sub b, proc_availab_table
0421   018D FD 9F 05      shl b, 5
0422   0190 DA            push d
0423   0191 D8            push b
0424   0192 28            mov b, c
0425   0193 07 74 12      call print_u8x
0426   0196 22 20         mov ah, ' '
0427   0198 07 8E 10      call _putchar
0428   019B 07 8E 10      call _putchar
0429   019E E5            pop b
0430   019F 74            mov d, b
0431   01A0 58 75 19      add d, proc_names
0432   01A3 07 D8 11      call _puts
0433   01A6 07 85 11      call printnl
0434   01A9 E7            pop d
0435   01AA             list_procs_next:
0436   01AA 79            inc d
0437   01AB 78            inc c
0438   01AC C2 09 00      cmp c, 9
0439   01AF C7 84 01      jne list_procs_L0
0440   01B2             list_procs_end:
0441   01B2 06            sysret
0442   01B3             
0443   01B3             ; ------------------------------------------------------------------------------------------------------------------;
0444   01B3             ; Exceptions' Code Block
0445   01B3             ; ------------------------------------------------------------------------------------------------------------------;
0446   01B3             ; Privilege
0447   01B3             ; ------------------------------------------------------------------------------------------------------------------;
0448   01B3             trap_privilege:
0449   01B3 0A 34 01      jmp syscall_reboot
0450   01B6 DA            push d
0451   01B7 3B 68 17      mov d, s_priviledge
0452   01BA 07 D8 11      call _puts
0453   01BD E7            pop d
0454   01BE 06            sysret
0455   01BF             
0456   01BF             ; ------------------------------------------------------------------------------------------------------------------;
0457   01BF             ; Breakpoint
0458   01BF             ; IMPORTANT: values in the stack are being pushed in big endian. i.e.: MSB at low address
0459   01BF             ; and LSB at high address. *** NEED TO CORRECT THIS IN THE MICROCODE and make it little endian again ***
0460   01BF             ; ------------------------------------------------------------------------------------------------------------------;
0461   01BF             syscall_breakpoint:
0462   01BF 4B            pusha
0463   01C0             syscall_break_prompt:
0464   01C0 3B 7A 02      mov d, s_break1
0465   01C3 07 D8 11      call _puts
0466   01C6 07 85 11      call printnl
0467   01C9 07 D2 12      call scan_u16d
0468   01CC AF 00 00      cmp a, 0
0469   01CF C6 DA 01      je syscall_break_regs
0470   01D2 AF 01 00      cmp a, 1
0471   01D5 C6 FD 01      je syscall_break_mem
0472   01D8             syscall_break_end:  
0473   01D8 4C            popa
0474   01D9 06            sysret
0475   01DA             syscall_break_regs:
0476   01DA 48            mov a, sp
0477   01DB 53 0E 00      add a, 14               ; back-track 7 registers
0478   01DE 3C            mov d, a
0479   01DF 3A 07         mov cl, 7
0480   01E1             syscall_regs_L0:
0481   01E1 2A            mov b, [d]
0482   01E2 FD AB         swp b
0483   01E4 07 30 12      call print_u16x         ; print register value
0484   01E7 07 85 11      call printnl
0485   01EA 63 02 00      sub d, 2
0486   01ED 71 01         sub cl, 1
0487   01EF C3 00         cmp cl, 0
0488   01F1 C7 E1 01      jne syscall_regs_L0
0489   01F4 0A C0 01      jmp syscall_break_prompt
0490   01F7 07 85 11      call printnl
0491   01FA 0A C0 01      jmp syscall_break_prompt
0492   01FD             syscall_break_mem:
0493   01FD 07 85 11      call printnl
0494   0200 07 52 12      call scan_u16x
