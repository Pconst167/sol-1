1271   0743             ;------------------------------------------------------------------------------------------------------;
1272   0743             ; get path from a given directory dirID
1273   0743             ; pseudo code:
1274   0743             ;  fs_dir_id_to_path(int dirID, char *D){
1275   0743             ;    if(dirID == 0){
1276   0743             ;      reverse path in D;
1277   0743             ;      return;
1278   0743             ;    }
1279   0743             ;    else{
1280   0743             ;      copy directory name to end of D;
1281   0743             ;      add '/' to end of D;
1282   0743             ;      parentID = get parent directory ID;
1283   0743             ;      fs_dir_id_to_path(parentID, D);
1284   0743             ;    }
1285   0743             ;  }
1286   0743             ; A = dirID
1287   0743             ; D = generated path string pointer
1288   0743             ;------------------------------------------------------------------------------------------------------;
1289   0743             ; sample path: /usr/bin
1290   0743             fs_dir_id_to_path:
1291   0743 3B E1 1A      mov d, filename
1292   0746 19 00         mov al, 0
1293   0748 3E            mov [d], al                     ; initialize path string 
1294   0749 14 76 16      mov a, [current_dirID]
1295   074C 07 59 07      call fs_dir_id_to_path_E0
1296   074F 3B E1 1A      mov d, filename
1297   0752 07 28 0F      call _strrev
1298   0755 07 3C 11      call _puts
1299   0758 06            sysret
1300   0759             fs_dir_id_to_path_E0:
1301   0759 07 78 07      call get_dirname_from_dirID
1302   075C FD 4D 88 16   mov si, s_fslash
1303   0760 FD 50         mov di, d
1304   0762 07 A2 0F      call _strcat                    ; add '/' to end of path
1305   0765 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1306   0768 C6 77 07      je fs_dir_id_to_path_root
1307   076B 07 95 07      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1308   076E AF 20 00      cmp a, root_id               ; check if we are at the root directory
1309   0771 C6 77 07      je fs_dir_id_to_path_root
1310   0774 07 59 07      call fs_dir_id_to_path_E0     ; recursively call itself
1311   0777             fs_dir_id_to_path_root:
1312   0777 09            ret
1313   0778             
1314   0778             ;------------------------------------------------------------------------------------------------------;
1315   0778             ; in_puts:
1316   0778             ; A = directory ID
1317   0778             ; out_puts:
1318   0778             ; D = pointer to directory name string
1319   0778             ;------------------------------------------------------------------------------------------------------;
1320   0778             get_dirname_from_dirID:
1321   0778 D7            push a
1322   0779 D8            push b
1323   077A DA            push d
1324   077B 27            mov b, a
1325   077C 38 00 00      mov c, 0                      ; reset LBA to 0
1326   077F 22 01         mov ah, $01                   ; disk read
1327   0781 3B 61 3D      mov d, transient_area - 512
1328   0784 07 27 04      call ide_read_sect            ; read directory
1329   0787 07 28 0F      call _strrev                  ; reverse dir name before copying
1330   078A FD 4E         mov si, d
1331   078C E7            pop d                         ; destination address = D value pushed at beginning
1332   078D FD 50         mov di, d
1333   078F 07 A2 0F      call _strcat                  ; copy filename to D
1334   0792 E5            pop b
1335   0793 E4            pop a
1336   0794 09            ret
1337   0795             
1338   0795             ;------------------------------------------------------------------------------------------------------;
1339   0795             ; in_puts:
1340   0795             ; A = directory ID
1341   0795             ; out_puts:
1342   0795             ; A = parent directory ID
1343   0795             ;------------------------------------------------------------------------------------------------------;
1344   0795             get_parentID_from_dirID:
1345   0795 D8            push b
1346   0796 DA            push d
1347   0797 27            mov b, a
1348   0798 38 00 00      mov c, 0                      ; reset LBA to 0
1349   079B 22 01         mov ah, $01                   ; disk read
1350   079D 3B 61 3D      mov d, transient_area - 512
1351   07A0 07 27 04      call ide_read_sect            ; read directory
1352   07A3 16 40 00      mov a, [d + 64]               ; copy parent ID value to A
1353   07A6 E7            pop d
1354   07A7 E5            pop b
1355   07A8 09            ret
1356   07A9             
1357   07A9             ;------------------------------------------------------------------------------------------------------;
1358   07A9             ; get dirID from a given path string
1359   07A9             ; in_puts:
1360   07A9             ; D = path pointer 
1361   07A9             ; out_puts:
1362   07A9             ; A = dirID
1363   07A9             ; if dir non existent, A = FFFF (fail code)
1364   07A9             ; /usr/local/bin    - absolute
1365   07A9             ; local/bin/games    - relative
1366   07A9             ;------------------------------------------------------------------------------------------------------;
1367   07A9             fs_path_to_dir_id_user:
1368   07A9 FD 4E         mov si, d
1369   07AB FD 4F 61 1B   mov di, user_data
1370   07AF 38 00 02      mov c, 512
1371   07B2 04            load
1372   07B3 07 B7 07      call get_dirID_from_path
1373   07B6 06            sysret
1374   07B7             get_dirID_from_path:
1375   07B7 26 61 1B      mov b, user_data
1376   07BA FD 42 61 15   mov [prog], b                  ; token pointer set to path string
1377   07BE 07 C2 13      call get_token
1378   07C1 31 64 15      mov bl, [tok]
1379   07C4 C1 01         cmp bl, TOK_FSLASH
1380   07C6 C6 D2 07      je get_dirID_from_path_abs 
1381   07C9 14 76 16      mov a, [current_dirID]
1382   07CC 07 48 15      call _putback
1383   07CF 0A D5 07      jmp get_dirID_from_path_E0
1384   07D2             get_dirID_from_path_abs:
1385   07D2 10 20 00      mov a, root_id
1386   07D5             get_dirID_from_path_E0:
1387   07D5 07 C2 13      call get_token
1388   07D8 31 63 15      mov bl, [toktyp]
1389   07DB C1 00         cmp bl, TOKTYP_IDENTIFIER
1390   07DD C7 2E 08      jne get_dirID_from_path_end   ; check if there are tokens after '/'. i.e. is this a 'cd /' command?
1391   07E0             
1392   07E0 FD 4D 65 15   mov si, tokstr
1393   07E4 FD 4F E1 1A   mov di, filename
1394   07E8 07 94 0F      call _strcpy        
1395   07EB 77            inc a                         ; metadata sector
1396   07EC 27            mov b, a
