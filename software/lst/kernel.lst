1056   060C 06            sysret  
1057   060D             
1058   060D             ; filename in D (userspace data)
1059   060D             ; permission in BL
1060   060D             fs_chmod:
1061   060D DD            push bl
1062   060E FD 4E         mov si, d
1063   0610 FD 4F DD 1B   mov di, user_data
1064   0614 38 80 00      mov c, 128
1065   0617 04            load                        ; load filename from user-space
1066   0618 14 F2 16      mov a, [current_dirID]
1067   061B 77            inc a                       ; metadata sector
1068   061C 27            mov b, a
1069   061D 38 00 00      mov c, 0                    ; reset LBA to 0
1070   0620 22 01         mov ah, $01                 ; disk read
1071   0622 3B DD 23      mov d, transient_area
1072   0625 07 4E 04      call ide_read_sect          ; read directory
1073   0628 FD 10         cla
1074   062A 42 EA 16      mov [index], a              ; reset file counter
1075   062D             fs_chmod_L1:
1076   062D FD 4E         mov si, d
1077   062F FD 4F DD 1B   mov di, user_data
1078   0633 07 FB 0F      call _strcmp
1079   0636 C6 4D 06      je fs_chmod_found_entry
1080   0639 58 20 00      add d, 32
1081   063C 14 EA 16      mov a, [index]
1082   063F 77            inc a
1083   0640 42 EA 16      mov [index], a
1084   0643 AF 10 00      cmp a, FST_FILES_PER_DIR
1085   0646 C7 2D 06      jne fs_chmod_L1
1086   0649 EA            pop bl
1087   064A 0A 66 06      jmp fs_chmod_not_found
1088   064D             fs_chmod_found_entry:  
1089   064D FD 79         mov g, b                    ; save LBA
1090   064F EA            pop bl                      ; retrieve saved permission value
1091   0650 1F 18 00      mov al, [d + 24]            ; read file permissions
1092   0653 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1093   0655 8C            or al, bl                   ; set new permissions
1094   0656 3F 18 00      mov [d + 24], al            ; write new permissions
1095   0659 38 00 00      mov c, 0
1096   065C 3B DD 23      mov d, transient_area
1097   065F 22 01         mov ah, $01                 ; disk write 1 sect
1098   0661 FD 27         mov b, g                    ; retrieve LBA
1099   0663 07 74 04      call ide_write_sect         ; write sector
1100   0666             fs_chmod_not_found:
1101   0666 06            sysret
