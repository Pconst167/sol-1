0594   02F4             ; RTC Services Syscall
0595   02F4             ; RTC I/O bank = FFA0 to FFAF
0596   02F4             ; FFA0 to FFA7 is scratch RAM
0597   02F4             ; Control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0598   02F4             ; al = 0..6 -> get
0599   02F4             ; al = 7..D -> set
