1085   05F0 06            sysret  
1086   05F1             
1087   05F1             ; filename in D (userspace data)
1088   05F1             ; permission in BL
1089   05F1             fs_chmod:
1090   05F1 DD            push bl
1091   05F2 FD 4E         mov si, d
1092   05F4 FD 4F BA 1B   mov di, user_data
1093   05F8 38 80 00      mov c, 128
1094   05FB 04            load                        ; load filename from user-space
1095   05FC 14 CF 16      mov a, [current_dirID]
1096   05FF 77            inc a                       ; metadata sector
1097   0600 27            mov b, a
1098   0601 38 00 00      mov c, 0                    ; reset LBA to 0
1099   0604 22 01         mov ah, $01                 ; disk read
1100   0606 3B BA 27      mov d, transient_area
1101   0609 07 58 04      call ide_read_sect          ; read directory
1102   060C FD 10         cla
1103   060E 42 C7 16      mov [index], a              ; reset file counter
1104   0611             fs_chmod_L1:
1105   0611 FD 4E         mov si, d
1106   0613 FD 4F BA 1B   mov di, user_data
1107   0617 07 D8 0F      call _strcmp
1108   061A C6 31 06      je fs_chmod_found_entry
1109   061D 58 20 00      add d, 32
1110   0620 14 C7 16      mov a, [index]
1111   0623 77            inc a
1112   0624 42 C7 16      mov [index], a
1113   0627 AF 10 00      cmp a, FST_FILES_PER_DIR
1114   062A C7 11 06      jne fs_chmod_L1
1115   062D EA            pop bl
1116   062E 0A 4A 06      jmp fs_chmod_not_found
1117   0631             fs_chmod_found_entry:  
1118   0631 FD 79         mov g, b                    ; save LBA
1119   0633 EA            pop bl                      ; retrieve saved permission value
1120   0634 1F 18 00      mov al, [d + 24]            ; read file permissions
1121   0637 87 F8         and al, %11111000           ; remove all permissions, keep other flags
1122   0639 8C            or al, bl                   ; set new permissions
1123   063A 3F 18 00      mov [d + 24], al            ; write new permissions
1124   063D 38 00 00      mov c, 0
1125   0640 3B BA 27      mov d, transient_area
1126   0643 22 01         mov ah, $01                 ; disk write 1 sect
1127   0645 FD 27         mov b, g                    ; retrieve LBA
1128   0647 07 7E 04      call ide_write_sect         ; write sector
1129   064A             fs_chmod_not_found:
1130   064A 06            sysret
