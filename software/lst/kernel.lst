1240   0714 58 18 00      add d, 24                     ; goto ATTRIBUTES
1241   0717 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1242   0719 3E            mov [d], al      
1243   071A 79            inc d
1244   071B E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1245   071C FD 43         mov [d], b                    ; save LBA
1246   071E             ; set file creation date  
1247   071E 58 04 00      add d, 4
1248   0721 19 04         mov al, 4
1249   0723 05 01         syscall sys_rtc
1250   0725 1A            mov al, ah
1251   0726 3E            mov [d], al                   ; set day
1252   0727 79            inc d
1253   0728 19 05         mov al, 5
1254   072A 05 01         syscall sys_rtc
1255   072C 1A            mov al, ah
1256   072D 3E            mov [d], al                   ; set month
1257   072E 79            inc d
1258   072F 19 06         mov al, 6
1259   0731 05 01         syscall sys_rtc
1260   0733 1A            mov al, ah
1261   0734 3E            mov [d], al                   ; set year
