0791   043A F2 D6 FF 40   mov byte [_ide_R6], %01000000   ; lba[3:0](reserved), bit 6=1
0792   043E F2 D7 FF E6   mov byte [_ide_R7], $E6         ; sleep command
0793   0442 07 D0 04      call ide_wait                   ; wait for IDE ready
