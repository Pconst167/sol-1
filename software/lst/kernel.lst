0899   0502             syscall_io:
0900   0502 FD 0A FA 04   jmp [syscall_io_jmp + al]
0901   0506             ; bit7 is the Divisor Latch Access Bit (DLAB). It must be set high (logic 1) to access the Divisor Latches
0902   0506             ; of the Baud Generator during a Read or Write operation. It must be set low (logic 0) to access the Receiver
0903   0506             ; Buffer, the Transmitter Holding Register, or the Interrupt Enable Register.
0904   0506             syscall_io_uart_setup:
0905   0506 1D 4F 17      mov al, [sys_uart0_lcr]
0906   0509 8B 80         or al, $80                ; set DLAB access bit
0907   050B 3D 83 FF      mov [_UART0_LCR], al      ; 8 data, 1 stop, no parity by default
0908   050E 1D 52 17      mov al, [sys_uart0_div0]
0909   0511 3D 80 FF      mov [_UART0_DLAB_0], al   ; divisor latch byte 0
0910   0514 1D 53 17      mov al, [sys_uart0_div1]
0911   0517 3D 81 FF      mov [_UART0_DLAB_1], al   ; divisor latch byte 1      
0912   051A             
0913   051A 1D 4F 17      mov al, [sys_uart0_lcr]
0914   051D 87 7F         and al, $7F               ; clear DLAB access bit 
0915   051F F2 83 FF 03   mov byte[_UART0_LCR], 3      
