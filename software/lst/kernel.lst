1306   0781             ;------------------------------------------------------------------------------------------------------;
1307   0781             ; get path from a given directory dirID
1308   0781             ; pseudo code:
1309   0781             ;  fs_dir_id_to_path(int dirID, char *D){
1310   0781             ;    if(dirID == 0){
1311   0781             ;      reverse path in D;
1312   0781             ;      return;
1313   0781             ;    }
1314   0781             ;    else{
1315   0781             ;      copy directory name to end of D;
1316   0781             ;      add '/' to end of D;
1317   0781             ;      parentID = get parent directory ID;
1318   0781             ;      fs_dir_id_to_path(parentID, D);
1319   0781             ;    }
1320   0781             ;  }
1321   0781             ; A = dirID
1322   0781             ; D = generated path string pointer
1323   0781             ;------------------------------------------------------------------------------------------------------;
1324   0781             ; sample path: /usr/bin
1325   0781             fs_dir_id_to_path:
1326   0781 3B 1F 1B      mov d, filename
1327   0784 19 00         mov al, 0
1328   0786 3E            mov [d], al                     ; initialize path string 
1329   0787 14 B4 16      mov a, [current_dirID]
1330   078A 07 97 07      call fs_dir_id_to_path_E0
1331   078D 3B 1F 1B      mov d, filename
1332   0790 07 66 0F      call _strrev
1333   0793 07 7A 11      call _puts
1334   0796 06            sysret
1335   0797             fs_dir_id_to_path_E0:
1336   0797 07 B6 07      call get_dirname_from_dirID
1337   079A FD 4D C6 16   mov si, s_fslash
1338   079E FD 50         mov di, d
1339   07A0 07 E0 0F      call _strcat                    ; add '/' to end of path
1340   07A3 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1341   07A6 C6 B5 07      je fs_dir_id_to_path_root
1342   07A9 07 D3 07      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1343   07AC AF 20 00      cmp a, root_id               ; check if we are at the root directory
1344   07AF C6 B5 07      je fs_dir_id_to_path_root
1345   07B2 07 97 07      call fs_dir_id_to_path_E0     ; recursively call itself
1346   07B5             fs_dir_id_to_path_root:
1347   07B5 09            ret
1348   07B6             
1349   07B6             ;------------------------------------------------------------------------------------------------------;
1350   07B6             ; in_puts:
1351   07B6             ; A = directory ID
1352   07B6             ; out_puts:
1353   07B6             ; D = pointer to directory name string
1354   07B6             ;------------------------------------------------------------------------------------------------------;
1355   07B6             get_dirname_from_dirID:
1356   07B6 D7            push a
1357   07B7 D8            push b
1358   07B8 DA            push d
1359   07B9 27            mov b, a
1360   07BA 38 00 00      mov c, 0                      ; reset LBA to 0
1361   07BD 22 01         mov ah, $01                   ; disk read
1362   07BF 3B 9F 25      mov d, transient_area - 512
1363   07C2 07 38 04      call ide_read_sect            ; read directory
1364   07C5 07 66 0F      call _strrev                  ; reverse dir name before copying
1365   07C8 FD 4E         mov si, d
1366   07CA E7            pop d                         ; destination address = D value pushed at beginning
1367   07CB FD 50         mov di, d
1368   07CD 07 E0 0F      call _strcat                  ; copy filename to D
1369   07D0 E5            pop b
1370   07D1 E4            pop a
1371   07D2 09            ret
1372   07D3             
1373   07D3             ;------------------------------------------------------------------------------------------------------;
1374   07D3             ; in_puts:
1375   07D3             ; A = directory ID
1376   07D3             ; out_puts:
1377   07D3             ; A = parent directory ID
1378   07D3             ;------------------------------------------------------------------------------------------------------;
1379   07D3             get_parentID_from_dirID:
1380   07D3 D8            push b
1381   07D4 DA            push d
1382   07D5 27            mov b, a
1383   07D6 38 00 00      mov c, 0                      ; reset LBA to 0
1384   07D9 22 01         mov ah, $01                   ; disk read
1385   07DB 3B 9F 25      mov d, transient_area - 512
1386   07DE 07 38 04      call ide_read_sect            ; read directory
1387   07E1 16 40 00      mov a, [d + 64]               ; copy parent ID value to A
1388   07E4 E7            pop d
1389   07E5 E5            pop b
1390   07E6 09            ret
1391   07E7             
1392   07E7             ;------------------------------------------------------------------------------------------------------;
1393   07E7             ; get dirID from a given path string
1394   07E7             ; in_puts:
