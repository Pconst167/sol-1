0002   0000             ; Solarium - Sol-1 Homebrew Minicomputer Operating System Kernel.
0003   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0004   0000             
0005   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0006   0000             ; Memory Map
0007   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0008   0000             ; 0000    ROM BEGIN
0009   0000             ; ....
0010   0000             ; 7FFF    ROM END
0011   0000             ;
0012   0000             ; 8000    RAM begin
0013   0000             ; ....
0014   0000             ; F7FF    Stack root
0015   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0016   0000             
0017   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0018   0000             ; I/O MAP
0019   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0020   0000             ; FF80    UART 0    (16550)
0021   0000             ; FF90    UART 1    (16550)
0022   0000             ; FFA0    RTC       (M48T02)
0023   0000             ; FFB0    PIO 0     (8255)
0024   0000             ; FFC0    PIO 1     (8255)
0025   0000             ; FFD0    IDE       (Compact Flash / PATA)
0026   0000             ; FFE0    Timer     (8253)
0027   0000             ; FFF0    BIOS CONFIGURATION NV-RAM STORE AREA
0028   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
0029   0000             
0030   0000             ; SYSTEM CONSTANTS / EQUATIONS
0031   0000             _UART0_DATA       .equ $FF80            ; data
0032   0000             _UART0_DLAB_0     .equ $FF80            ; divisor latch low byte
0033   0000             _UART0_DLAB_1     .equ $FF81            ; divisor latch high byte
0034   0000             _UART0_IER        .equ $FF81            ; Interrupt enable register
0035   0000             _UART0_FCR        .equ $FF82            ; FIFO control register
0036   0000             _UART0_LCR        .equ $FF83            ; line control register
0037   0000             _UART0_LSR        .equ $FF85            ; line status register
0038   0000             
0039   0000             _UART1_DATA       .equ $FF90            ; data
0040   0000             _UART1_DLAB_0     .equ $FF90            ; divisor latch low byte
0041   0000             _UART1_DLAB_1     .equ $FF91            ; divisor latch high byte
0042   0000             _UART1_IER        .equ $FF91            ; Interrupt enable register
0043   0000             _UART1_FCR        .equ $FF92            ; FIFO control register
0044   0000             _UART1_LCR        .equ $FF93            ; line control register
0045   0000             _UART1_LSR        .equ $FF95            ; line status register
0046   0000             
0047   0000             _ide_BASE         .equ $FFD0            ; IDE BASE
0048   0000             _ide_R0           .equ _ide_BASE + 0    ; DATA PORT
0049   0000             _ide_R1           .equ _ide_BASE + 1    ; READ: ERROR CODE, WRITE: FEATURE
0050   0000             _ide_R2           .equ _ide_BASE + 2    ; NUMBER OF SECTORS TO TRANSFER
0051   0000             _ide_R3           .equ _ide_BASE + 3    ; SECTOR ADDRESS LBA 0 [0:7]
0052   0000             _ide_R4           .equ _ide_BASE + 4    ; SECTOR ADDRESS LBA 1 [8:15]
0053   0000             _ide_R5           .equ _ide_BASE + 5    ; SECTOR ADDRESS LBA 2 [16:23]
0054   0000             _ide_R6           .equ _ide_BASE + 6    ; SECTOR ADDRESS LBA 3 [24:27 (LSB)]
0055   0000             _ide_R7           .equ _ide_BASE + 7    ; READ: STATUS, WRITE: COMMAND
0056   0000             
0057   0000             _7SEG_DISPLAY     .equ $FFB0            ; BIOS POST CODE HEX DISPLAY (2 DIGITS)
0058   0000             _BIOS_POST_CTRL   .equ $FFB3            ; BIOS POST DISPLAY CONTROL REGISTER, 80h = As Output
0059   0000             _PIO_A            .equ $FFB0    
0060   0000             _PIO_B            .equ $FFB1
0061   0000             _PIO_C            .equ $FFB2
0062   0000             _PIO_CONTROL      .equ $FFB3            ; PIO CONTROL PORT
0063   0000             
0064   0000             _TIMER_C_0        .equ $FFE0            ; TIMER COUNTER 0
0065   0000             _TIMER_C_1        .equ $FFE1            ; TIMER COUNTER 1
0066   0000             _TIMER_C_2        .equ $FFE2            ; TIMER COUNTER 2
0067   0000             _TIMER_CTRL       .equ $FFE3            ; TIMER CONTROL REGISTER
0068   0000             
0069   0000             STACK_BEGIN       .equ $F7FF            ; beginning of stack
0070   0000             FIFO_SIZE         .equ (1024 * 4)
0071   0000             
0072   0000             TEXT_ORG     .equ $400
0073   0000             
0074   0000             
0075   0000             ; For the next iteration:
0076   0000             ; boot-sector(1) | kernel-sectors(32) | inode-bitmap | rawdata-bitmap | inode-table | raw-disk-data
0077   0000             ; inode-table format:
0078   0000             ;  file-type(f, d)
0079   0000             ;  permissons
0080   0000             ;  link-count
0081   0000             ;  filesize
0082   0000             ;  time-stamps
0083   0000             ;  15 data block pointers
0084   0000             ;  single-indirect pointer
0085   0000             ;
0086   0000             
0087   0000             ; FILE ENTRY ATTRIBUTES
0088   0000             ; filename (24)
0089   0000             ; attributes (1)       :|0|0|file_type(3bits)|x|w|r|
0090   0000             ; LBA (2)          : location of raw data for file entry, or dirID for directory entry
0091   0000             ; size (2)          : filesize
0092   0000             ; day (1)           
0093   0000             ; month (1)
0094   0000             ; year (1)
0095   0000             ; packet size = 32 bytes  : total packet size in bytes
0096   0000             ;
0097   0000             FST_ENTRY_SIZE          .equ 32  ; bytes
0098   0000             FST_FILES_PER_SECT      .equ (512 / FST_ENTRY_SIZE)
0099   0000             FST_FILES_PER_DIR       .equ (512 / FST_ENTRY_SIZE)
0100   0000             FST_NBR_DIRECTORIES     .equ 64
0101   0000                                     ; 1 sector for header, the rest is for the list of files/dirs
0102   0000             FST_SECTORS_PER_DIR     .equ (1 + (FST_ENTRY_SIZE * FST_FILES_PER_DIR / 512))    
0103   0000             FST_TOTAL_SECTORS       .equ (FST_SECTORS_PER_DIR * FST_NBR_DIRECTORIES)
0104   0000             FST_LBA_START           .equ 32
0105   0000             FST_LBA_END             .equ (FST_LBA_START + FST_TOTAL_SECTORS - 1)
0106   0000             
0107   0000             FS_NBR_FILES            .equ (FST_NBR_DIRECTORIES * FST_FILES_PER_DIR)
0108   0000             FS_SECTORS_PER_FILE     .equ 32         ; the first sector is always a header with a NULL parameter (first byte)
0109   0000                                                     ; so that we know which blocks are free or taken
0110   0000             FS_FILE_SIZE            .equ (FS_SECTORS_PER_FILE * 512)                  
0111   0000             FS_TOTAL_SECTORS        .equ (FS_NBR_FILES * FS_SECTORS_PER_FILE)
0112   0000             FS_LBA_START            .equ (FST_LBA_END + 1)
0113   0000             FS_LBA_END              .equ (FS_LBA_START + FS_NBR_FILES - 1)
0114   0000             
0115   0000             CF_CARD_LBA_SIZE        .equ $800       ; temporary small size
0116   0000             
0117   0000             ROOT_dirID:              .equ FST_LBA_START
0118   0000             
0119   0000             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
