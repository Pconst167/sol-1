0001   0000             ; ------------------------------------------------------------------------------------------------------------------;
0002   0000             ; Solarium - Sol-1 Homebrew Minicomputer Operating System Kernel.
0003   0000             ; ------------------------------------------------------------------------------------------------------------------;
0004   0000             ; Memory Map
0005   0000             ; ------------------------------------------------------------------------------------------------------------------;
0006   0000             ; 0000    ROM BEGIN
0007   0000             ; ....
0008   0000             ; 7FFF    ROM END
0009   0000             ;
0010   0000             ; 8000    RAM begin
0011   0000             ; ....
0012   0000             ; F7FF    Stack root
0013   0000             ; ------------------------------------------------------------------------------------------------------------------;
0014   0000             ; I/O MAP
0015   0000             ; ------------------------------------------------------------------------------------------------------------------;
0016   0000             ; FF80    UART 0    (16550)
0017   0000             ; FF90    UART 1    (16550)
0018   0000             ; FFA0    RTC       (M48T02)
0019   0000             ; FFB0    PIO 0     (8255)
0020   0000             ; FFC0    PIO 1     (8255)
0021   0000             ; FFD0    IDE       (Compact Flash / PATA)
0022   0000             ; FFE0    Timer     (8253)
0023   0000             ; FFF0    BIOS CONFIGURATION NV-RAM STORE AREA
0024   0000             ; ------------------------------------------------------------------------------------------------------------------;
0025   0000             
0026   0000             ; ------------------------------------------------------------------------------------------------------------------;
0027   0000             ; System Constants
0028   0000             ; ------------------------------------------------------------------------------------------------------------------;
0029   0000             _UART0_DATA       .equ $FF80            ; data
0030   0000             _UART0_DLAB_0     .equ $FF80            ; divisor latch low byte
0031   0000             _UART0_DLAB_1     .equ $FF81            ; divisor latch high byte
0032   0000             _UART0_IER        .equ $FF81            ; Interrupt enable register
0033   0000             _UART0_FCR        .equ $FF82            ; FIFO control register
0034   0000             _UART0_LCR        .equ $FF83            ; line control register
0035   0000             _UART0_LSR        .equ $FF85            ; line status register
0036   0000             
0037   0000             _UART1_DATA       .equ $FF90            ; data
0038   0000             _UART1_DLAB_0     .equ $FF90            ; divisor latch low byte
0039   0000             _UART1_DLAB_1     .equ $FF91            ; divisor latch high byte
0040   0000             _UART1_IER        .equ $FF91            ; Interrupt enable register
0041   0000             _UART1_FCR        .equ $FF92            ; FIFO control register
0042   0000             _UART1_LCR        .equ $FF93            ; line control register
0043   0000             _UART1_LSR        .equ $FF95            ; line status register
0044   0000             
0045   0000             XON               .equ $11
0046   0000             XOFF              .equ $13
0047   0000             
0048   0000             _ide_BASE         .equ $FFD0            ; IDE BASE
0049   0000             _ide_R0           .equ _ide_BASE + 0    ; DATA PORT
0050   0000             _ide_R1           .equ _ide_BASE + 1    ; READ: ERROR CODE, WRITE: FEATURE
0051   0000             _ide_R2           .equ _ide_BASE + 2    ; NUMBER OF SECTORS TO TRANSFER
0052   0000             _ide_R3           .equ _ide_BASE + 3    ; SECTOR ADDRESS LBA 0 [0:7]
0053   0000             _ide_R4           .equ _ide_BASE + 4    ; SECTOR ADDRESS LBA 1 [8:15]
0054   0000             _ide_R5           .equ _ide_BASE + 5    ; SECTOR ADDRESS LBA 2 [16:23]
0055   0000             _ide_R6           .equ _ide_BASE + 6    ; SECTOR ADDRESS LBA 3 [24:27 (LSB)]
0056   0000             _ide_R7           .equ _ide_BASE + 7    ; READ: STATUS, WRITE: COMMAND
0057   0000             
0058   0000             _7SEG_DISPLAY     .equ $FFB0            ; BIOS POST CODE HEX DISPLAY (2 DIGITS)
0059   0000             _BIOS_POST_CTRL   .equ $FFB3            ; BIOS POST DISPLAY CONTROL REGISTER, 80h = As Output
0060   0000             _PIO_A            .equ $FFB0    
0061   0000             _PIO_B            .equ $FFB1
0062   0000             _PIO_C            .equ $FFB2
0063   0000             _PIO_CONTROL      .equ $FFB3            ; PIO CONTROL PORT
0064   0000             
0065   0000             _TIMER_C_0        .equ $FFE0            ; TIMER COUNTER 0
0066   0000             _TIMER_C_1        .equ $FFE1            ; TIMER COUNTER 1
0067   0000             _TIMER_C_2        .equ $FFE2            ; TIMER COUNTER 2
0068   0000             _TIMER_CTRL       .equ $FFE3            ; TIMER CONTROL REGISTER
0069   0000             
0070   0000             STACK_BEGIN       .equ $F7FF            ; beginning of stack
0071   0000             FIFO_SIZE         .equ 1024
0072   0000             
0073   0000             TEXT_ORG          .equ $400
0074   0000             ; ------------------------------------------------------------------------------------------------------------------;
0075   0000             
0076   0000             
0077   0000             ; For the next iteration:
0078   0000             ; boot-sector(1) | kernel-sectors(32) | inode-bitmap | rawdata-bitmap | inode-table | raw-disk-data
0079   0000             ; inode-table format:
0080   0000             ;  file-type(f, d)
0081   0000             ;  permissons
0082   0000             ;  link-count
0083   0000             ;  filesize
0084   0000             ;  time-stamps
0085   0000             ;  15 data block pointers
0086   0000             ;  single-indirect pointer
0087   0000             
0088   0000             ; FILE ENTRY ATTRIBUTES
0089   0000             ; filename (24)
0090   0000             ; attributes (1)       :|0|0|file_type(3bits)|x|w|r|
0091   0000             ; LBA (2)              : location of raw data for file entry, or dirID for directory entry
0092   0000             ; size (2)             : filesize
0093   0000             ; day (1)           
0094   0000             ; month (1)
0095   0000             ; year (1)
0096   0000             ; packet size = 32 bytes  : total packet size in bytes
0097   0000             
0098   0000             FST_ENTRY_SIZE          .equ 32  ; bytes
0099   0000             FST_FILES_PER_SECT      .equ (512 / FST_ENTRY_SIZE)
0100   0000             FST_FILES_PER_DIR       .equ (512 / FST_ENTRY_SIZE)
0101   0000             FST_NBR_DIRECTORIES     .equ 64
0102   0000                                     ; 1 sector for header, the rest is for the list of files/dirs
0103   0000             FST_SECTORS_PER_DIR     .equ (1 + (FST_ENTRY_SIZE * FST_FILES_PER_DIR / 512))    
0104   0000             FST_TOTAL_SECTORS       .equ (FST_SECTORS_PER_DIR * FST_NBR_DIRECTORIES)
0105   0000             FST_LBA_START           .equ 32
0106   0000             FST_LBA_END             .equ (FST_LBA_START + FST_TOTAL_SECTORS - 1)
0107   0000             
0108   0000             FS_NBR_FILES            .equ (FST_NBR_DIRECTORIES * FST_FILES_PER_DIR)
0109   0000             FS_SECTORS_PER_FILE     .equ 32         ; the first sector is always a header with a NULL parameter (first byte)
0110   0000                                                     ; so that we know which blocks are free or taken
0111   0000             FS_FILE_SIZE            .equ (FS_SECTORS_PER_FILE * 512)                  
0112   0000             FS_TOTAL_SECTORS        .equ (FS_NBR_FILES * FS_SECTORS_PER_FILE)
0113   0000             FS_LBA_START            .equ (FST_LBA_END + 1)
0114   0000             FS_LBA_END              .equ (FS_LBA_START + FS_NBR_FILES - 1)
0115   0000             
0116   0000             root_id:                .equ FST_LBA_START
0117   0000             
0118   0000             ; ------------------------------------------------------------------------------------------------------------------;
0119   0000             ; GLOBAL SYSTEM VARIABLES
0120   0000             ; ------------------------------------------------------------------------------------------------------------------;
0121   0000             
0122   0000             ; ------------------------------------------------------------------------------------------------------------------;
0123   0000             ; IRQ Table
0124   0000             ; Highest priority at lowest address
0125   0000             ; ------------------------------------------------------------------------------------------------------------------;
0126   0000 3A 00       .dw int_0
0127   0002 3B 00       .dw int_1
0128   0004 3C 00       .dw int_2
0129   0006 3D 00       .dw int_3
0130   0008 3E 00       .dw int_4
0131   000A 3F 00       .dw int_5
0132   000C 40 00       .dw int_6
0133   000E 8C 00       .dw int_7
0134   0010             
0135   0010             ; ------------------------------------------------------------------------------------------------------------------;
0136   0010             ; Reset Vector
0137   0010             ; ------------------------------------------------------------------------------------------------------------------;
0138   0010 39 0E       .dw kernel_reset_vector
0139   0012             
0140   0012             ; ------------------------------------------------------------------------------------------------------------------;
0141   0012             ; Exception Vector Table
0142   0012             ; Total of 7 entries, starting at address $0012
0143   0012             ; ------------------------------------------------------------------------------------------------------------------;
0144   0012 C9 01       .dw trap_privilege
0145   0014 E6 02       .dw trap_div_zero
0146   0016 F3 02       .dw trap_undef_opcode
0147   0018 00 00       .dw 0
0148   001A 00 00       .dw 0
0149   001C 00 00       .dw 0
0150   001E 00 00       .dw 0
0151   0020             
0152   0020             ; ------------------------------------------------------------------------------------------------------------------;
0153   0020             ; System Call Vector Table
0154   0020             ; Starts at address $0020
0155   0020             ; ------------------------------------------------------------------------------------------------------------------;
0156   0020 D5 01       .dw syscall_break
0157   0022 F4 02       .dw syscall_rtc
0158   0024 2E 04       .dw syscall_ide
0159   0026 09 05       .dw syscall_io
0160   0028 10 06       .dw syscall_file_system
0161   002A 10 0F       .dw syscall_spawn_proc
0162   002C 8E 01       .dw syscall_list_procs
0163   002E 26 03       .dw syscall_datetime
0164   0030 4A 01       .dw syscall_reboot
0165   0032 DA 0E       .dw syscall_pause_proc
0166   0034 56 01       .dw syscall_resume_proc
0167   0036 97 0E       .dw syscall_terminate_proc
0168   0038 1E 01       .dw syscall_system
0169   003A             
0170   003A             ; ------------------------------------------------------------------------------------------------------------------;
0171   003A             ; System Call Aliases
0172   003A             ; ------------------------------------------------------------------------------------------------------------------;
0173   003A             sys_break            .equ 0
0174   003A             sys_rtc              .equ 1
0175   003A             sys_ide              .equ 2
0176   003A             sys_io               .equ 3
0177   003A             sys_filesystem       .equ 4
0178   003A             sys_spawn_proc       .equ 5
0179   003A             sys_list             .equ 6
0180   003A             sys_datetime         .equ 7
0181   003A             sys_reboot           .equ 8
0182   003A             sys_pause_proc       .equ 9
0183   003A             sys_resume_proc      .equ 10
0184   003A             sys_terminate_proc   .equ 11
0185   003A             sys_system           .equ 12
0186   003A             
0187   003A             ; ------------------------------------------------------------------------------------------------------------------;
0188   003A             ; Alias Exports
0189   003A             ; ------------------------------------------------------------------------------------------------------------------;
0190   003A             .export TEXT_ORG
0191   003A             .export sys_break
0192   003A             .export sys_ide
0193   003A             .export sys_io
0194   003A             .export sys_filesystem
0195   003A             .export sys_spawn_proc
0196   003A             .export sys_list
0197   003A             .export sys_rtc
0198   003A             .export sys_datetime
0199   003A             .export sys_reboot
0200   003A             .export sys_pause_proc
0201   003A             .export sys_resume_proc
0202   003A             .export sys_terminate_proc
0203   003A             .export sys_system
0204   003A             
0205   003A             ; ------------------------------------------------------------------------------------------------------------------;
0206   003A             ; IRQs' Code Block
0207   003A             ; ------------------------------------------------------------------------------------------------------------------;
0208   003A             int_0:
0209   003A 06            sysret
0210   003B             int_1:
0211   003B 06            sysret
0212   003C             int_2:
0213   003C 06            sysret
0214   003D             int_3:
0215   003D 06            sysret
0216   003E             int_4:
0217   003E 06            sysret
0218   003F             int_5:
0219   003F 06            sysret
0220   0040             
0221   0040             ; ------------------------------------------------------------------------------------------------------------------;
0222   0040             ; Process Swapping
0223   0040             ; ------------------------------------------------------------------------------------------------------------------;
0224   0040             int_6:  
0225   0040 4B            pusha ; save all registers into kernel stack
0226   0041 22 00         mov ah, 0
0227   0043 1D 0B 17      mov al, [active_proc_index]
0228   0046 FD 99         shl a              ; x2
0229   0048 B7 8D 0F      mov a, [proc_table_convert + a]  ; get process state start index
0230   004B 4F            mov di, a
0231   004C 48            mov a, sp
0232   004D 77            inc a
0233   004E 4D            mov si, a
0234   004F 38 14 00      mov c, 20
0235   0052 FD F5         rep movsb          ; save process state!
0236   0054             ; restore kernel stack position to point before interrupt arrived
0237   0054 51 14 00      add sp, 20
0238   0057             ; now load next process in queue
0239   0057 1D 0B 17      mov al, [active_proc_index]
0240   005A 31 0A 17      mov bl, [nbr_active_procs]
0241   005D BA            cmp al, bl
0242   005E C6 65 00      je int6_cycle_back
0243   0061 7A            inc al            ; next process is next in the series
0244   0062 0A 67 00      jmp int6_continue
0245   0065             int6_cycle_back:
0246   0065 19 01         mov al, 1        ; next process = process 1
0247   0067             int6_continue:
0248   0067 3D 0B 17      mov [active_proc_index], al    ; set next active proc
0249   006A             
0250   006A             ; calculate LUT entry for next process
0251   006A 22 00         mov ah, 0
0252   006C FD 99         shl a              ; x2
0253   006E B7 8D 0F      mov a, [proc_table_convert + a]    ; get process state start index  
0254   0071               
0255   0071 4D            mov si, a            ; source is proc state block
0256   0072 48            mov a, sp
0257   0073 5F 13 00      sub a, 19
0258   0076 4F            mov di, a            ; destination is kernel stack
0259   0077             ; restore SP
0260   0077 7D            dec a
0261   0078 47            mov sp, a
0262   0079 38 14 00      mov c, 20
0263   007C FD F5         rep movsb
0264   007E             ; set VM process
0265   007E 1D 0B 17      mov al, [active_proc_index]
0266   0081 01            setptb
0267   0082 F2 E0 FF 00   mov byte[_TIMER_C_0], 0        ; load counter 0 low byte
0268   0086 F2 E0 FF 10   mov byte[_TIMER_C_0], $10        ; load counter 0 high byte
0269   008A 4C            popa
0270   008B 06            sysret
0271   008C             
0272   008C             ; ------------------------------------------------------------------------------------------------------------------;
0273   008C             ; UART0 Interrupt
0274   008C             ; ------------------------------------------------------------------------------------------------------------------;
0275   008C             int_7:
0276   008C D7            push a
0277   008D DA            push d
0278   008E E1            pushf
0279   008F 14 10 17      mov a, [fifo_in]
0280   0092 3C            mov d, a
0281   0093 31 80 FF      mov bl, [_UART0_DATA]  ; get character
0282   0096 C1 03         cmp bl, $03        ; CTRL-C
0283   0098 C6 0A 01      je CTRLC
0284   009B C1 1A         cmp bl, $1A        ; CTRL-Z
0285   009D C6 10 01      je CTRLZ
0286   00A0 FD 3E         mov [d], bl        ; add to fifo
0287   00A2 77            inc a
0288   00A3 42 10 17      mov [fifo_in], a
0289   00A6 AF FF 21      cmp a, fifo + FIFO_SIZE
0290   00A9 C6 B0 00      je int_7_xoff
0291   00AC             int_7_continue1:  
0292   00AC EE            popf
0293   00AD E7            pop d
0294   00AE E4            pop a  
0295   00AF 06            sysret
0296   00B0             
0297   00B0             int_7_xoff:    
0298   00B0 22 13         mov ah, XOFF  
0299   00B2 07 B6 10      call _putchar
0300   00B5 22 0A         mov ah, $0A
0301   00B7 07 B6 10      call _putchar
0302   00BA 22 3E         mov ah, '>'
0303   00BC 07 B6 10      call _putchar
0304   00BF 22 20         mov ah, ' '
0305   00C1 07 B6 10      call _putchar
0306   00C4 29 12 17      mov b, [fifo_out]
0307   00C7 07 3A 12      call print_u16x
0308   00CA 22 20         mov ah, ' '
0309   00CC 07 B6 10      call _putchar
0310   00CF 29 10 17      mov b, [fifo_in]
0311   00D2 07 3A 12      call print_u16x
0312   00D5 22 0A         mov ah, $0A
0313   00D7 07 B6 10      call _putchar
0314   00DA 0A AC 00      jmp int_7_continue1
0315   00DD             
0316   00DD             ; condition for 'fifo-full':
0317   00DD             ; fifo_in == fifo + FIFO_SIZE
0318   00DD             ; condition for fifo recovery:
0319   00DD             ; fifo must be full and
0320   00DD             ; fifo_out == fifo_in
0321   00DD             
0322   00DD 0A 57 61 72 s_int_7_xoff: .db "\nWarning: FIFO is full. Sending XOFF. Ptrs: ", 0
0322   00E1 6E 69 6E 67 
0322   00E5 3A 20 46 49 
0322   00E9 46 4F 20 69 
0322   00ED 73 20 66 75 
0322   00F1 6C 6C 2E 20 
0322   00F5 53 65 6E 64 
0322   00F9 69 6E 67 20 
0322   00FD 58 4F 46 46 
0322   0101 2E 20 50 74 
0322   0105 72 73 3A 20 
0322   0109 00 
0323   010A             
0324   010A             CTRLC:
0325   010A 51 05 00      add sp, 5
0326   010D 0A 97 0E      jmp syscall_terminate_proc
0327   0110             CTRLZ:
0328   0110 EE            popf
0329   0111 E7            pop d
0330   0112 E4            pop a
0331   0113 0A DA 0E      jmp syscall_pause_proc    ; pause current process and go back to the shell
0332   0116             
0333   0116             ; ------------------------------------------------------------------------------------------------------------------;
0334   0116             ; System Syscalls
0335   0116             ; ------------------------------------------------------------------------------------------------------------------;
0336   0116             system_jmptbl:
0337   0116 48 01         .dw system_uname
0338   0118 49 01         .dw system_whoami
0339   011A 45 01         .dw system_setparam
0340   011C 22 01         .dw system_bootloader_install
0341   011E             syscall_system:
0342   011E FD 0A 16 01   jmp [system_jmptbl + al]
0343   0122             
0344   0122             ; kernel LBA address in 'b'
0345   0122             system_bootloader_install:
0346   0122 D8            push b
0347   0123 26 00 00      mov b, 0
0348   0126 38 00 00      mov c, 0
0349   0129 22 01         mov ah, $01                 ; 1 sector
0350   012B 3B FF 23      mov d, transient_area
0351   012E 07 78 04      call ide_read_sect          ; read sector
0352   0131 E5            pop b
0353   0132 FD 44 FE 01   mov [d + 510], b            ; update LBA address
0354   0136 26 00 00      mov b, 0
0355   0139 38 00 00      mov c, 0
0356   013C 22 01         mov ah, $01                 ; 1 sector
0357   013E 3B FF 23      mov d, transient_area
0358   0141 07 9E 04      call ide_write_sect         ; write sector
0359   0144 06            sysret
0360   0145             
0361   0145             ; param register address in register d
0362   0145             ; param value in register bl
0363   0145             system_setparam:
0364   0145 FD 3E         mov [d], bl
0365   0147 06            sysret
0366   0148             
0367   0148             system_uname:
0368   0148 06            sysret
0369   0149             
0370   0149             system_whoami:
0371   0149 06            sysret
0372   014A             
0373   014A             ; REBOOT SYSTEM
0374   014A             syscall_reboot:
0375   014A FD D7 FF FF   push word $FFFF 
0376   014E FD DB 00      push byte %00000000             ; dma_ack = 0, interrupts disabled, mode = supervisor, paging = off, halt=0, display_reg_load=0, dir=0
0377   0151 FD D7 C0 01   push word BIOS_RESET_VECTOR    ; and then push RESET VECTOR of the shell to the stack
0378   0155 06            sysret
0379   0156             
0380   0156             ;------------------------------------------------------------------------------------------------------;;
0381   0156             ; switch to another process
0382   0156             ; inputs:
0383   0156             ; AL = new process number
0384   0156             ;------------------------------------------------------------------------------------------------------;;
0385   0156             syscall_resume_proc:
0386   0156 FD 78         mov g, a                            ; save the process number
0387   0158 4B            pusha                               ; save all registers into kernel stack
0388   0159 22 00         mov ah, 0
0389   015B 1D 0B 17      mov al, [active_proc_index]
0390   015E FD 99         shl a              ; x2
0391   0160 B7 8D 0F      mov a, [proc_table_convert + a]     ; get process state start index
0392   0163 4F            mov di, a
0393   0164 48            mov a, sp
0394   0165 77            inc a
0395   0166 4D            mov si, a
0396   0167 38 14 00      mov c, 20
0397   016A FD F5         rep movsb                           ; save process state!
0398   016C             ; restore kernel stack position to point before interrupt arrived
0399   016C 51 14 00      add sp, 20
0400   016F             ; now load the new process number!
0401   016F FD 12         mov a, g                            ; retrieve the process number argument that was saved in the beginning
0402   0171 3D 0B 17      mov [active_proc_index], al         ; set new active proc
0403   0174             ; calculate LUT entry for next process
0404   0174 22 00         mov ah, 0
0405   0176 FD 99         shl a                               ; x2
0406   0178 B7 8D 0F      mov a, [proc_table_convert + a]     ; get process state start index  
0407   017B 4D            mov si, a                           ; source is proc state block
0408   017C 48            mov a, sp
0409   017D 5F 13 00      sub a, 19
0410   0180 4F            mov di, a                           ; destination is kernel stack
0411   0181             ; restore SP
0412   0181 7D            dec a
0413   0182 47            mov sp, a
0414   0183 38 14 00      mov c, 20
0415   0186 FD F5         rep movsb
0416   0188             ; set VM process
0417   0188 1D 0B 17      mov al, [active_proc_index]
0418   018B 01            setptb
0419   018C 4C            popa
0420   018D 06            sysret
0421   018E             
0422   018E             syscall_list_procs:
0423   018E 3B 30 17      mov d, s_ps_header
0424   0191 07 E2 11      call _puts
0425   0194 3B 70 19      mov d, proc_availab_table + 1
0426   0197 38 01 00      mov c, 1
0427   019A             list_procs_L0:  
0428   019A BD 01         cmp byte[d], 1
0429   019C C7 C0 01      jne list_procs_next
0430   019F 2D            mov b, d
0431   01A0 61 6F 19      sub b, proc_availab_table
0432   01A3 FD 9F 05      shl b, 5
0433   01A6 DA            push d
0434   01A7 D8            push b
0435   01A8 28            mov b, c
0436   01A9 07 7E 12      call print_u8x
0437   01AC 22 20         mov ah, ' '
0438   01AE 07 B6 10      call _putchar
0439   01B1 07 B6 10      call _putchar
0440   01B4 E5            pop b
0441   01B5 74            mov d, b
0442   01B6 58 7F 19      add d, proc_names
0443   01B9 07 E2 11      call _puts
0444   01BC 07 8F 11      call printnl
0445   01BF E7            pop d
0446   01C0             list_procs_next:
0447   01C0 79            inc d
0448   01C1 78            inc c
0449   01C2 C2 09 00      cmp c, 9
0450   01C5 C7 9A 01      jne list_procs_L0
0451   01C8             list_procs_end:
0452   01C8 06            sysret
0453   01C9             
0454   01C9             ; ------------------------------------------------------------------------------------------------------------------;
0455   01C9             ; Exceptions' Code Block
0456   01C9             ; ------------------------------------------------------------------------------------------------------------------;
0457   01C9             ; Privilege
0458   01C9             ; ------------------------------------------------------------------------------------------------------------------;
0459   01C9             trap_privilege:
0460   01C9 0A 4A 01      jmp syscall_reboot
0461   01CC DA            push d
0462   01CD 3B 72 17      mov d, s_priviledge
0463   01D0 07 E2 11      call _puts
0464   01D3 E7            pop d
0465   01D4 06            sysret
0466   01D5             
0467   01D5             ; ------------------------------------------------------------------------------------------------------------------;
0468   01D5             ; Breakpoint
0469   01D5             ; IMPORTANT: values in the stack are being pushed in big endian. i.e.: MSB at low address
0470   01D5             ; and LSB at high address. *** NEED TO CORRECT THIS IN THE MICROCODE and make it little endian again ***
0471   01D5             ; ------------------------------------------------------------------------------------------------------------------;
0472   01D5             syscall_break:
0473   01D5 4B            pusha
0474   01D6             syscall_break_prompt:
0475   01D6 3B 90 02      mov d, s_break1
0476   01D9 07 E2 11      call _puts
0477   01DC 07 8F 11      call printnl
0478   01DF 07 DC 12      call scan_u16d
0479   01E2 AF 00 00      cmp a, 0
0480   01E5 C6 F0 01      je syscall_break_regs
0481   01E8 AF 01 00      cmp a, 1
0482   01EB C6 13 02      je syscall_break_mem
0483   01EE             syscall_break_end:  
0484   01EE 4C            popa
0485   01EF 06            sysret
0486   01F0             syscall_break_regs:
0487   01F0 48            mov a, sp
0488   01F1 53 0E 00      add a, 14               ; back-track 7 registers
0489   01F4 3C            mov d, a
0490   01F5 3A 07         mov cl, 7
0491   01F7             syscall_regs_L0:
