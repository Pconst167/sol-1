2687   18B3             ; ************************************************************
2688   18B3             ; GET HEX FILE
2689   18B3             ; di = destination address
2690   18B3             ; return length in bytes in C
2691   18B3             ; ************************************************************
2692   18B3             _load_hex:
2693   18B3 D2            push bp
2694   18B4 9B            mov bp, sp
2695   18B5 D7            push a
2696   18B6 D8            push b
2697   18B7 DA            push d
2698   18B8 E2            push si
2699   18B9 E3            push di
2700   18BA 52 00 80      sub sp, $8000      ; string data block
2701   18BD 38 00 00      mov c, 0
2702   18C0 48            mov a, sp
2703   18C1 77            inc a
2704   18C2 3C            mov d, a          ; start of string data block
2705   18C3 07 32 01      call _gets        ; get program string
2706   18C6 4D            mov si, a
2707   18C7             __load_hex_loop:
2708   18C7 F6            lodsb             ; load from [SI] to AL
2709   18C8 B9 00         cmp al, 0         ; check if ASCII 0
2710   18CA C6 D8 18      jz __load_hex_ret
2711   18CD 36            mov bh, al
2712   18CE F6            lodsb
2713   18CF 2F            mov bl, al
2714   18D0 07 E1 00      call _atoi        ; convert ASCII byte in B to int (to AL)
2715   18D3 F7            stosb             ; store AL to [DI]
2716   18D4 78            inc c
2717   18D5 0A C7 18      jmp __load_hex_loop
2718   18D8             __load_hex_ret:
2719   18D8 51 00 80      add sp, $8000
2720   18DB F0            pop di
2721   18DC EF            pop si
2722   18DD E7            pop d
2723   18DE E5            pop b
2724   18DF E4            pop a
2725   18E0 9C            mov sp, bp
2726   18E1 F1            pop bp
2727   18E2 09            ret
2728   18E3             
2729   18E3             ; ************************************************************
2730   18E3             ; GET HEX FILE WITHOUT ECHO
2731   18E3             ; di = destination address
2732   18E3             ; return length in bytes in C
2733   18E3             ; ************************************************************
2734   18E3             _load_hex_sil:
2735   18E3 D2            push bp
2736   18E4 9B            mov bp, sp
2737   18E5 D7            push a
2738   18E6 D8            push b
2739   18E7 DA            push d
2740   18E8 E2            push si
2741   18E9 E3            push di
2742   18EA 52 00 80      sub sp, $8000      ; string data block
2743   18ED 38 00 00      mov c, 0
2744   18F0 48            mov a, sp
2745   18F1 77            inc a
2746   18F2 3C            mov d, a          ; start of string data block
2747   18F3 07 D9 01      call _gets_sil        ; get program string silently
2748   18F6 4D            mov si, a
2749   18F7             __load_hex_sil_loop:
2750   18F7 F6            lodsb             ; load from [SI] to AL
2751   18F8 B9 00         cmp al, 0         ; check if ASCII 0
2752   18FA C6 08 19      jz __load_hex_sil_ret
2753   18FD 36            mov bh, al
2754   18FE F6            lodsb
2755   18FF 2F            mov bl, al
2756   1900 07 E1 00      call _atoi        ; convert ASCII byte in B to int (to AL)
2757   1903 F7            stosb             ; store AL to [DI]
2758   1904 78            inc c
2759   1905 0A F7 18      jmp __load_hex_sil_loop
2760   1908             __load_hex_sil_ret:
2761   1908 51 00 80      add sp, $8000
2762   190B F0            pop di
2763   190C EF            pop si
2764   190D E7            pop d
2765   190E E5            pop b
2766   190F E4            pop a
2767   1910 9C            mov sp, bp
2768   1911 F1            pop bp
2769   1912 09            ret
2770   1913             
2771   1913             ; synopsis: look insIDE a certain DIRECTORY for files/directories
2772   1913             ; BEFORE CALLING THIS FUNCTION, CD INTO REQUIRED DIRECTORY
2773   1913             ; for each entry insIDE DIRECTORY:
2774   1913             ;  if entry is a file:
2775   1913             ;    compare filename to searched filename
2776   1913             ;    if filenames are the same, print filename
2777   1913             ;  else if entry is a directory:
2778   1913             ;    cd to the given directory
2779   1913             ;    recursively call cmd_find
2780   1913             ;    cd outsIDE previous directory
2781   1913             ;  if current entry == last entry, return
2782   1913             ; endfor
2783   1913             f_find:
2784   1913 09            ret
