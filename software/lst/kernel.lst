0641   02F4 1B            mov al, bl              ; get data back
0642   02F5 F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0643   02F9 3E            mov [d], al             ; set data
0644   02FA F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0645   02FE EA            pop bl
0646   02FF E7            pop d
0647   0300 E8            pop al
0648   0301 06            sysret
