0736   03DB 23 04         .dw ide_write_sect_wrapper
0737   03DD             syscall_ide:
0738   03DD DD            push bl
0739   03DE 31 65 16      mov bl, [sys_debug_mode]
0740   03E1               ; debug block
0741   03E1 C1 00         cmp bl, 0
