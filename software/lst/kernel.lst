0985   0563             ;------------------------------------------------------------------------------------------------------;
0986   0563             ; FILE SYSTEM DATA
0987   0563             ;------------------------------------------------------------------------------------------------------;
0988   0563             ; infor for : IDE SERVICES INTERRUPT
0989   0563             ; IDE read/write 512-byte sector
0990   0563             ; al = option
0991   0563             ; user buffer pointer in D
0992   0563             ; AH = number of sectors
0993   0563             ; CB = LBA bytes 3..0  
0994   0563             ;------------------------------------------------------------------------------------------------------;
0995   0563             ; FILE SYSTEM DATA STRUCTURE
0996   0563             ;------------------------------------------------------------------------------------------------------;
0997   0563             ; for a directory we have the header first, followed by metadata
0998   0563             ; header 1 sector (512 bytes)
0999   0563             ; metadata 1 sector (512 bytes)
1000   0563             ; HEADER ENTRIES:
1001   0563             ; filename (64)
1002   0563             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1003   0563             ;
1004   0563             ; metadata entries:
1005   0563             ; filename (24)
1006   0563             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1007   0563             ; LBA (2)
1008   0563             ; size (2)
1009   0563             ; day (1)
1010   0563             ; month (1)
1011   0563             ; year (1)
1012   0563             ; packet size = 32 bytes
1013   0563             ;
1014   0563             ; first directory on disk is the root directory '/'
1015   0563             file_system_jmptbl:
1016   0563 CE 05         .dw fs_mkfs                   ; 0
1017   0565 00 00         .dw 0                         ; 1
1018   0567 30 06         .dw fs_mkdir                  ; 2
1019   0569 A9 09         .dw fs_cd                     ; 3
1020   056B B1 09         .dw fs_ls                     ; 4
1021   056D 00 00         .dw 0                  ; 5
1022   056F 63 0B         .dw fs_mkbin                  ; 6
1023   0571 2A 0C         .dw fs_pwd                    ; 7
1024   0573 47 0C         .dw fs_cat                    ; 8
1025   0575 A3 0C         .dw fs_rmdir                  ; 9
1026   0577 FF 0C         .dw fs_rm                     ; 10
1027   0579 BE 0A         .dw fs_starcom                ; 11
1028   057B 00 00         .dw 0                         ; 12
1029   057D 00 00         .dw 0                         ; 13
1030   057F D6 05         .dw fs_chmod                  ; 14
1031   0581 67 0D         .dw fs_mv                     ; 15
1032   0583 CF 05         .dw fs_cd_root                ; 16
1033   0585 A5 09         .dw fs_get_curr_dirID         ; 17
1034   0587 81 07         .dw fs_dir_id_to_path         ; 18
1035   0589 E7 07         .dw fs_path_to_dir_id_user    ; 19
1036   058B 01 09         .dw fs_load_from_path_user    ; 20  
1037   058D 71 08         .dw fs_filepath_exists_user   ; 21
