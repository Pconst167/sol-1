0213   0811 B9 03         cmp al, $03        ; CTRL-C
0214   0813 C6 AA 08      je CTRLC
0215   0816 B9 1A         cmp al, $1A        ; CTRL-Z
0216   0818 C6 B0 08      je CTRLZ
0217   081B 3E            mov [d], al        ; add to fifo
0218   081C 14 1B 19      mov a, [fifo_pi]
0219   081F 77            inc a
0220   0820 AF 1A 32      cmp a, fifo + FIFO_SIZE         ; check if pointer reached the end of the fifo
0221   0823 C7 29 08      jne int_0_continue
0222   0826 10 1A 22      mov a, fifo  
0223   0829             int_0_continue:  
0224   0829 42 1B 19      mov [fifo_pi], a      ; update fifo pointer
0225   082C EE            popf
