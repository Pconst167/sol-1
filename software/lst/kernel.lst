0997   057C             ;------------------------------------------------------------------------------------------------------;
0998   057C             ; FILE SYSTEM DATA
0999   057C             ;------------------------------------------------------------------------------------------------------;
1000   057C             ; infor for : IDE SERVICES INTERRUPT
1001   057C             ; IDE read/write 512-byte sector
1002   057C             ; al = option
1003   057C             ; user buffer pointer in D
1004   057C             ; AH = number of sectors
1005   057C             ; CB = LBA bytes 3..0  
1006   057C             ;------------------------------------------------------------------------------------------------------;
1007   057C             ; FILE SYSTEM DATA STRUCTURE
1008   057C             ;------------------------------------------------------------------------------------------------------;
1009   057C             ; for a directory we have the header first, followed by metadata
1010   057C             ; header 1 sector (512 bytes)
1011   057C             ; metadata 1 sector (512 bytes)
1012   057C             ; HEADER ENTRIES:
1013   057C             ; filename (64)
1014   057C             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1015   057C             ;
1016   057C             ; metadata entries:
1017   057C             ; filename (24)
1018   057C             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1019   057C             ; LBA (2)
1020   057C             ; size (2)
1021   057C             ; day (1)
1022   057C             ; month (1)
1023   057C             ; year (1)
1024   057C             ; packet size = 32 bytes
1025   057C             ;
1026   057C             ; first directory on disk is the root directory '/'
1027   057C             file_system_jmptbl:
1028   057C E7 05         .dw fs_mkfs                   ; 0
1029   057E 00 00         .dw 0                         ; 1
1030   0580 49 06         .dw fs_mkdir                  ; 2
1031   0582 C2 09         .dw fs_cd                     ; 3
1032   0584 CA 09         .dw fs_ls                     ; 4
1033   0586 00 00         .dw 0                  ; 5
1034   0588 7C 0B         .dw fs_mkbin                  ; 6
1035   058A 43 0C         .dw fs_pwd                    ; 7
1036   058C 60 0C         .dw fs_cat                    ; 8
1037   058E BC 0C         .dw fs_rmdir                  ; 9
1038   0590 18 0D         .dw fs_rm                     ; 10
1039   0592 D7 0A         .dw fs_starcom                ; 11
1040   0594 00 00         .dw 0                         ; 12
1041   0596 00 00         .dw 0                         ; 13
1042   0598 EF 05         .dw fs_chmod                  ; 14
1043   059A 80 0D         .dw fs_mv                     ; 15
1044   059C E8 05         .dw fs_cd_root                ; 16
1045   059E BE 09         .dw fs_get_curr_dirID         ; 17
1046   05A0 9A 07         .dw fs_dir_id_to_path         ; 18
1047   05A2 00 08         .dw fs_path_to_dir_id_user    ; 19
1048   05A4 1A 09         .dw fs_load_from_path_user    ; 20  
1049   05A6 8A 08         .dw fs_filepath_exists_user   ; 21
