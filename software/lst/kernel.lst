0936   0510 42 68 16      mov [fifo_out], a             ; update fifo pointer
0937   0513 E9            pop ah
0938   0514             ; here we just echo the char back to the console
0939   0514             ;syscall_io_getch_echo_L0:
0940   0514             ;  mov al, [_UART0_LSR]         ; read Line Status Register
0941   0514             ;  test al, $20                 ; isolate Transmitter Empty
0942   0514             ;  jz syscall_io_getch_echo_L0
0943   0514             ;  mov al, ah
0944   0514             ;  mov [_UART0_DATA], al        ; write char to Transmitter Holding Register
0945   0514 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0946   0516 E7            pop d
0947   0517 E5            pop b
0948   0518 06            sysret
