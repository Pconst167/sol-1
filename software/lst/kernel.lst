0610   02FB 22 FF         mov ah, $FF    
0611   02FD 3C            mov d, a                ; get to FFA9 + offset
0612   02FE 1B            mov al, bl              ; get data back
0613   02FF F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0614   0303 3E            mov [d], al             ; set data
0615   0304 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0616   0308 EA            pop bl
0617   0309 E7            pop d
0618   030A E8            pop al
0619   030B 06            sysret
