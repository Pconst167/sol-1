0624   02DB             syscall_rtc_get:
0625   02DB 6A A9         add al, $A9             ; generate RTC address to get to address A9 of clock
0626   02DD 22 FF         mov ah, $FF    
0627   02DF 3C            mov d, a                ; get to FFA9 + offset
0628   02E0 F2 A8 FF 40   mov byte[$FFA8], $40    ; set R bit to 1
0629   02E4 1E            mov al, [d]             ; get data
0630   02E5 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset R bit
0631   02E9 23            mov ah, al
0632   02EA E7            pop d
0633   02EB E8            pop al
0634   02EC 06            sysret
