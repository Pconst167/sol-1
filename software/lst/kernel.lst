0917   0503             ; char in ah
0918   0503             ; al = sucess code
0919   0503             syscall_io_getch:
0920   0503 D8            push b
0921   0504 DA            push d
0922   0505             syscall_io_getch_L0:  
0923   0505 14 B2 16      mov a, [fifo_out]
0924   0508 29 B0 16      mov b, [fifo_in]
0925   050B B0            cmp a, b
0926   050C C6 34 05      je syscall_io_getch_fail
0927   050F 3C            mov d, a
0928   0510 1E            mov al, [d]
0929   0511 DB            push al
