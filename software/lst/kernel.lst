1006   057C             ;------------------------------------------------------------------------------------------------------;
1007   057C             ; FILE SYSTEM DATA
1008   057C             ;------------------------------------------------------------------------------------------------------;
1009   057C             ; infor for : IDE SERVICES INTERRUPT
1010   057C             ; IDE read/write 512-byte sector
1011   057C             ; al = option
1012   057C             ; user buffer pointer in D
1013   057C             ; AH = number of sectors
1014   057C             ; CB = LBA bytes 3..0  
1015   057C             ;------------------------------------------------------------------------------------------------------;
1016   057C             ; FILE SYSTEM DATA STRUCTURE
1017   057C             ;------------------------------------------------------------------------------------------------------;
1018   057C             ; for a directory we have the header first, followed by metadata
1019   057C             ; header 1 sector (512 bytes)
1020   057C             ; metadata 1 sector (512 bytes)
1021   057C             ; HEADER ENTRIES:
1022   057C             ; filename (64)
1023   057C             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1024   057C             ;
1025   057C             ; metadata entries:
1026   057C             ; filename (24)
1027   057C             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1028   057C             ; LBA (2)
1029   057C             ; size (2)
1030   057C             ; day (1)
1031   057C             ; month (1)
1032   057C             ; year (1)
1033   057C             ; packet size = 32 bytes
1034   057C             ;
1035   057C             ; first directory on disk is the root directory '/'
1036   057C             file_system_jmptbl:
1037   057C E7 05         .dw fs_mkfs                   ; 0
1038   057E 00 00         .dw 0                         ; 1
1039   0580 49 06         .dw fs_mkdir                  ; 2
1040   0582 C2 09         .dw fs_cd                     ; 3
1041   0584 CA 09         .dw fs_ls                     ; 4
1042   0586 00 00         .dw 0                  ; 5
1043   0588 7C 0B         .dw fs_mkbin                  ; 6
1044   058A 43 0C         .dw fs_pwd                    ; 7
1045   058C 60 0C         .dw fs_cat                    ; 8
1046   058E BC 0C         .dw fs_rmdir                  ; 9
1047   0590 18 0D         .dw fs_rm                     ; 10
1048   0592 D7 0A         .dw fs_starcom                ; 11
1049   0594 00 00         .dw 0                         ; 12
1050   0596 00 00         .dw 0                         ; 13
1051   0598 EF 05         .dw fs_chmod                  ; 14
1052   059A 80 0D         .dw fs_mv                     ; 15
1053   059C E8 05         .dw fs_cd_root                ; 16
1054   059E BE 09         .dw fs_get_curr_dirID         ; 17
1055   05A0 9A 07         .dw fs_dir_id_to_path         ; 18
1056   05A2 00 08         .dw fs_path_to_dir_id_user    ; 19
1057   05A4 1A 09         .dw fs_load_from_path_user    ; 20  
1058   05A6 8A 08         .dw fs_filepath_exists_user   ; 21
1059   05A8             
1060   05A8 0A 3E 20 73 s_syscall_fs_dbg0: .db "\n> syscall_file_system called: ", 0
1060   05AC 79 73 63 61 
1060   05B0 6C 6C 5F 66 
1060   05B4 69 6C 65 5F 
1060   05B8 73 79 73 74 
1060   05BC 65 6D 20 63 
1060   05C0 61 6C 6C 65 
