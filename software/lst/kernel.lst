1062   05C8 DD            push bl
1063   05C9 31 D9 16      mov bl, [sys_debug_mode]
1064   05CC               ; debug block
1065   05CC C1 00         cmp bl, 0
1066   05CE EA            pop bl
1067   05CF C6 E3 05      je syscall_filesystem_jmp
1068   05D2 DA            push d
1069   05D3 DD            push bl
1070   05D4 3B A8 05      mov d, s_syscall_fs_dbg0
1071   05D7 07 B8 11      call _puts
1072   05DA 2F            mov bl, al
1073   05DB 07 54 12      call print_u8x
1074   05DE 07 65 11      call printnl
1075   05E1 EA            pop bl
1076   05E2 E7            pop d
1077   05E3             syscall_filesystem_jmp:
1078   05E3 FD 0A 7C 05   jmp [file_system_jmptbl + al]
