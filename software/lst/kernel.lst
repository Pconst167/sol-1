1285   0766 FD 50         mov di, d
1286   0768 07 F2 0F      call _strcpy                  ; copy directory name
1287   076B 58 18 00      add d, 24                     ; goto ATTRIBUTES
1288   076E 19 0B         mov al, %00001011             ; directory, no execute, write, read, 
1289   0770 3E            mov [d], al      
1290   0771 79            inc d
1291   0772 E5            pop b                         ; new directory's LBA itself. for self-referential directory entry '.'
1292   0773 FD 43         mov [d], b                    ; save LBA
1293   0775             ; set file creation date  
1294   0775 58 04 00      add d, 4
1295   0778 19 04         mov al, 4
1296   077A 05 01         syscall sys_rtc
1297   077C 1A            mov al, ah
1298   077D 3E            mov [d], al                   ; set day
1299   077E 79            inc d
1300   077F 19 05         mov al, 5
1301   0781 05 01         syscall sys_rtc
1302   0783 1A            mov al, ah
1303   0784 3E            mov [d], al                   ; set month
1304   0785 79            inc d
1305   0786 19 06         mov al, 6
1306   0788 05 01         syscall sys_rtc
1307   078A 1A            mov al, ah
1308   078B 3E            mov [d], al                   ; set year
