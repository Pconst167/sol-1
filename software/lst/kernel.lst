0030   07CB             ; SYSTEM CONSTANTS
0031   07CB             _UART0_DATA       .equ $FF80            ; data
0032   07CB             _UART0_DLAB_0     .equ $FF80            ; divisor latch low byte
0033   07CB             _UART0_DLAB_1     .equ $FF81            ; divisor latch high byte
0034   07CB             _UART0_IER        .equ $FF81            ; Interrupt enable register
0035   07CB             _UART0_FCR        .equ $FF82            ; FIFO control register
0036   07CB             _UART0_LCR        .equ $FF83            ; line control register
0037   07CB             _UART0_LSR        .equ $FF85            ; line status register
0038   07CB             _UART1_DATA       .equ $FF90            ; data
0039   07CB             _UART1_DLAB_0     .equ $FF90            ; divisor latch low byte
0040   07CB             _UART1_DLAB_1     .equ $FF91            ; divisor latch high byte
0041   07CB             _UART1_IER        .equ $FF91            ; Interrupt enable register
0042   07CB             _UART1_FCR        .equ $FF92            ; FIFO control register
0043   07CB             _UART1_LCR        .equ $FF93            ; line control register
0044   07CB             _UART1_LSR        .equ $FF95            ; line status register
0045   07CB             _ide_BASE         .equ $FFD0            ; IDE BASE
0046   07CB             _ide_R0           .equ _ide_BASE + 0    ; DATA PORT
0047   07CB             _ide_R1           .equ _ide_BASE + 1    ; READ: ERROR CODE, WRITE: FEATURE
0048   07CB             _ide_R2           .equ _ide_BASE + 2    ; NUMBER OF SECTORS TO TRANSFER
0049   07CB             _ide_R3           .equ _ide_BASE + 3    ; SECTOR ADDRESS LBA 0 [0:7]
0050   07CB             _ide_R4           .equ _ide_BASE + 4    ; SECTOR ADDRESS LBA 1 [8:15]
0051   07CB             _ide_R5           .equ _ide_BASE + 5    ; SECTOR ADDRESS LBA 2 [16:23]
0052   07CB             _ide_R6           .equ _ide_BASE + 6    ; SECTOR ADDRESS LBA 3 [24:27 (LSB)]
0053   07CB             _ide_R7           .equ _ide_BASE + 7    ; READ: STATUS, WRITE: COMMAND
0054   07CB             _7SEG_DISPLAY     .equ $FFB0            ; BIOS POST CODE HEX DISPLAY (2 DIGITS)
0055   07CB             _BIOS_POST_CTRL   .equ $FFB3            ; BIOS POST DISPLAY CONTROL REGISTER, 80h = As Output
0056   07CB             _PIO_A            .equ $FFB0    
0057   07CB             _PIO_B            .equ $FFB1
0058   07CB             _PIO_C            .equ $FFB2
0059   07CB             _PIO_CONTROL      .equ $FFB3            ; PIO CONTROL PORT
0060   07CB             _TIMER_C_0        .equ $FFE0            ; TIMER COUNTER 0
0061   07CB             _TIMER_C_1        .equ $FFE1            ; TIMER COUNTER 1
0062   07CB             _TIMER_C_2        .equ $FFE2            ; TIMER COUNTER 2
0063   07CB             _TIMER_CTRL       .equ $FFE3            ; TIMER CONTROL REGISTER
0064   07CB             STACK_BEGIN       .equ $F7FF            ; beginning of stack
0065   07CB             FIFO_SIZE         .equ (1024 * 4)
0066   07CB             TEXT_ORG          .equ $400
0067   07CB             
0068   07CB             ; For the next iteration:
0069   07CB             ; boot-sector(1) | kernel-sectors(32) | inode-bitmap | rawdata-bitmap | inode-table | raw-disk-data
0070   07CB             ; inode-table format:
0071   07CB             ;  file-type(f, d)
0072   07CB             ;  permissons
0073   07CB             ;  link-count
0074   07CB             ;  filesize
0075   07CB             ;  time-stamps
0076   07CB             ;  15 data block pointers
0077   07CB             ;  single-indirect pointer
0078   07CB             
0079   07CB             ; FILE ENTRY ATTRIBUTES
0080   07CB             ; filename (24)
0081   07CB             ; attributes (1)       :|0|0|file_type(3bits)|x|w|r|
0082   07CB             ; LBA (2)          : location of raw data for file entry, or dirID for directory entry
0083   07CB             ; size (2)          : filesize
0084   07CB             ; day (1)           
0085   07CB             ; month (1)
0086   07CB             ; year (1)
0087   07CB             ; packet size = 32 bytes  : total packet size in bytes
0088   07CB             FST_ENTRY_SIZE          .equ 32  ; bytes
0089   07CB             FST_FILES_PER_SECT      .equ (512 / FST_ENTRY_SIZE)
0090   07CB             FST_FILES_PER_DIR       .equ (512 / FST_ENTRY_SIZE)
0091   07CB             FST_NBR_DIRECTORIES     .equ 64
0092   07CB                                     ; 1 sector for header, the rest is for the list of files/dirs
0093   07CB             FST_SECTORS_PER_DIR     .equ (1 + (FST_ENTRY_SIZE * FST_FILES_PER_DIR / 512))    
0094   07CB             FST_TOTAL_SECTORS       .equ (FST_SECTORS_PER_DIR * FST_NBR_DIRECTORIES)
0095   07CB             FST_LBA_START           .equ 32
0096   07CB             FST_LBA_END             .equ (FST_LBA_START + FST_TOTAL_SECTORS - 1)
0097   07CB             
0098   07CB             FS_NBR_FILES            .equ (FST_NBR_DIRECTORIES * FST_FILES_PER_DIR)
0099   07CB             FS_SECTORS_PER_FILE     .equ 32         ; the first sector is always a header with a NULL parameter (first byte)
0100   07CB                                                     ; so that we know which blocks are free or taken
0101   07CB             FS_FILE_SIZE            .equ (FS_SECTORS_PER_FILE * 512)                  
0102   07CB             FS_TOTAL_SECTORS        .equ (FS_NBR_FILES * FS_SECTORS_PER_FILE)
0103   07CB             FS_LBA_START            .equ (FST_LBA_END + 1)
0104   07CB             FS_LBA_END              .equ (FS_LBA_START + FS_NBR_FILES - 1)
0105   07CB             
0106   07CB             CF_CARD_LBA_SIZE        .equ $800       ; temporary small size
0107   07CB             
0108   07CB             ROOT_DIR_ID:            .equ FST_LBA_START
