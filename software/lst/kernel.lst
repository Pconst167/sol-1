1183   06B1 58 20 00      add d, FST_ENTRY_SIZE
1184   06B4 0A AC 06      jmp fs_mkdir_L2                ; we look for a NULL entry here but dont check for limits. CARE NEEDED WHEN ADDING TOO MANY FILES TO A DIRECTORY
1185   06B7             fs_mkdir_found_null2:
1186   06B7 FD 4D BA 1B   mov si, user_data
1187   06BB FD 50         mov di, d
1188   06BD 07 ED 0F      call _strcpy                    ; copy directory name
1189   06C0 58 18 00      add d, 24                       ; goto ATTRIBUTES
1190   06C3 19 0B         mov al, %00001011               ; directory, no execute, write, read
1191   06C5 3E            mov [d], al      
1192   06C6 79            inc d
1193   06C7 E5            pop b
1194   06C8 D8            push b                          ; push LBA back
1195   06C9 FD 43         mov [d], b                      ; save LBA
1196   06CB             ; set file creation date  
1197   06CB 58 04 00      add d, 4
1198   06CE 19 04         mov al, 4
1199   06D0 05 01         syscall sys_rtc
1200   06D2 1A            mov al, ah
1201   06D3 3E            mov [d], al                     ; set day
1202   06D4 79            inc d
1203   06D5 19 05         mov al, 5
1204   06D7 05 01         syscall sys_rtc
1205   06D9 1A            mov al, ah
1206   06DA 3E            mov [d], al                     ; set month
1207   06DB 79            inc d
1208   06DC 19 06         mov al, 6
1209   06DE 05 01         syscall sys_rtc
1210   06E0 1A            mov al, ah
1211   06E1 3E            mov [d], al                     ; set year
1212   06E2             ; write sector into disk for new directory entry
1213   06E2 FD 27         mov b, g
1214   06E4 38 00 00      mov c, 0
1215   06E7 3B BA 27      mov d, transient_area
1216   06EA 22 01         mov ah, $01                     ; disk write, 1 sector
1217   06EC 07 7E 04      call ide_write_sect             ; write sector
1218   06EF             
1219   06EF             ; after adding the new directory's information to its parent directory's list
1220   06EF             ; we need to now enter the new directory, and to it add two new directories!
1221   06EF             ; which directories do we need to add ? '..' and '.' are the directories needed.
1222   06EF             ; importantly, note that these two new directories are only entries in the list
1223   06EF             ; and do not have actual physical entries in the disk as real directories.
1224   06EF             ; i.e. they only exist as list entries in the new directory created so that
1225   06EF             ; the new directory can reference its parent and itself.
1226   06EF             ; We need to add both '..' and '.'
1227   06EF             ; this first section is for '..' and on the section below we do the same for '.'
1228   06EF E4            pop a                         ; retrieve the new directory's LBA  
1229   06F0 D7            push a                        ; and save again
1230   06F1 53 01 00      add a, 1
1231   06F4 27            mov b, a                      ; metadata sector
1232   06F5 38 00 00      mov c, 0
1233   06F8 FD 79         mov g, b                      ; save LBA
1234   06FA 3B BA 27      mov d, transient_area
1235   06FD 22 01         mov ah, $01                   ; disk read
1236   06FF 07 58 04      call ide_read_sect            ; read metadata sector
1237   0702             fs_mkdir_L3:
