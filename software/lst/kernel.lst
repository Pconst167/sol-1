1053   05E3 DD            push bl
1054   05E4 31 F9 16      mov bl, [sys_debug_mode]
1055   05E7               ; debug block
1056   05E7 C1 00         cmp bl, 0
1057   05E9 EA            pop bl
1058   05EA C6 FE 05      je syscall_filesystem_jmp
1059   05ED DA            push d
1060   05EE DD            push bl
1061   05EF 3B C3 05      mov d, s_syscall_fs_dbg0
1062   05F2 07 D8 11      call _puts
1063   05F5 2F            mov bl, al
1064   05F6 07 74 12      call print_u8x
1065   05F9 07 85 11      call printnl
1066   05FC EA            pop bl
1067   05FD E7            pop d
1068   05FE             syscall_filesystem_jmp:
1069   05FE FD 0A 97 05   jmp [file_system_jmptbl + al]
