0995   0571 1E            mov al, [d]
0996   0572 DB            push al
0997   0573 22 11         mov ah, XON
0998   0575 07 69 10      call _putchar
0999   0578 E9            pop ah
1000   0579 19 01         mov al, 1                    ; AL = 1 means a char successfully received
1001   057B E7            pop d
