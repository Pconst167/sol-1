0869   04C3             ; IO Syscall
0870   04C3             ;----------------------------------------------------------------------------------------------------;
0871   04C3             ; Baud  Divisor
0872   04C3             ; 50    2304
0873   04C3             ; 110   1047
0874   04C3             ; 300    384
0875   04C3             ; 600    192
0876   04C3             ; 1200    96
0877   04C3             ; 9600    12
0878   04C3             ; 19200    6
