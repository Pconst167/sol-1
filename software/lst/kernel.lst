0614   0304 DD            push bl
0615   0305 99            mov bl, ah              ; set data asIDE
0616   0306 6A A2         add al, $A2             ; generate RTC address to get to address A9 of clock
0617   0308 22 FF         mov ah, $FF    
0618   030A 3C            mov d, a                ; get to FFA9 + offset
0619   030B 1B            mov al, bl              ; get data back
0620   030C F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0621   0310 3E            mov [d], al             ; set data
0622   0311 F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0623   0315 EA            pop bl
0624   0316 E7            pop d
0625   0317 E8            pop al
0626   0318 06            sysret
