0909   04E5 1D 85 FF      mov al, [_UART0_LSR]         ; read Line Status Register
0910   04E8 93 20         test al, $20                 ; isolate Transmitter Empty
0911   04EA C6 E5 04      jz syscall_io_putchar_L0    
