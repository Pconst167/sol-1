1318   07B5             ;------------------------------------------------------------------------------------------------------;
1319   07B5             ; get path from a given directory dirID
1320   07B5             ; pseudo code:
1321   07B5             ;  fs_dir_id_to_path(int dirID, char *D){
1322   07B5             ;    if(dirID == 0){
1323   07B5             ;      reverse path in D;
1324   07B5             ;      return;
1325   07B5             ;    }
1326   07B5             ;    else{
1327   07B5             ;      copy directory name to end of D;
1328   07B5             ;      add '/' to end of D;
1329   07B5             ;      parentID = get parent directory ID;
1330   07B5             ;      fs_dir_id_to_path(parentID, D);
1331   07B5             ;    }
1332   07B5             ;  }
1333   07B5             ; A = dirID
1334   07B5             ; D = generated path string pointer
1335   07B5             ;------------------------------------------------------------------------------------------------------;
1336   07B5             ; sample path: /usr/bin
1337   07B5             fs_dir_id_to_path:
1338   07B5 3B 9B 1B      mov d, filename
1339   07B8 19 00         mov al, 0
1340   07BA 3E            mov [d], al                     ; initialize path string 
1341   07BB 14 30 17      mov a, [current_dirID]
1342   07BE 07 CB 07      call fs_dir_id_to_path_E0
1343   07C1 3B 9B 1B      mov d, filename
1344   07C4 07 A1 0F      call _strrev
1345   07C7 07 FE 11      call _puts
1346   07CA 06            sysret
1347   07CB             fs_dir_id_to_path_E0:
1348   07CB 07 EA 07      call get_dirname_from_dirID
1349   07CE FD 4D 42 17   mov si, s_fslash
1350   07D2 FD 50         mov di, d
1351   07D4 07 1B 10      call _strcat                    ; add '/' to end of path
1352   07D7 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1353   07DA C6 E9 07      je fs_dir_id_to_path_root
1354   07DD 07 07 08      call get_parentID_from_dirID    ; use current ID (A) to find parentID (into A)
1355   07E0 AF 20 00      cmp a, root_id               ; check if we are at the root directory
1356   07E3 C6 E9 07      je fs_dir_id_to_path_root
1357   07E6 07 CB 07      call fs_dir_id_to_path_E0     ; recursively call itself
1358   07E9             fs_dir_id_to_path_root:
1359   07E9 09            ret
1360   07EA             
1361   07EA             ;------------------------------------------------------------------------------------------------------;
1362   07EA             ; in_puts:
1363   07EA             ; A = directory ID
1364   07EA             ; out_puts:
1365   07EA             ; D = pointer to directory name string
1366   07EA             ;------------------------------------------------------------------------------------------------------;
1367   07EA             get_dirname_from_dirID:
1368   07EA D7            push a
1369   07EB D8            push b
1370   07EC DA            push d
1371   07ED 27            mov b, a
1372   07EE 38 00 00      mov c, 0                      ; reset LBA to 0
1373   07F1 22 01         mov ah, $01                   ; disk read
1374   07F3 3B 1B 3C      mov d, transient_area - 512
1375   07F6 07 62 04      call ide_read_sect            ; read directory
1376   07F9 07 A1 0F      call _strrev                  ; reverse dir name before copying
1377   07FC FD 4E         mov si, d
1378   07FE E7            pop d                         ; destination address = D value pushed at beginning
1379   07FF FD 50         mov di, d
1380   0801 07 1B 10      call _strcat                  ; copy filename to D
1381   0804 E5            pop b
1382   0805 E4            pop a
1383   0806 09            ret
1384   0807             
1385   0807             ;------------------------------------------------------------------------------------------------------;
1386   0807             ; in_puts:
1387   0807             ; A = directory ID
1388   0807             ; out_puts:
1389   0807             ; A = parent directory ID
1390   0807             ;------------------------------------------------------------------------------------------------------;
1391   0807             get_parentID_from_dirID:
1392   0807 D8            push b
1393   0808 DA            push d
1394   0809 27            mov b, a
1395   080A 38 00 00      mov c, 0                      ; reset LBA to 0
