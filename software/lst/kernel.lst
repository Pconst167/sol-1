0612   02D4             ; RTC Services Syscall
0613   02D4             ; RTC I/O bank = FFA0 to FFAF
0614   02D4             ; FFA0 to FFA7 is scratch RAM
0615   02D4             ; Control register at $FFA8 [ W | R | S | Cal4..Cal0 ]
0616   02D4             ; al = 0..6 -> get
0617   02D4             ; al = 7..D -> set
0618   02D4             ; ------------------------------------------------------------------------------------------------------------------;
0619   02D4             syscall_rtc:
