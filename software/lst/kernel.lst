0941   0526 93 20         test al, $20                 ; isolate Transmitter Empty
0942   0528 C6 23 05      jz syscall_io_getch_echo_L0
0943   052B 1A            mov al, ah
0944   052C 3D 80 FF      mov [_UART0_DATA], al        ; write char to Transmitter Holding Register
0945   052F 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0946   0531 E7            pop d
0947   0532 E5            pop b
0948   0533 06            sysret
0949   0534             syscall_io_getch_fail:
0950   0534 E7            pop d
0951   0535 E5            pop b
0952   0536 19 00         mov al, 0                    ; AL = 0 means no char received
0953   0538 06            sysret
0954   0539             ; char in ah
0955   0539             ; al = sucess code
0956   0539             syscall_io_getch_noech:
0957   0539 D8            push b
0958   053A DA            push d
0959   053B             syscall_io_getch_noech_L0:  
0960   053B 14 B2 16      mov a, [fifo_out]
0961   053E 29 B0 16      mov b, [fifo_in]
0962   0541 B0            cmp a, b
0963   0542 C6 5E 05      je syscall_io_getch_noech_fail
0964   0545 3C            mov d, a
0965   0546 1E            mov al, [d]
0966   0547 DB            push al
0967   0548 14 B2 16      mov a, [fifo_out]
0968   054B 77            inc a
0969   054C AF 9F 25      cmp a, fifo + FIFO_SIZE      ; check if pointer reached the end of the fifo
0970   054F C7 55 05      jne syscall_io_getch_noech_cont
0971   0552 10 9F 1D      mov a, fifo  
0972   0555             syscall_io_getch_noech_cont:  
0973   0555 42 B2 16      mov [fifo_out], a             ; update fifo pointer
0974   0558 E9            pop ah
0975   0559 19 01         mov al, 1                    ; AL = 1 means a char successfully received
0976   055B E7            pop d
0977   055C E5            pop b
0978   055D 06            sysret
0979   055E             syscall_io_getch_noech_fail:
0980   055E E7            pop d
0981   055F E5            pop b
0982   0560 19 00         mov al, 0                    ; AL = 0 means no char received
0983   0562 06            sysret
