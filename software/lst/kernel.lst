0982   05C4             ;------------------------------------------------------------------------------------------------------;
0983   05C4             ; FILE SYSTEM DATA
0984   05C4             ;------------------------------------------------------------------------------------------------------;
0985   05C4             ; infor for : IDE SERVICES INTERRUPT
0986   05C4             ; IDE read/write 512-byte sector
0987   05C4             ; al = option
0988   05C4             ; user buffer pointer in D
0989   05C4             ; AH = number of sectors
0990   05C4             ; CB = LBA bytes 3..0  
0991   05C4             ;------------------------------------------------------------------------------------------------------;
0992   05C4             ; FILE SYSTEM DATA STRUCTURE
0993   05C4             ;------------------------------------------------------------------------------------------------------;
0994   05C4             ; for a directory we have the header first, followed by metadata
0995   05C4             ; header 1 sector (512 bytes)
0996   05C4             ; metadata 1 sector (512 bytes)
0997   05C4             ; HEADER ENTRIES:
0998   05C4             ; filename (64)
0999   05C4             ; parent dir LBA (2) -  to be used for faster backwards navigation...
1000   05C4             ;
1001   05C4             ; metadata entries:
1002   05C4             ; filename (24)
1003   05C4             ; attributes (1)  |_|_|file_type(3bits)|x|w|r| types: file, directory, character device
1004   05C4             ; LBA (2)
1005   05C4             ; size (2)
1006   05C4             ; day (1)
1007   05C4             ; month (1)
1008   05C4             ; year (1)
1009   05C4             ; packet size = 32 bytes
1010   05C4             ;
1011   05C4             ; first directory on disk is the root directory '/'
1012   05C4             file_system_jmptbl:
1013   05C4 2F 06         .dw fs_mkfs                   ; 0
1014   05C6 00 00         .dw 0                         ; 1
1015   05C8 91 06         .dw fs_mkdir                  ; 2
1016   05CA 0A 0A         .dw fs_cd                     ; 3
1017   05CC 12 0A         .dw fs_ls                     ; 4
1018   05CE 00 00         .dw 0                  ; 5
1019   05D0 C4 0B         .dw fs_mkbin                  ; 6
1020   05D2 8B 0C         .dw fs_pwd                    ; 7
1021   05D4 A8 0C         .dw fs_cat                    ; 8
1022   05D6 04 0D         .dw fs_rmdir                  ; 9
1023   05D8 60 0D         .dw fs_rm                     ; 10
1024   05DA 1F 0B         .dw fs_starcom                ; 11
1025   05DC 00 00         .dw 0                         ; 12
1026   05DE 00 00         .dw 0                         ; 13
1027   05E0 37 06         .dw fs_chmod                  ; 14
1028   05E2 C8 0D         .dw fs_mv                     ; 15
1029   05E4 30 06         .dw fs_cd_root                ; 16
1030   05E6 06 0A         .dw fs_get_curr_dirID         ; 17
1031   05E8 E2 07         .dw fs_dir_id_to_path         ; 18
1032   05EA 48 08         .dw fs_path_to_dir_id_user    ; 19
1033   05EC 62 09         .dw fs_load_from_path_user    ; 20  
1034   05EE D2 08         .dw fs_filepath_exists_user   ; 21
