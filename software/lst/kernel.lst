0618   0AD4 1B            mov al, bl              ; get data back
0619   0AD5 F2 A8 FF 80   mov byte[$FFA8], $80    ; set W bit to 1
0620   0AD9 3E            mov [d], al             ; set data
0621   0ADA F2 A8 FF 00   mov byte[$FFA8], 0      ; reset write bit
0622   0ADE EA            pop bl
0623   0ADF E7            pop d
0624   0AE0 E8            pop al
0625   0AE1 06            sysret
