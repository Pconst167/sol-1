1006   0565 DD            push bl
1007   0566 31 59 16      mov bl, [sys_debug_mode]
1008   0569               ; debug block
1009   0569 C1 00         cmp bl, 0
1010   056B EA            pop bl
1011   056C C6 80 05      je syscall_filesystem_jmp
1012   056F DA            push d
1013   0570 DD            push bl
1014   0571 3B 45 05      mov d, s_syscall_fs_dbg0
1015   0574 07 30 11      call _puts
1016   0577 2F            mov bl, al
1017   0578 07 D0 11      call print_u8x
1018   057B 07 DD 10      call printnl
1019   057E EA            pop bl
1020   057F E7            pop d
